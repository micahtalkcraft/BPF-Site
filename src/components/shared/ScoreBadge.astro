---
interface Props {
  score: number;
  size?: "sm" | "md" | "lg";
}

const { score, size = "md" } = Astro.props;

function solidBg(s: number) {
  if (s >= 88) return "bg-green-500";
  if (s >= 82) return "bg-green-400";
  if (s >= 76) return "bg-lime-500";
  if (s >= 70) return "bg-yellow-400";
  if (s >= 62) return "bg-amber-500";
  return "bg-red-500";
}
---

{size === "lg" ? (
  <div
    class={`flex flex-col items-center justify-center w-14 h-14 rounded-xl ${solidBg(score)} shadow-md`}
    title={`Score: ${score}/100`}
  >
    <span class="text-xl font-black text-white leading-none">{score}</span>
    <span class="text-[9px] text-white/70 font-medium leading-none mt-0.5">/100</span>
  </div>
) : (
  <span
    class={`inline-flex items-center rounded-full text-white font-semibold ${solidBg(score)} ${size === "sm" ? "text-xs px-2 py-0.5" : "text-sm px-2.5 py-1"}`}
    title={`Score: ${score}/100`}
  >
    {score}
  </span>
)}
