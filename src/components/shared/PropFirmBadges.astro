---
/**
 * Quick-glance badge strip for a prop firm.
 * All values come from the canonical PropFirm record — never hardcoded.
 */
import type { PropFirm, Review } from "../../content/config";

interface Props {
  firm: PropFirm;
  review?: Review;
}

const { firm, review } = Astro.props;
---

<div class="flex flex-wrap gap-2 text-xs">
  <!-- Score (only if review with score exists) -->
  {review?.overallScore !== undefined && (
    <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-2.5 py-1 font-medium text-blue-700 ring-1 ring-blue-200">
      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
      {review.overallScore}/100
    </span>
  )}

  <!-- Status warning -->
  {firm.status !== "active" && (
    <span class="rounded-full bg-amber-100 px-2.5 py-1 font-medium text-amber-800 ring-1 ring-amber-300 uppercase tracking-wide">
      {firm.status}
    </span>
  )}

  <!-- Evaluation types -->
  {firm.evaluation.types.map((t) => (
    <span class="rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-600 ring-1 ring-slate-200 capitalize">
      {t}
    </span>
  ))}

  <!-- Max payout split -->
  {firm.payouts.splitMax !== null && (
    <span class="rounded-full bg-violet-50 px-2.5 py-1 font-medium text-violet-700 ring-1 ring-violet-200">
      {firm.payouts.splitMax}% split
    </span>
  )}

  <!-- Max drawdown -->
  {firm.evaluation.maxDrawdown !== null && (
    <span class="rounded-full bg-teal-50 px-2.5 py-1 font-medium text-teal-700 ring-1 ring-teal-200">
      {firm.evaluation.maxDrawdown}% DD
    </span>
  )}

  <!-- Notable flags -->
  {(firm.trust.notableFlags ?? []).length > 0 && (
    <span class="rounded-full bg-red-100 px-2.5 py-1 font-medium text-red-700 ring-1 ring-red-300">
      ⚠ Flagged
    </span>
  )}
</div>
