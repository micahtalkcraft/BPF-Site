---
/**
 * Renders quick-glance badges for a broker or prop firm.
 * Accepts the raw entity data and a review record.
 * All values must come from the entity's canonical fields — never hardcoded.
 */
import type { Broker, PropFirm, Review } from "../../content/config";

interface Props {
  entity: Broker | PropFirm;
  review: Review;
  entityType: "broker" | "prop-firm";
}

const { entity, review, entityType } = Astro.props;

const regCount =
  entityType === "broker"
    ? (entity as Broker).licenses.filter((l) => l.status === "active").length
    : 0;

const minDeposit =
  entityType === "broker"
    ? (entity as Broker).fees.minDeposit
    : null;

const platforms = entity.platforms ?? (entity as PropFirm).markets?.platforms ?? [];

const maxPayout =
  entityType === "prop-firm"
    ? (entity as PropFirm).fundingModel.payoutSplitMax
    : null;
---

<div class="flex flex-wrap gap-2 text-xs">
  <!-- Score -->
  <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-2.5 py-1 font-medium text-blue-700 ring-1 ring-blue-200">
    <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
    {review.overallScore}/100
  </span>

  <!-- Regulation -->
  {
    regCount > 0 && (
      <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 font-medium text-emerald-700 ring-1 ring-emerald-200">
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        {regCount} {regCount === 1 ? "Licence" : "Licences"}
      </span>
    )
  }

  <!-- Platforms -->
  {
    platforms.slice(0, 3).map((p) => (
      <span class="rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-600 ring-1 ring-slate-200">
        {p}
      </span>
    ))
  }
  {platforms.length > 3 && (
    <span class="rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-500">
      +{platforms.length - 3}
    </span>
  )}

  <!-- Min deposit (broker only) -->
  {
    minDeposit !== null && minDeposit !== undefined && (
      <span class="rounded-full bg-violet-50 px-2.5 py-1 font-medium text-violet-700 ring-1 ring-violet-200">
        Min ${minDeposit}
      </span>
    )
  }

  <!-- Payout split (prop firm only) -->
  {
    maxPayout !== null && maxPayout !== undefined && (
      <span class="rounded-full bg-violet-50 px-2.5 py-1 font-medium text-violet-700 ring-1 ring-violet-200">
        {maxPayout}% split
      </span>
    )
  }
</div>
