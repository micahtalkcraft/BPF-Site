        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">$200,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;975</td>
          <td class="px-4 py-3 text-right text-slate-700">8% ($16,000)</td>
          <td class="px-4 py-3 text-right text-slate-700">5% ($10,000)</td>
          <td class="px-4 py-3 text-right text-slate-700">5% ($10,000)</td>
