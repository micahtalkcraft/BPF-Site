  <div class="rounded-xl bg-teal-50 border border-teal-200 p-4 mb-4">
    <p class="text-xs font-bold text-teal-800 uppercase tracking-wide mb-2">Scaling Qualification Criteria</p>
    <ul class="text-sm text-teal-700 space-y-1 list-disc list-inside">
