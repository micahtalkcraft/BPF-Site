---
// Static editorial content for Funded Trading Plus
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Simulated Environment Banner -->
  <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 mb-6 flex items-start gap-3">
    <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
    <div>
      <p class="text-sm font-bold text-blue-900 mb-1">Simulated Trading Environment</p>
      <p class="text-sm text-blue-800">All FTP accounts operate in a simulated trading environment. Payouts are based on simulated profits. Traders do not manage real capital directly.</p>
    </div>
  </div>

  <!-- Overview -->
  <p class="mb-4">
    Funded Trading Plus currently offers three core programmes: <strong>Instant Funding</strong>, <strong>1-Step Express</strong>, and <strong>2-Step Classic</strong>. Older models listed in help articles (Master, Experienced, Advanced, Premium, Prestige Lite, Prestige Pro) are legacy and no longer the main offerings.
  </p>
  <p class="mb-4">
    Drawdown rules, payout schedules, and trading restrictions vary by programme, so it's important to review the specific terms for your chosen model before signing up.
  </p>

  <!-- Per-programme summaries -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Instant Funding</p>
      <p>No evaluation required — start trading immediately with the strictest risk rules. 6% daily and 6% max drawdown (both relative). Account sizes from $5,000 to $100,000. Withdraw from day 1, then every 7 days.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Skip the evaluation entirely and start withdrawing profits immediately</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">1-Step Express</p>
      <p>One-step evaluation with a 10% profit target, 4% daily drawdown, and 6% max drawdown (relative). Account sizes from $10,000 to $200,000. Withdraw from day 1 once funded, then every 7 days.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Fast path to funding with no minimum trading days or time limits</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">2-Step Classic</p>
      <p>Traditional two-step evaluation with 10% and 5% profit targets, 4% daily drawdown, and 8% max drawdown (static). Account sizes from $10,000 to $200,000. 10-day payout cycle. Consistency rule applies.</p>
