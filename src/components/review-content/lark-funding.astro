    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <div class="flex items-center gap-2 mb-1">
        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-teal-500 text-white text-xs font-bold">2</span>
        <p class="font-bold text-slate-900">One Step Challenge</p>
