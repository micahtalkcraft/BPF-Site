    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2.5 text-center">
      <p class="text-[10px] text-slate-500 uppercase tracking-wider font-semibold mb-0.5">Account Sizes</p>
      <p class="text-base font-bold text-slate-800">$5K – $200K</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2.5 text-center">
