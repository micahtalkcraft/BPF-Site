  <!-- Per-model summaries -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1 flex items-center gap-2">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500 text-white text-xs font-black flex items-center justify-center">1</span>
        Instant Funding Starter
