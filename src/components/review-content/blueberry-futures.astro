            <td class="px-3 py-3 text-right text-slate-700">1 day &ge; $200</td>
            <td class="px-3 py-3 text-right text-slate-700">1 day &ge; $200</td>
          </tr>
          <tr class="bg-white">
            <td class="px-3 py-3 font-medium text-slate-900">Max Contracts</td>
            <td class="px-3 py-3 text-right text-slate-700">2 minis / 20 micros</td>
            <td class="px-3 py-3 text-right text-slate-700">6 minis / 60 micros</td>
