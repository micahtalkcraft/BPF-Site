---
// Static editorial content for IC Funded
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Simulated environment notice -->
  <div class="rounded-xl border-l-4 border-amber-400 bg-amber-50/60 px-5 py-4 mb-6">
    <p class="text-sm font-semibold text-amber-800 mb-1">Simulated Trading Environment</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      All trading at IC Funded is conducted in a simulated trading environment, including evaluation phases and the funded stage.
    </p>
  </div>

  <!-- Overview -->
  <p class="mb-4">
    IC Funded offers two evaluation models: a <strong>one step</strong> and a <strong>two step</strong> challenge. The one step challenge has a single profit target with tighter drawdown limits and a 45% consistency rule, while the two step challenge spreads the evaluation across two phases with more drawdown room. The programmes differ in daily drawdown, max drawdown, minimum trading days, and weekend holding rules.
  </p>
  <p class="mb-6">
    IC Funded does not provide services in the United States, Canada, and other restricted jurisdictions.
  </p>

  <!-- ─── Challenge Comparison Table ──────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-10">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-3 py-3 text-left">Evaluation Process</th>
          <th class="px-3 py-3 text-center">One Step Challenge</th>
          <th class="px-3 py-3 text-center">Two Step Challenge</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-3 py-3 font-medium text-slate-600">Challenge Fees</td>
          <td class="px-3 py-3 text-center text-slate-900">$154 &ndash; $1,495</td>
          <td class="px-3 py-3 text-center text-slate-900">$74 &ndash; $1,475</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-3 py-3 font-medium text-slate-600">Account Sizes</td>
          <td class="px-3 py-3 text-center text-slate-900">$10K &ndash; $200K</td>
          <td class="px-3 py-3 text-center text-slate-900">$5K &ndash; $200K</td>
        </tr>
        <tr class="bg-white">
          <td class="px-3 py-3 font-medium text-slate-600">Profit Target</td>
          <td class="px-3 py-3 text-center text-slate-900">10%</td>
          <td class="px-3 py-3 text-center text-slate-900">10% (Step 1), 5% (Step 2)</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-3 py-3 font-medium text-slate-600">Max Daily Loss</td>
          <td class="px-3 py-3 text-center text-slate-900">3%</td>
          <td class="px-3 py-3 text-center text-slate-900">4% (Step 1), 5% (Step 2)</td>
        </tr>
        <tr class="bg-white">
          <td class="px-3 py-3 font-medium text-slate-600">Max Overall Loss</td>
          <td class="px-3 py-3 text-center text-slate-900">6%</td>
          <td class="px-3 py-3 text-center text-slate-900">8% (Step 1), 10% (Step 2)*</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-3 py-3 font-medium text-slate-600">Minimum Trading Days</td>
          <td class="px-3 py-3 text-center text-slate-900">3</td>
          <td class="px-3 py-3 text-center text-slate-900">3 per step</td>
        </tr>
        <tr class="bg-white">
          <td class="px-3 py-3 font-medium text-slate-600">Max Trading Days</td>
          <td class="px-3 py-3 text-center text-slate-400">Unlimited</td>
          <td class="px-3 py-3 text-center text-slate-400">Unlimited</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-3 py-3 font-medium text-slate-600">Consistency Rule</td>
          <td class="px-3 py-3 text-center text-slate-900">45%</td>
          <td class="px-3 py-3 text-center text-slate-900">Soft 45% (Step 1)</td>
        </tr>
        <tr class="bg-white">
          <td class="px-3 py-3 font-medium text-slate-600">Weekend Holding</td>
