---
// Static editorial content for FTMO
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    FTMO's audition fees vary depending on the account size and type you select, ranging from <strong>&euro;155</strong> for a 10K account up to <strong>&euro;1,080</strong> for a 200K account. These fees cover the entire evaluation process, including both the Challenge and Verification phases. Fees are refundable upon successful completion.
  </p>

  <!-- Fee Table -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Audition Fees</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-8">
    <table class="w-full text-sm">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Account Size</th>
          <th class="px-4 py-3 text-right">Audition Fee</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">&euro;10,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;155</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">&euro;25,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;250</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">&euro;50,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;345</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">&euro;100,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;540</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">&euro;200,000</td>
          <td class="px-4 py-3 text-right text-slate-900">&euro;1,080</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Account Types -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Account Types</h3>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- STANDARD ACCOUNT                                                -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-8">
    <h4 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">1</span>
      Standard Account
    </h4>
    <p class="mb-4">
      The Standard Account is FTMO's default option, designed with typical profit targets and risk limits. Traders need to achieve a <strong>10% profit target</strong> during the Challenge, dropping to <strong>5%</strong> during Verification. Daily loss limit is <strong>5%</strong>, maximum overall loss is <strong>10%</strong>. Ideal for traders who prefer a balanced approach with moderate risk.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-3">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Challenge Target</p>
        <p class="text-sm font-bold text-slate-800">10%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Verification Target</p>
        <p class="text-sm font-bold text-slate-800">5%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Daily Loss</p>
        <p class="text-sm font-bold text-slate-800">5%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Overall Loss</p>
        <p class="text-sm font-bold text-slate-800">10%</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- AGGRESSIVE ACCOUNT                                              -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-8">
    <h4 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">2</span>
      Aggressive Account
    </h4>
    <p class="mb-4">
      The Aggressive Account is structured for strategies that aim for larger profits but carry higher risks. The profit target is increased to <strong>20%</strong> during the Challenge and <strong>10%</strong> during Verification, with a <strong>10% daily loss limit</strong> and <strong>20% maximum overall loss</strong>. Suitable for traders comfortable with higher drawdowns.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-3">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Challenge Target</p>
        <p class="text-sm font-bold text-slate-800">20%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Verification Target</p>
        <p class="text-sm font-bold text-slate-800">10%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Daily Loss</p>
        <p class="text-sm font-bold text-slate-800">10%</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Overall Loss</p>
        <p class="text-sm font-bold text-slate-800">20%</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- SWING ACCOUNT                                                    -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-8">
    <h4 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">3</span>
      Swing Account
    </h4>
    <p class="mb-4">
      The Swing Account is specifically designed for traders who hold positions over longer periods, including weekends and during significant news events. It follows the same profit targets and loss limits as the Standard account, but operates with reduced leverage &mdash; up to <strong>1:30</strong> for forex pairs, compared to 1:100 on Standard and Aggressive accounts.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-3">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Weekend Holding</p>
        <p class="text-sm font-bold text-teal-600">Allowed</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">News Trading</p>
        <p class="text-sm font-bold text-teal-600">Allowed</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Forex Leverage</p>
        <p class="text-sm font-bold text-slate-800">1:30</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Same Targets As</p>
        <p class="text-sm font-bold text-slate-800">Standard</p>
      </div>
    </div>
  </div>

  <!-- ─── Scaling Plan ────────────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Scaling &amp; Increased Profit Splits</h3>
  <p class="mb-4">
    FTMO's automatic scaling system increases account balance by <strong>25% every four months</strong> for consistent performers. To qualify, traders must achieve a 10% profit over four consecutive months (or 2.5% per month average for Standard accounts). As your account scales up, the profit split can increase from the standard 80% to <strong>90%</strong>.
  </p>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Scale-Up Amount</p>
      <p class="text-sm font-bold text-teal-600">25%</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Scaling Interval</p>
      <p class="text-sm font-bold text-slate-800">Every 4 months</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Allocation</p>
      <p class="text-sm font-bold text-teal-600">$2,000,000</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Profit Split</p>
      <p class="text-sm font-bold text-teal-600">90%</p>
    </div>
  </div>

  <!-- ─── How to Pass ────────────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">How to Pass the FTMO Challenge</h3>
  <p class="mb-4">
    FTMO's evaluation consists of two key steps: the <strong>FTMO Challenge</strong> and <strong>FTMO Verification</strong>. Minimum 4 trading days required in each phase. Loss limits are dynamic and adjust proportionally to your account balance.
  </p>

  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-4">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Rule</th>
          <th class="px-4 py-3 text-center">Standard</th>
          <th class="px-4 py-3 text-center">Aggressive</th>
          <th class="px-4 py-3 text-center">Swing</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Challenge Profit Target</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
          <td class="px-4 py-3 text-center text-slate-900">20%</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Verification Target</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Max Daily Loss</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Max Overall Loss</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
          <td class="px-4 py-3 text-center text-slate-900">20%</td>
          <td class="px-4 py-3 text-center text-slate-900">10%</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Leverage (Forex)</td>
          <td class="px-4 py-3 text-center text-slate-900">1:100</td>
          <td class="px-4 py-3 text-center text-slate-900">1:100</td>
          <td class="px-4 py-3 text-center text-slate-900">1:30</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Weekend Holding</td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span></td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span></td>
          <td class="px-4 py-3 text-center"><span class="text-teal-600 font-bold">&#10003;</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">News Trading</td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span> <span class="text-xs text-slate-500">2-min rule</span></td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span> <span class="text-xs text-slate-500">2-min rule</span></td>
          <td class="px-4 py-3 text-center"><span class="text-teal-600 font-bold">&#10003;</span></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Other Rules -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Other Rules</h3>
  <div class="space-y-3 mb-6">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">No Mandatory Stop Loss</p>
      <p>You are not required to use a stop loss during the Challenge, Verification, or as a funded trader.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">No Lot Size Limits</p>
      <p>There is no limit on the number of lots you can trade.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">News Trading Restriction (Standard &amp; Aggressive)</p>
      <p>Cannot open or close trades on targeted assets within <strong>2 minutes</strong> before or after significant news releases. Non-targeted assets are exempt. FTMO provides an economic calendar listing restricted events.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Multiple Accounts</p>
      <p>Traders can manage multiple accounts with a total combined limit of <strong>$400,000</strong> before scaling adjustments.</p>
    </div>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on FTMO Challenges &amp; Accounts</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      FTMO offers account sizes from &euro;10,000 to &euro;200,000, with fees ranging from &euro;155 to &euro;1,080. The evaluation process includes two phases &mdash; Challenge and Verification. The Standard account suits balanced trading, the Aggressive account allows for higher risk, and the Swing account offers flexibility for longer-term trades with reduced leverage. FTMO's scaling feature increases account sizes and profit splits for consistent traders, making it a solid option for those looking for long-term growth.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* SPREADS / COMMISSION FEES & PRICING SECTION                         */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "spreads" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-6">
    FTMO operates differently from many other prop trading firms by not using a third-party forex broker. Instead, they partner with various liquidity providers to offer an <strong>institutional data feed</strong>, ensuring direct market access (DMA) and RAW spreads. The funds on funded accounts are virtual &mdash; FTMO mirrors your trades on their own live accounts.
  </p>

  <!-- Forex Spreads -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Forex Spreads</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-8">
    <table class="w-full text-sm">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Currency Pair</th>
          <th class="px-4 py-3 text-right">Typical Spread</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">EUR/USD</td>
          <td class="px-4 py-3 text-right font-semibold text-teal-600">0.22 pips</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">GBP/USD</td>
          <td class="px-4 py-3 text-right text-slate-900">0.65 pips</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">USD/JPY</td>
          <td class="px-4 py-3 text-right text-slate-900">0.27 pips</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Commission Fees -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Commission Fees</h3>
  <p class="mb-4">
    FTMO charges commissions on trades, unlike some other prop firms that absorb these costs.
  </p>

  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-6">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Asset Class</th>
          <th class="px-4 py-3 text-right">Commission</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">Forex</td>
          <td class="px-4 py-3 text-right text-slate-900">$3 per standard lot (round trip)</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">Equities</td>
          <td class="px-4 py-3 text-right text-slate-900">0.0040% of volume</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">Metals</td>
          <td class="px-4 py-3 text-right text-slate-900">0.0010% of volume</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on Spreads &amp; Commissions</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      FTMO scores well for its tight spreads with DMA execution, but the fact that they do not cover commission costs, unlike some other prop firms, has a slight impact on their overall ranking.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* MARKETS / FINANCIAL MARKETS & LEVERAGE SECTION                      */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "markets" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-6">
    With FTMO you can trade various asset classes including <strong>forex, commodities, indices, crypto, stocks and bonds</strong>. This diverse selection caters to traders with various strategies and preferences.
  </p>

  <!-- Market Categories -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Forex</p>
      <p>28 major currency pairs (EUR/USD, GBP/USD), 14 minor pairs (AUD/NZD, GBP/JPY), plus exotic pairs (USD/ZAR, USD/SEK).</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Commodities</p>
      <p>Gold (XAUUSD), Silver (XAGUSD), West Texas Intermediate (USOIL.cash), Brent Crude Oil (UKOIL.cash).</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Indices</p>
      <p>14 global indices including US30 (Dow Jones), GER40 (DAX), and UK100 (FTSE 100).</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Cryptocurrencies</p>
      <p>10 pairs including BTC/USD, ETH/USD, and LTC/USD.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Stocks</p>
      <p>Major global stocks including Apple (AAPL), Amazon (AMZN), and Tesla (TSLA).</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Bonds</p>
      <p>Government bonds for additional diversification.</p>
    </div>
  </div>

  <!-- Leverage Table -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Leverage by Account Type</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-6">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Asset Class</th>
          <th class="px-4 py-3 text-center">Standard / Aggressive</th>
          <th class="px-4 py-3 text-center">Swing</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-slate-900">Forex</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">1:100</td>
          <td class="px-4 py-3 text-center text-slate-900">1:30</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-semibold text-slate-900">Commodities</td>
          <td class="px-4 py-3 text-center text-slate-900">1:50</td>
          <td class="px-4 py-3 text-center text-slate-900">1:15</td>
