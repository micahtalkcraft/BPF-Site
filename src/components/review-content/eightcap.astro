---
// Static editorial content for Eightcap
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    Eightcap gives you three evaluation processes to choose from with its One Step, Two Step and short-session Day Trader challenges. The forex broker has created an interesting selection of challenges with something for everyone, and each operates within a simulated environment rather than a live market.
  </p>
  <p class="mb-4">
    The standard challenges range from $10K to $200K, with fees starting from $99 for the Two Step and $119 for the One Step. The fast-paced Day Trader challenges are much cheaper, with entry costs from $5, but all run on a fixed $10,000 balance.
  </p>

  <!-- Per-challenge summaries -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">One Step Challenge</p>
      <p>Account sizes from $10,000 to $200,000 with a single 10% profit target, 4% daily and 8% total drawdown. Minimum 5 trading days.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Add-on options: Earlier payout (7 days) or higher 90% profit split</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Two Step Challenge</p>
      <p>Account sizes from $10,000 to $200,000 with a 10% Phase 1 and 8% Phase 2 target, 5% daily and 10% total drawdown. Minimum 3 trading days per step.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Add-on options: Earlier payout (7 days) or higher 90% profit split</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Day Trader Challenge (1–8 Hours)</p>
      <p>Fixed $10,000 balance with stakes from $5 to $250. Choose a 1, 2, 4 or 8-hour session and a 2x, 5x or 10x payout multiplier. Instant payouts after successful sessions.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">No add-ons available — payouts are instant based on multiplier</p>
    </div>
  </div>

  <!-- ─── Comparison Table ───────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-10">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Feature</th>
          <th class="px-4 py-3 text-center">One Step</th>
          <th class="px-4 py-3 text-center">Two Step</th>
          <th class="px-4 py-3 text-center">Day Trader (1–8 Hr)</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Account Size Range</td>
          <td class="px-4 py-3 text-center text-slate-900">$10,000 – $200,000</td>
          <td class="px-4 py-3 text-center text-slate-900">$10,000 – $200,000</td>
          <td class="px-4 py-3 text-center text-slate-900">Fixed $10,000</td>
