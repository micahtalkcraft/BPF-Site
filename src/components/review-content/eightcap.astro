          <td class="px-4 py-3 text-center text-slate-900">Varies by multiplier</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Max Daily Loss</td>
          <td class="px-4 py-3 text-center text-slate-900">4%</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
          <td class="px-4 py-3 text-center text-slate-900">Fixed dollar drawdown</td>
