          <td class="px-4 py-3 text-center text-slate-900">$59 – $1,199</td>
          <td class="px-4 py-3 text-center text-slate-900">$5 – $500</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Evaluation Process</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">One Phase</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">Two Phase</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">1, 2, 4 or 8-hour</td>
