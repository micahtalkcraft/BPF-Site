---
// Static editorial content for Eightcap Challenges
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    Eightcap Challenges gives you three evaluation types to choose from: the <strong>Day Trader</strong>, <strong>One Phase</strong> and <strong>Two Phase</strong> challenges. Each operates within a simulated environment rather than a live market.
  </p>
  <p class="mb-4">
    One Phase and Two Phase challenges both run from <strong>$5,000 to $200,000</strong>, with fees starting from <strong>$59</strong> for the Two Phase and <strong>$69</strong> for the One Phase. The fast-paced Day Trader challenges are much cheaper, with entry costs from $5 to $500, but all run on a fixed $10,000 balance.
  </p>

  <!-- Per-challenge summaries -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">One Phase Challenge</p>
      <p>Account sizes from $5,000 to $200,000 with a single 10% profit target, 4% daily and 8% total drawdown. Minimum 5 trading days.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Add-on options: Earlier payout (7 days) or 90% profit split (standard is 80%)</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Two Phase Challenge</p>
      <p>Account sizes from $5,000 to $200,000 with a 10% Phase 1 and 8% Phase 2 target, 5% daily and 10% total drawdown. Minimum 3 trading days per step.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Add-on options: Earlier payout (7 days) or 90% profit split (standard is 80%)</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Day Trader Challenge (1–8 Hours)</p>
      <p>Fixed $10,000 balance with stakes from $5 to $500. Choose a 1, 2, 4 or 8-hour session and a 2x, 5x or 10x payout multiplier. A successful stake is multiplied and paid instantly.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">No add-ons available — payouts are instant based on multiplier</p>
    </div>
  </div>

  <!-- ─── Comparison Table ───────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-10">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Feature</th>
          <th class="px-4 py-3 text-center">One Phase</th>
          <th class="px-4 py-3 text-center">Two Phase</th>
          <th class="px-4 py-3 text-center">Day Trader (1–8 Hr)</th>
