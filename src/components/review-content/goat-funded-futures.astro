          <td class="px-4 py-3 text-center text-slate-900">$99</td>
          <td class="px-4 py-3 text-center text-slate-900">$349</td>
          <td class="px-4 py-3 text-center"><span class="text-red-500 font-semibold">Not Available</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Consistency Rule</td>
          <td class="px-4 py-3 text-center text-slate-900">50% (Eval) / 30% (Funded)</td>
          <td class="px-4 py-3 text-center text-slate-900">50% (Eval) / 30% (Funded)</td>
          <td class="px-4 py-3 text-center text-slate-900">20% of total profit per day</td>
