            <td class="px-4 py-3 text-right text-slate-900">$149</td>
            <td class="px-4 py-3 text-right text-slate-700">$9,000</td>
            <td class="px-4 py-3 text-right text-slate-700">$4,000</td>
            <td class="px-4 py-3 text-right text-slate-700">2.5%</td>
            <td class="px-4 py-3 text-right text-slate-700">9 minis / 90 micros</td>
          </tr>
          <tr class="bg-white">
            <td class="px-4 py-3 font-semibold text-slate-900">$150,000</td>
            <td class="px-4 py-3 text-right text-slate-900">$249</td>
            <td class="px-4 py-3 text-right text-slate-700">$12,000</td>
            <td class="px-4 py-3 text-right text-slate-700">$5,500</td>
            <td class="px-4 py-3 text-right text-slate-700">2.5%</td>
            <td class="px-4 py-3 text-right text-slate-700">12 minis / 120 micros</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 2. STATIC EVALUATION                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-10">
    <h3 class="text-lg font-bold text-slate-900 mb-3 flex items-center gap-2">
