---
// Static editorial content for Goat Funded Futures
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    Goat Funded Futures offers three evaluation types: <strong>EOD</strong>, <strong>Static</strong>, and <strong>Instant Funding</strong>. Each model has different pricing, rules, and drawdown logic. EOD and Static follow a monthly subscription structure, while Instant is a one-time fee model with immediate funding upon passing.
  </p>

  <!-- Per-challenge summaries -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">EOD Evaluation – Monthly Subscription</p>
      <p>Account sizes of $50K, $100K, and $150K with monthly fees from $99 to $249. Trailing EOD drawdown with no daily loss limits during evaluation. The only model that allows contract scaling mid-evaluation.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">2.5% daily loss limit applies only once funded</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Static Evaluation – Monthly Subscription</p>
      <p>Account sizes of $30K and $75K with monthly fees of $199 and $349. Fixed drawdown that never trails your equity. No daily loss limits and no minimum trading days.</p>
      <p class="text-xs text-teal-600 font-semibold mt-1">Predictable risk limits — drawdown stays static regardless of profit</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Instant Funding – One-Time Fee</p>
      <p>Account sizes of $25K, $50K, and $75K with one-time fees from $349 to $699. Trailing real-time drawdown with a 3% daily loss cap. Requires 7% profit target and at least 10 trading days with a minimum of 6 trades before first payout.</p>
      <p class="text-xs text-red-500 font-semibold mt-1">No reset option available — strictest risk rules</p>
    </div>
  </div>

  <!-- ─── Comparison Table ───────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-10">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Feature</th>
          <th class="px-4 py-3 text-center">EOD</th>
          <th class="px-4 py-3 text-center">Static</th>
          <th class="px-4 py-3 text-center">Instant Funding</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Account Sizes</td>
          <td class="px-4 py-3 text-center text-slate-900">$50K, $100K, $150K</td>
          <td class="px-4 py-3 text-center text-slate-900">$30K, $75K</td>
          <td class="px-4 py-3 text-center text-slate-900">$25K, $50K, $75K</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Fee Type</td>
          <td class="px-4 py-3 text-center text-slate-900">Monthly Subscription</td>
