    <!-- Suited For -->
    <div class="rounded-xl bg-teal-50 border border-teal-200 p-4 mb-5">
      <p class="text-xs font-bold text-teal-800 uppercase tracking-wide mb-1">Best Suited For</p>
      <p class="text-sm text-teal-700">Traders who want lower intraday drawdown pressure and the ability to scale contracts during evaluation. Ideal for swing or position trading strategies with no time pressure.</p>
