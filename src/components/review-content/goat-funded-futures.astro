        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Cost Range</td>
          <td class="px-4 py-3 text-center text-slate-900">$99 – $249/month</td>
          <td class="px-4 py-3 text-center text-slate-900">$199 – $349/month</td>
          <td class="px-4 py-3 text-center text-slate-900">$349 – $699</td>
