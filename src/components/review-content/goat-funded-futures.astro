          <td class="px-4 py-3 text-center text-slate-900">3%</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Min Trading Days</td>
          <td class="px-4 py-3 text-center text-slate-400">None</td>
          <td class="px-4 py-3 text-center text-slate-400">None</td>
          <td class="px-4 py-3 text-center text-slate-900">10 days before first payout</td>
        </tr>
        <tr class="bg-slate-50">
