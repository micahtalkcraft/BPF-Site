---
// Static editorial content for FXIFY Futures
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    FXIFY Futures offers three programs for simulated futures trading, designed to suit different experience levels and preferences. All accounts operate in a <strong>simulated trading environment</strong> designed to mirror futures market conditions.
  </p>

  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Standard Plan</p>
      <p>A cost-effective one-step evaluation with structured risk management and a step-by-step growth process. Monthly subscription from <strong>$89</strong>.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Expert Plan</p>
      <p>Higher position limits, no activation fee, and a higher default profit split for experienced traders. Monthly subscription from <strong>$149</strong>.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Straight to Sim Live Plan</p>
      <p>Provides a direct simulated funded account without an evaluation phase. Skip the challenge and start trading immediately.</p>
    </div>
  </div>

  <div class="rounded-xl border-l-4 border-amber-400 bg-amber-50/60 px-5 py-4 mb-8">
    <p class="text-sm text-slate-700 leading-relaxed">
      <strong>Subscription billing:</strong> Standard and Expert evaluations are <strong>monthly subscriptions</strong> that rebill until passed or cancelled. If you cancel your subscription, it remains active until the end of the billing cycle.
    </p>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- STANDARD PLAN                                                    -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
