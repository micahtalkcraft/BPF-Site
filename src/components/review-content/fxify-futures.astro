            <td class="px-3 py-3 text-right text-slate-700">$225</td>
          </tr>
          <tr class="bg-white">
            <td class="px-3 py-3 font-semibold text-slate-900">$150,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$349</td>
            <td class="px-3 py-3 text-right text-slate-700">$10,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$4,500</td>
            <td class="px-3 py-3 text-right text-slate-700">$6,000</td>
            <td class="px-3 py-3 text-center text-slate-900">15</td>
            <td class="px-3 py-3 text-right font-semibold text-teal-600">$0</td>
            <td class="px-3 py-3 text-right text-slate-700">$299</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ─── Add-Ons ─────────────────────────────────────────────────── -->
