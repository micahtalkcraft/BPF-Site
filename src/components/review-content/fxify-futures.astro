  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-10">
    <h3 class="text-lg font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">3</span>
