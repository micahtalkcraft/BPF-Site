---
// Static editorial content for FXIFY Futures
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    FXIFY Futures allows you to choose from two challenge types for futures trading, designed to suit different experience levels:
  </p>

  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Starter Plan</p>
      <p>Ideal if you prefer a structured futures evaluation with a lower entry fee and a step-by-step growth process.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Expert Plan</p>
      <p>Best for experienced traders wanting higher trading limits, no activation fees, and faster payouts with a higher profit split.</p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- STARTER PLAN                                                     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-10">
    <h3 class="text-lg font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">1</span>
      Starter Plan
    </h3>

    <p class="mb-3">
      The Starter Plan is perfect if you're looking for a cost-effective challenge with structured risk management. You'll follow a <strong>one-step evaluation</strong>, with no time limits and a minimum of <strong>four trading days</strong> required to pass. Once you meet the objectives, you can get funded with up to $150,000 in simulated capital.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-5">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Profit Split</p>
        <p class="text-sm font-bold text-teal-600">80% (up to 90%)</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Min Trading Days</p>
        <p class="text-sm font-bold text-slate-800">4 days</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Time Limit</p>
        <p class="text-sm font-bold text-teal-600">Unlimited</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Position Size</p>
        <p class="text-sm font-bold text-slate-800">Up to 12 contracts</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">First Payout</p>
        <p class="text-sm font-bold text-slate-800">After 14 days</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Activation Fee</p>
        <p class="text-sm font-bold text-slate-800">$125</p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-200 mb-5">
      <table class="w-full text-sm whitespace-nowrap">
        <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
          <tr>
            <th class="px-3 py-3 text-left">Account Size</th>
            <th class="px-3 py-3 text-right">Monthly Fee</th>
            <th class="px-3 py-3 text-right">Profit Target</th>
            <th class="px-3 py-3 text-right">Daily Loss (2%)</th>
            <th class="px-3 py-3 text-right">Max Loss (4%)</th>
            <th class="px-3 py-3 text-center">Max Contracts</th>
            <th class="px-3 py-3 text-right">Activation Fee</th>
            <th class="px-3 py-3 text-right">Reset Fee</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="bg-white">
            <td class="px-3 py-3 font-semibold text-slate-900">$50,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$89</td>
            <td class="px-3 py-3 text-right text-slate-700">$3,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$1,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$2,000</td>
            <td class="px-3 py-3 text-center text-slate-900">3</td>
            <td class="px-3 py-3 text-right text-slate-700">$125</td>
            <td class="px-3 py-3 text-right text-slate-700">$79</td>
          </tr>
          <tr class="bg-slate-50">
            <td class="px-3 py-3 font-semibold text-slate-900">$100,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$149</td>
            <td class="px-3 py-3 text-right text-slate-700">$6,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$2,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$4,000</td>
            <td class="px-3 py-3 text-center text-slate-900">7</td>
            <td class="px-3 py-3 text-right text-slate-700">$125</td>
            <td class="px-3 py-3 text-right text-slate-700">$125</td>
          </tr>
          <tr class="bg-white">
            <td class="px-3 py-3 font-semibold text-slate-900">$150,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$225</td>
            <td class="px-3 py-3 text-right text-slate-700">$9,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$3,000</td>
            <td class="px-3 py-3 text-right text-slate-700">$6,000</td>
            <td class="px-3 py-3 text-center text-slate-900">12</td>
            <td class="px-3 py-3 text-right text-slate-700">$125</td>
            <td class="px-3 py-3 text-right text-slate-700">$199</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- EXPERT PLAN                                                      -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="mb-10">
    <h3 class="text-lg font-bold text-slate-900 mb-3 flex items-center gap-2">
      <span class="flex-shrink-0 w-7 h-7 rounded-full bg-teal-500 text-white text-xs font-black flex items-center justify-center">2</span>
      Expert Plan
    </h3>

    <p class="mb-3">
      The Expert Plan is a better option if you're looking for higher position limits, faster payouts, and <strong>no activation fees</strong>. This plan offers more flexibility, allowing you to scale up quickly while benefiting from higher profit splits. With a minimum of <strong>three trading days</strong>, you can pass the evaluation and start earning from your funded account faster.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-5">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Profit Split</p>
        <p class="text-sm font-bold text-teal-600">90% (up to 100%)</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Min Trading Days</p>
        <p class="text-sm font-bold text-slate-800">3 days</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Time Limit</p>
        <p class="text-sm font-bold text-teal-600">Unlimited</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Position Size</p>
        <p class="text-sm font-bold text-slate-800">Up to 15 contracts</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">First Payout</p>
        <p class="text-sm font-bold text-slate-800">After 14 days</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Activation Fee</p>
        <p class="text-sm font-bold text-teal-600">$0</p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-200 mb-5">
      <table class="w-full text-sm whitespace-nowrap">
        <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
          <tr>
            <th class="px-3 py-3 text-left">Account Size</th>
            <th class="px-3 py-3 text-right">Monthly Fee</th>
            <th class="px-3 py-3 text-right">Profit Target</th>
            <th class="px-3 py-3 text-right">Daily Loss (3%)</th>
            <th class="px-3 py-3 text-right">Max Loss (4&ndash;5%)</th>
            <th class="px-3 py-3 text-center">Max Contracts</th>
            <th class="px-3 py-3 text-right">Activation Fee</th>
            <th class="px-3 py-3 text-right">Reset Fee</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="bg-white">
            <td class="px-3 py-3 font-semibold text-slate-900">$50,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$149</td>
            <td class="px-3 py-3 text-right text-slate-700">$3,500</td>
            <td class="px-3 py-3 text-right text-slate-700">$1,500</td>
            <td class="px-3 py-3 text-right text-slate-700">$2,500</td>
            <td class="px-3 py-3 text-center text-slate-900">5</td>
            <td class="px-3 py-3 text-right font-semibold text-teal-600">$0</td>
            <td class="px-3 py-3 text-right text-slate-700">$125</td>
          </tr>
          <tr class="bg-slate-50">
            <td class="px-3 py-3 font-semibold text-slate-900">$100,000</td>
            <td class="px-3 py-3 text-right text-slate-900">$249</td>
            <td class="px-3 py-3 text-right text-slate-700">$7,000</td>
