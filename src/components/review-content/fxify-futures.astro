        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-900">CME Price Limit Trading</td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span> <span class="text-slate-600">No trading within 2% of price limit</span></td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-900">Funded Account Reset</td>
          <td class="px-4 py-3 text-center"><span class="text-red-400 font-bold">&#10007;</span> <span class="text-slate-600">Funded accounts cannot be reset</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-900">Inactivity Penalty</td>
