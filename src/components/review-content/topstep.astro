        </tbody>
      </table>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-4">
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Profit Target</p>
        <p class="text-sm font-bold text-slate-800">6% of account</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Loss Limit</p>
        <p class="text-sm font-bold text-slate-800">3&ndash;4% of account</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Time Limit</p>
        <p class="text-sm font-bold text-emerald-600">Unlimited</p>
