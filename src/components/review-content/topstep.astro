            <td class="px-4 py-3 text-right text-emerald-600 font-semibold">No additional fee</td>
            <td class="px-4 py-3 text-right text-emerald-600 font-semibold">No target</td>
            <td class="px-4 py-3 text-right text-red-500">Account closure</td>
            <td class="px-4 py-3 text-right text-slate-700">$1,500</td>
          </tr>
          <tr class="bg-white">
            <td class="px-4 py-3 font-semibold text-slate-900">$150K</td>
            <td class="px-4 py-3 text-right text-emerald-600 font-semibold">No additional fee</td>
            <td class="px-4 py-3 text-right text-emerald-600 font-semibold">No target</td>
            <td class="px-4 py-3 text-right text-red-500">Account closure</td>
            <td class="px-4 py-3 text-right text-slate-700">$2,000</td>
