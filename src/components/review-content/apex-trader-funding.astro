---
// Static editorial content for Apex Trader Funding
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

  <!-- Overview -->
  <p class="mb-4">
    Apex Trader Funding has transitioned from legacy monthly subscription evaluations to <strong>one-time fee products</strong> with 30-day access and no recurring billing. Current products are split by drawdown model — <strong>EOD</strong> (End-of-Day) and <strong>Intraday</strong> — with vendor options including <strong>Rithmic</strong>, <strong>Tradovate</strong>, and <strong>WealthCharts</strong>. Account sizes available for new purchases are <strong>25K, 50K, 100K, and 150K</strong>.
  </p>

  <p class="mb-4">
    Evaluations have <strong>no minimum trading days</strong> and can be passed in as little as 1 day. Legacy products (250K, 300K, Static accounts, monthly subscriptions) are no longer available for new purchases.
  </p>

  <!-- Drawdown model cards -->
  <div class="space-y-3 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">EOD — End-of-Day Drawdown</p>
      <p>Trailing End-of-Day drawdown calculated at the close of each trading session. Includes a fixed <strong>Daily Loss Limit (DLL)</strong>. Suitable for traders who prefer a drawdown that only updates at end of day rather than in real time.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Intraday — Real-Time Drawdown</p>
      <p>Trailing real-time drawdown that updates continuously during the session. <strong>No Daily Loss Limit</strong>. Suitable for active intraday traders who want flexibility without a separate daily cap.</p>
    </div>
  </div>

  <!-- Key specs -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Evaluation Structure</h3>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 mb-4">
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Fee Type</p>
      <p class="text-sm font-bold text-teal-600">One-Time</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Access Period</p>
      <p class="text-sm font-bold text-slate-800">30 Days</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Min Trading Days</p>
      <p class="text-sm font-bold text-teal-600">None</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Resets</p>
      <p class="text-sm font-bold text-red-600">Not Available</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Account Sizes</p>
      <p class="text-sm font-bold text-slate-800">25K–150K</p>
    </div>
  </div>

  <!-- Comparison table -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">EOD vs Intraday Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-8">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Attribute</th>
          <th class="px-4 py-3 text-center">EOD</th>
          <th class="px-4 py-3 text-center">Intraday</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Drawdown Type</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">Trailing EOD</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">Trailing Real-Time</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Daily Loss Limit</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">Yes (fixed)</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">No DLL</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Account Sizes</td>
          <td class="px-4 py-3 text-center text-slate-900">25K, 50K, 100K, 150K</td>
          <td class="px-4 py-3 text-center text-slate-900">25K, 50K, 100K, 150K</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Min Trading Days</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">None</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">None</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Fee Type</td>
          <td class="px-4 py-3 text-center text-slate-900">One-time</td>
          <td class="px-4 py-3 text-center text-slate-900">One-time</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Vendors</td>
          <td class="px-4 py-3 text-center text-slate-900">Rithmic, Tradovate, WealthCharts</td>
          <td class="px-4 py-3 text-center text-slate-900">Rithmic, Tradovate, WealthCharts</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Funded Account (PA) details -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Performance Account (Funded)</h3>
  <p class="mb-3">
    After passing the evaluation, traders receive a funded Performance Account (PA). PA activation must be completed within <strong>7 calendar days</strong> of qualifying. Funded accounts use <strong>tier-based contract scaling</strong> — max contracts and Daily Loss Limit increase as you progress through tiers.
  </p>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-4">
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Payout Split</p>
      <p class="text-sm font-bold text-teal-600">100%</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Activation Fee</p>
      <p class="text-sm font-bold text-slate-800">One-time</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Scaling</p>
      <p class="text-sm font-bold text-slate-800">Tier-based</p>
    </div>
  </div>

  <!-- Legacy notice -->
  <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 mb-6">
    <p class="text-sm font-bold text-amber-900 mb-1">Legacy Products Retired</p>
    <p class="text-sm text-amber-800">
      Previous products (250K, 300K, Static accounts, monthly subscription evaluations) are no longer available for new purchases. All current evaluations use one-time fees with no recurring billing.
    </p>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on Challenges — 8/10</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      Apex has significantly improved its evaluation structure by moving to one-time fees with no recurring billing. The two drawdown models (EOD with DLL and Intraday without DLL) give traders flexibility. No minimum trading days, 30-day access, and account sizes from 25K to 150K make the evaluation accessible. The tier-based scaling on funded accounts rewards consistency, and the 100% payout split is competitive. The lack of resets on current products is a notable limitation.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* SPREADS / PRICING SECTION                                          */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "spreads" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-3">
    Apex Trader Funding's current products use <strong>one-time evaluation fees</strong> with 30-day access and no recurring billing. This replaces the legacy monthly subscription model. The PA activation fee is also a <strong>one-time payment</strong> per account (non-recurring).
  </p>

  <p class="mb-4">
    Evaluation fees start from <strong>$118</strong> for the 25K Rithmic Intraday product. Pricing varies by account size, drawdown model (EOD vs Intraday), and vendor (Rithmic, Tradovate, WealthCharts). Commission rates are not publicly disclosed but are typically estimated at <strong>$1.50–$2.50 per round turn</strong> depending on the instrument and vendor.
  </p>

  <!-- Fee structure overview -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-6">
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Eval Fee Type</p>
      <p class="text-sm font-bold text-teal-600">One-Time</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Starting From</p>
      <p class="text-sm font-bold text-slate-800">$118</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Recurring Billing</p>
      <p class="text-sm font-bold text-teal-600">None</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">PA Activation</p>
      <p class="text-sm font-bold text-slate-800">One-time fee</p>
    </div>
  </div>

  <!-- Commission note -->
  <div class="rounded-xl border border-slate-200 bg-white p-4 mb-6">
    <p class="font-bold text-slate-900 mb-1">Commission Rates</p>
    <p class="text-sm text-slate-700">Commission rates are not publicly disclosed in the current product documentation. Based on industry estimates, typical rates for CME futures range from <strong>$1.50–$2.50 per round turn</strong> depending on instrument and vendor. Traders should confirm specific commission rates before purchasing.</p>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on Pricing — 8/10</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      The move to one-time evaluation fees is a major improvement over the previous monthly subscription model. Starting from $118 with no recurring billing and 30-day access makes the evaluation more affordable and transparent. The one-time PA activation fee is clearer than the legacy monthly/lifetime activation choices. The lack of publicly disclosed commission rates is a minor gap.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* MARKETS SECTION                                                     */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "markets" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-4">
    Apex Trader Funding offers futures across multiple asset classes on <strong>CME, CBOT, NYMEX, and EUREX</strong> exchanges. Markets include equity, currency, agricultural, energy, and crypto futures (micro contracts only). However, <strong>COMEX and all metals are temporarily unavailable</strong> at present.
  </p>

  <!-- Market categories -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">EQ</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Equity Futures</p>
      <p class="text-xs text-slate-400 mt-1">ES, NQ, YM, RTY + micros</p>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">FX</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Currency Futures</p>
      <p class="text-xs text-slate-400 mt-1">6E, 6B, 6J, 6A + more</p>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">AG</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Agricultural Futures</p>
      <p class="text-xs text-slate-400 mt-1">ZC, ZW, ZS, HE, LE</p>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">EN</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Energy Futures</p>
      <p class="text-xs text-slate-400 mt-1">CL, NG, HO, RB</p>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">BTC</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Crypto Futures</p>
      <p class="text-xs text-slate-400 mt-1">Micro Bitcoin, Micro Ether only</p>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-center">
      <p class="text-2xl font-black text-slate-900 mb-1">EU</p>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">EUREX</p>
      <p class="text-xs text-slate-400 mt-1">European exchange futures</p>
    </div>
  </div>

  <!-- Metals warning -->
  <div class="rounded-xl border border-red-200 bg-red-50 p-4 mb-6">
    <p class="text-sm font-bold text-red-900 mb-1">Metals Temporarily Unavailable</p>
    <p class="text-sm text-red-800">
      COMEX and all metals futures (Gold, Silver, Copper, E-Micro Gold, etc.) are <strong>temporarily unavailable</strong>. The product set lists metals as part of its normal offering, but they cannot be traded at present. Traders requiring metals access should check for updates before purchasing.
    </p>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on Markets — 7/10</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      Apex covers a solid range of CME futures across equity, currency, agricultural, energy, and crypto (micro only), plus EUREX. The temporary unavailability of COMEX and all metals is a notable gap — traders who need gold, silver, or copper will need to wait or look elsewhere. Crypto is limited to micro contracts only.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* PLATFORMS SECTION                                                   */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "platforms" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-4">
    Apex Trader Funding's current products support three vendor options: <strong>Rithmic</strong>, <strong>Tradovate</strong>, and <strong>WealthCharts</strong>. NinjaTrader is available for the Rithmic setup, and RTrader Pro provides an additional option for Rithmic users. TradingView is not verified in the current product documentation.
  </p>

  <!-- Platform cards -->
  <div class="space-y-3 mb-6">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Rithmic</p>
      <p>High-speed execution with low-latency data feeds. Compatible with NinjaTrader for advanced charting, strategy automation, and custom indicators. Best suited for active traders who need fast execution and market depth.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">Tradovate</p>
      <p>Browser-based platform with mobile and desktop access. Intuitive interface with multi-device trading support. Ideal for traders who want flexibility across devices.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">WealthCharts</p>
      <p>Charting and analysis platform with modern interface. Available as a vendor option for both EOD and Intraday evaluations.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">NinjaTrader</p>
      <p>Advanced charting, algorithmic trading support, and custom indicators. Available for the Rithmic setup specifically. Free license provided for evaluation accounts.</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="font-bold text-slate-900 mb-1">RTrader Pro</p>
      <p>High-performance trading platform with low-latency data and real-time account monitoring. Available for Rithmic users. PC only.</p>
    </div>
  </div>

  <!-- Trading rules -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Trading Rules</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-6">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Rule</th>
          <th class="px-4 py-3 text-center">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Drawdown Models</td>
          <td class="px-4 py-3 text-center"><span class="text-slate-900 font-semibold">EOD (trailing + DLL) or Intraday (trailing, no DLL)</span></td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Min Trading Days (Eval)</td>
          <td class="px-4 py-3 text-center"><span class="text-teal-600 font-semibold">None — pass in 1 day</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Consistency Rule (Payout)</td>
          <td class="px-4 py-3 text-center"><span class="text-amber-600 font-semibold">50% — no single day ≥50% of profit</span></td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Contract Scaling</td>
          <td class="px-4 py-3 text-center"><span class="text-slate-900 font-semibold">Tier-based on funded accounts</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Weekend Holding</td>
          <td class="px-4 py-3 text-center"><span class="text-red-500 font-semibold">Not allowed</span></td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Automated Systems</td>
          <td class="px-4 py-3 text-center"><span class="text-amber-600 font-semibold">Not confirmed in current docs</span></td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Copy Trading</td>
          <td class="px-4 py-3 text-center"><span class="text-amber-600 font-semibold">Not confirmed in current docs</span></td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">News Trading</td>
          <td class="px-4 py-3 text-center"><span class="text-amber-600 font-semibold">Not confirmed in current docs</span></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 mb-6">
    <p class="text-sm font-bold text-amber-900 mb-1">Rules Data Gap</p>
    <p class="text-sm text-amber-800">
      Current product documentation does not clearly confirm rules for fully automated systems, semi-automated systems, copy trading, or news trading. If any of these are part of your strategy, confirm directly with Apex support before purchasing.
    </p>
  </div>

  <!-- Verdict -->
  <div class="rounded-xl border-l-4 border-teal-500 bg-teal-50/60 px-5 py-4">
    <p class="text-sm font-semibold text-teal-800 mb-1">Verdict on Platforms — 7/10</p>
    <p class="text-sm text-slate-700 leading-relaxed">
      Apex offers a solid platform stack with Rithmic, Tradovate, and WealthCharts as vendor options, plus NinjaTrader and RTrader Pro for Rithmic users. The two drawdown models and no minimum trading days give traders flexibility. The lack of confirmed rules on automation, copy trading, and news trading is a gap that traders should clarify before purchasing.
    </p>
  </div>

</div>
)}

{/* ════════════════════════════════════════════════════════════════════ */}
{/* PAYOUTS SECTION                                                     */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "payouts" && (
<div class="text-sm leading-relaxed text-slate-700">

  <p class="mb-4">
    Apex Trader Funding pays approved payouts at a <strong>100% split</strong>. Payout eligibility requires <strong>5 qualifying trading days</strong> with minimum daily profit thresholds. The safety net is required for the <strong>life of the PA</strong> — only profit above the safety net is eligible for withdrawal. Maximum <strong>6 payout requests per PA</strong>.
  </p>

  <!-- Payout overview grid -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-8">
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Profit Split</p>
      <p class="text-sm font-bold text-teal-600">100%</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Payout Eligibility</p>
      <p class="text-sm font-bold text-slate-800">5 qualifying days</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Min Payout</p>
      <p class="text-sm font-bold text-slate-800">$500</p>
    </div>
    <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
      <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Max Payouts</p>
      <p class="text-sm font-bold text-red-600">6 per PA</p>
    </div>
  </div>

  <!-- Payout rules table -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Payout Rules</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-6">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
