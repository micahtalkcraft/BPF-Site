      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Evaluation Steps</td>
          <td class="px-4 py-3 text-center font-semibold text-slate-900">One phase</td>
