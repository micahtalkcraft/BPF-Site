      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Drawdown Type</p>
        <p class="text-sm font-bold text-slate-800">Static (Balance-based)</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
