          <td class="px-4 py-3 text-center text-slate-900">$2,500 – $100,000</td>
          <td class="px-4 py-3 text-center text-slate-900">$2,500 – $100,000</td>
          <td class="px-4 py-3 text-center text-slate-900">$2,500 – $80,000</td>
