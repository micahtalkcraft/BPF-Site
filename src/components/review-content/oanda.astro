  <!-- ─── Comparison Table ───────────────────────────────────────── -->
  <h3 class="text-lg font-bold text-slate-900 mb-3">Challenge Comparison</h3>
  <div class="overflow-x-auto rounded-xl border border-slate-200 mb-10">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-slate-800 text-xs font-semibold text-white uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Feature</th>
          <th class="px-4 py-3 text-center">$5K – $200K</th>
          <th class="px-4 py-3 text-center">$500K</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Challenge Fees</td>
          <td class="px-4 py-3 text-center text-slate-900">$35 – $1,200</td>
          <td class="px-4 py-3 text-center text-slate-900">$2,400</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Profit Share</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">80%</td>
          <td class="px-4 py-3 text-center font-semibold text-teal-600">80%</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Phase 1 Profit Target</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
          <td class="px-4 py-3 text-center text-slate-900">8%</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-600">Phase 2 Profit Target</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
          <td class="px-4 py-3 text-center text-slate-900">5%</td>
