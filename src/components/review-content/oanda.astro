          <td class="px-4 py-3 font-medium text-slate-600">Max Total Loss</td>
          <td class="px-4 py-3 text-center text-slate-900">10% – Static Drawdown</td>
          <td class="px-4 py-3 text-center text-slate-900">10% – Trailing Drawdown</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-medium text-slate-600">Fee Refund</td>
          <td class="px-4 py-3 text-center text-slate-900">Yes, after first payout</td>
          <td class="px-4 py-3 text-center text-slate-900">Yes, after first payout</td>
        </tr>
