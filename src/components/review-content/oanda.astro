          </tr>
          <tr class="bg-white">
            <td class="px-4 py-3 font-semibold text-slate-900">$200,000</td>
            <td class="px-4 py-3 text-right text-slate-900">$1,200</td>
            <td class="px-4 py-3 text-right text-slate-700">$10,000</td>
            <td class="px-4 py-3 text-right text-slate-700">$10,000</td>
