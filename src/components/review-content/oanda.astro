      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Fee Refund</p>
        <p class="text-sm font-bold text-teal-600">After 1st payout</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Trading Days</p>
        <p class="text-sm font-bold text-slate-800">Unlimited</p>
      </div>
      <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide font-semibold">Inactivity Limit</p>
        <p class="text-sm font-bold text-slate-800">30 days</p>
      </div>
    </div>

    <!-- Suited For -->
    <div class="rounded-xl bg-teal-50 border border-teal-200 p-4 mb-5">
      <p class="text-xs font-bold text-teal-800 uppercase tracking-wide mb-1">Best Suited For</p>
      <p class="text-sm text-teal-700">Beginner to intermediate traders who prefer clear rules and a gradual evaluation process with consistent targets across both phases.</p>
    </div>

    <!-- Fee table -->
    <div class="overflow-x-auto rounded-xl border border-slate-200 mb-5">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3 text-left">Account Size</th>
            <th class="px-4 py-3 text-right">Fee</th>
            <th class="px-4 py-3 text-right">P1 Target</th>
            <th class="px-4 py-3 text-right">P2 Target</th>
            <th class="px-4 py-3 text-right">Max Daily Loss</th>
            <th class="px-4 py-3 text-right">Max Total Loss</th>
            <th class="px-4 py-3 text-right">Drawdown Type</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="bg-white">
            <td class="px-4 py-3 font-semibold text-slate-900">$5,000</td>
            <td class="px-4 py-3 text-right text-slate-900">$35</td>
            <td class="px-4 py-3 text-right text-slate-700">$250</td>
            <td class="px-4 py-3 text-right text-slate-700">$250</td>
