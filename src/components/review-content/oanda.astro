            <td class="px-4 py-3 text-right text-slate-700">$20,000</td>
            <td class="px-4 py-3 text-right text-slate-700">Static</td>
          </tr>
          <tr class="bg-slate-50">
            <td class="px-4 py-3 font-semibold text-slate-900">$500,000</td>
            <td class="px-4 py-3 text-right text-slate-900">$2,400</td>
