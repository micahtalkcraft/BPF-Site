          <td class="px-4 py-3 text-slate-700">Below $2,000</td>
          <td class="px-4 py-3 text-center text-slate-900">3 mini / 30 micro</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3 text-slate-700">$2,000 &ndash; $3,000</td>
          <td class="px-4 py-3 text-center text-slate-900">4 mini / 40 micro</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 text-slate-700">$3,000 and above</td>
