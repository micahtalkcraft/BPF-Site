---
// Static editorial content for Tradeify
// Supports multiple sections via the `section` prop
interface Props {
  section: string;
  fallbackBody?: string;
}
const { section, fallbackBody } = Astro.props;
---

{/* ════════════════════════════════════════════════════════════════════ */}
{/* CHALLENGES SECTION                                                  */}
{/* ════════════════════════════════════════════════════════════════════ */}
{section === "challenges" && (
<div class="text-sm leading-relaxed text-slate-700">

