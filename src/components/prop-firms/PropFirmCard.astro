---
import type { PropFirm, Review } from "../../content/config";
import ScoreBadge from "../shared/ScoreBadge.astro";
import PropFirmBadges from "../shared/PropFirmBadges.astro";

interface Props {
  firm: PropFirm;
  review: Review;
  rank?: number;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const { firm, review, rank } = Astro.props;

const lowestFee = firm.pricing.challengeFees.length > 0
  ? firm.pricing.challengeFees.reduce((min, f) => f.fee < min.fee ? f : min)
  : null;

// Zero-pad rank: 1 → "01", 10 → "10"
const rankLabel = rank !== undefined ? String(rank).padStart(2, "0") : null;

// Subtitle line: Est. YEAR · COUNTRY · COMMUNITY
const subtitleParts = [
  firm.foundedYear ? `Est. ${firm.foundedYear}` : null,
  firm.hqCountry ?? null,
  firm.trust.communitySize ?? null,
].filter(Boolean);
---

<article class="relative group rounded-xl border border-slate-200 bg-white px-7 py-6 shadow-sm hover:shadow-md hover:border-teal-200 transition-all duration-200 overflow-hidden">
  <!-- Left hover accent bar -->
  <span class="absolute left-0 top-4 bottom-4 w-0.5 rounded-r bg-teal-500 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></span>

  <div class="flex items-start gap-4">
    <!-- Rank -->
    {rankLabel && (
      <span class="flex-shrink-0 text-4xl font-black text-slate-200 w-12 text-center mt-1 leading-none select-none">
        {rankLabel}
      </span>
    )}

    <div class="flex-1 min-w-0">
      <!-- Name row -->
      <div class="flex items-start justify-between gap-3 flex-wrap">
        <div>
          <div class="flex items-center gap-1.5">
            <h2 class="text-2xl font-extrabold text-slate-900 leading-tight">
              <a href={`${base}/reviews/${firm.slug}/`} class="hover:text-teal-600 transition-colors">
                {firm.name}
              </a>
            </h2>
            <span class="relative group/verified flex-shrink-0">
              <svg class="h-[20px] w-[20px] text-[#1d9bf0]" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
              </svg>
              <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-[11px] font-semibold text-white opacity-0 group-hover/verified:opacity-100 transition-opacity duration-150 shadow-lg z-10">
                Verified
              </span>
            </span>
          </div>
          {subtitleParts.length > 0 && (
            <p class="text-xs text-slate-400 mt-0.5">
              {subtitleParts.join(" · ")}
            </p>
          )}
        </div>
        {review.overallScore !== undefined && (
          <ScoreBadge score={review.overallScore} size="lg" />
        )}
      </div>

      <!-- Badges -->
      <div class="mt-3">
        <PropFirmBadges firm={firm} review={review} />
      </div>

      <!-- Key stats grid -->
      <dl class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
        <div class="rounded-lg bg-slate-50 px-4 py-3">
          <dt class="text-[11px] text-slate-500 uppercase tracking-wide font-medium mb-0.5">Evaluation</dt>
          <dd class="font-bold text-slate-800 capitalize text-sm">
            {firm.evaluation.types.join(", ")}
          </dd>
        </div>
        <div class="rounded-lg bg-slate-50 px-4 py-3">
          <dt class="text-[11px] text-slate-500 uppercase tracking-wide font-medium mb-0.5">Max Payout</dt>
          <dd class={`font-bold text-sm ${firm.payouts.splitMax !== null ? "text-teal-600" : "text-slate-400"}`}>
            {firm.payouts.splitMax !== null ? `${firm.payouts.splitMax}%` : "—"}
          </dd>
        </div>
        <div class="rounded-lg bg-slate-50 px-4 py-3">
          <dt class="text-[11px] text-slate-500 uppercase tracking-wide font-medium mb-0.5">Max Drawdown</dt>
          <dd class="font-bold text-slate-800 text-sm">
            {firm.evaluation.maxDrawdown !== null ? `${firm.evaluation.maxDrawdown}%` : "—"}
          </dd>
        </div>
        <div class="rounded-lg bg-slate-50 px-4 py-3">
          <dt class="text-[11px] text-slate-500 uppercase tracking-wide font-medium mb-0.5">Daily Drawdown</dt>
          <dd class="font-bold text-slate-800 text-sm">
            {firm.evaluation.dailyDrawdown !== null ? `${firm.evaluation.dailyDrawdown}%` : "—"}
          </dd>
        </div>
      </dl>

      <!-- Lowest fee pill -->
      {lowestFee && (
        <p class="mt-3 inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-3 py-1 text-sm text-slate-600">
          From{" "}
          <span class="font-bold text-slate-900">${lowestFee.fee}</span>
          {" "}for a ${lowestFee.accountSize.toLocaleString()} account
        </p>
      )}

      <!-- Top 2 pros -->
      {review.pros.length > 0 && (
        <ul class="mt-3 space-y-1">
          {review.pros.slice(0, 2).map((pro) => (
            <li class="flex items-start gap-2 text-sm text-slate-600">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {pro}
            </li>
          ))}
        </ul>
      )}

      <!-- CTA row -->
      <div class="mt-4 flex items-center gap-3">
        <a
          href={`${base}/reviews/${firm.slug}/`}
          class="inline-flex items-center gap-1.5 rounded-lg bg-teal-500 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-600 transition-colors"
        >
          Full Review
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <p class="text-xs text-slate-400">Verified {firm.lastVerifiedAt}</p>
      </div>
    </div>
  </div>
</article>
