---
import Base from "../../layouts/Base.astro";
import { getAuthorProfileSchema, getBreadcrumbSchema, SITE_URL } from "../../helpers/schema";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "@id": `${SITE_URL}/about/noam-korbl/`,
    url: `${SITE_URL}/about/noam-korbl/`,
    name: "Noam Korbl — COO & Co-Founder",
    description: "Noam Korbl is the COO and Co-Founder of BestPropFirms.com. He holds a Bachelor of Business Administration from Monash University and an RG146 qualification.",
    dateModified: "2026-03-12",
    isPartOf: { "@id": `${SITE_URL}/#website` },
    mainEntity: getAuthorProfileSchema("noam-korbl"),
  },
  getBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "About Us", url: "/about/" },
    { name: "Noam Korbl" },
  ]),
];
---

<Base
  title="Noam Korbl — Co-Founder & Managing Director | BestPropFirms.com"
  description="Learn about Noam Korbl, co-founder of BestPropFirms.com. With expertise in finance and digital marketing, Noam drives strategic growth for the platform."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative bg-[#0d1b2a] text-white py-16 sm:py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(20,184,166,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(99,102,241,0.1),transparent_60%)]"></div>
    <div class="relative mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-8">
        <!-- Photo -->
        <div class="flex-shrink-0">
          <div class="w-44 h-44 sm:w-52 sm:h-52 rounded-full p-1 bg-gradient-to-br from-teal-400 via-emerald-400 to-teal-600 shadow-2xl shadow-teal-500/20">
            <div class="w-full h-full rounded-full overflow-hidden bg-white">
              <img
                src={`${base}/images/team/noam-korbl-300x280-1.png`}
                alt="Noam Korbl"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
        <!-- Info -->
        <div class="text-center sm:text-left">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/10 px-4 py-1.5 text-xs font-semibold text-teal-300 mb-4 backdrop-blur-sm">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Co-Founder &middot; BestPropFirms.com
          </div>
          <h1 class="text-4xl sm:text-5xl font-black mb-3 leading-tight">Noam Korbl</h1>
          <p class="text-lg text-teal-400 font-semibold mb-3">Co-Founder & Managing Director</p>
          <p class="text-slate-300 leading-relaxed max-w-xl">
            With a background in finance and digital marketing, Noam co-founded Best Prop Firms and CompareForexBrokers, combining data-driven strategy with hands-on experience to help traders compare firms more easily.
          </p>
          <!-- Social links -->
          <div class="flex items-center gap-3 mt-5 justify-center sm:justify-start">
            <a href="https://www.linkedin.com/in/noam-korbl-201a3266/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-blue-600 hover:border-blue-600 hover:text-white transition-all" aria-label="LinkedIn">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/nskorbz87" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-slate-700 hover:border-slate-600 hover:text-white transition-all" aria-label="X (Twitter)">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href={`${base}/contact`} class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-teal-600 hover:border-teal-600 hover:text-white transition-all" aria-label="Contact">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-16 pb-12">

    <!-- Co-Founder and Role -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Role</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Co-Founder<br/>& Managing Director</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed">
            Noam Korbl is the Co-Founder of the group behind Best Prop Firms and CompareForexBrokers. With a background in finance and digital marketing, Noam combines data-driven strategy with hands-on experience to help traders compare brokers and prop firms more easily. He's been central to building tools and content that make trading decisions clearer for both new and experienced traders.
          </p>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-2xl p-7 sm:p-8">
        <div class="flex items-center gap-3 mb-5">
          <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
          </svg>
          <h2 class="text-xl font-black text-blue-900">Education</h2>
        </div>
        <p class="text-blue-800 leading-relaxed mb-4">
          Noam graduated from <strong>Monash University</strong> in Melbourne, Australia with a <strong>Bachelor of Business</strong> (2011), with a focus on Banking &amp; Finance. His academic foundation in finance provides the analytical rigour behind the data-driven comparisons and content at Best Prop Firms and CompareForexBrokers.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Bachelor of Business
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Banking & Finance
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Monash University
          </span>
        </div>
      </div>
    </section>

    <!-- Career in Digital Marketing -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Career</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Digital Marketing<br/>& Business</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed mb-4">
            Noam started his digital marketing journey in 2012 at <strong class="text-slate-800">Innovate Online</strong> (which later joined Nunn Media). Working across a range of marketing disciplines, he gained diverse experiences that sparked the idea for creating platforms like <strong class="text-slate-800">CompareForexBrokers</strong> and <strong class="text-slate-800">Best Prop Firms</strong> — sites built to give traders clear, data-backed comparisons in an industry that often lacks transparency.
          </p>
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-5 mt-4">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72l1.189-1.19A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72M6.75 18h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .414.336.75.75.75z" />
              </svg>
              <div>
                <p class="font-bold text-amber-900 text-sm mb-1">Entrepreneurial Ventures</p>
                <p class="text-sm text-amber-800 leading-relaxed">
                  In 2016, Noam co-founded <strong>Hearing Choices</strong>, a hearing aid company, and transitioned to working on it full-time in 2017. Today he balances his time across Best Prop Firms, CompareForexBrokers, and Hearing Choices — bringing the same data-driven, consumer-first approach to each venture.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Strengths -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-200 rounded-2xl p-7 sm:p-8">
        <div class="flex items-center gap-3 mb-5">
          <svg class="h-6 w-6 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
          </svg>
          <h2 class="text-xl font-black text-teal-900">Professional Strengths</h2>
        </div>
        <p class="text-teal-800 leading-relaxed mb-4">
          Noam's core strengths lie in <strong>sales</strong>, <strong>financial management</strong>, and <strong>leadership</strong>. Across every venture, his philosophy centres on building trust and fostering lasting connections — whether with business partners, team members, or the traders who use the platforms he's helped create.
        </p>
        <p class="text-teal-800 leading-relaxed">
          This trust-first approach underpins the editorial integrity at Best Prop Firms, where honest and transparent comparisons are a non-negotiable standard.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <div class="flex items-center gap-2 bg-teal-100 text-teal-700 rounded-lg px-4 py-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72l1.189-1.19A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72M6.75 18h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .414.336.75.75.75z" /></svg>
            <span class="text-sm font-bold">3 Companies</span>
          </div>
          <div class="flex items-center gap-2 bg-teal-100 text-teal-700 rounded-lg px-4 py-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span class="text-sm font-bold">Trust-First Approach</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Family Life -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Beyond Work</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Family Life</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed mb-5">
            Outside of work, Noam is a dedicated family man. He is a husband to Ora-Tali and a proud father to three children — Eilon, Yishai, and Yaella. Family is at the centre of everything he does, and the values of trust and connection that guide his professional life are rooted in his family.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full">
              <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
              Family Man
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full">
              <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
              Father of Three
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Connect -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-slate-100 to-slate-50 border border-slate-200 rounded-2xl p-7 sm:p-8 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Connect</p>
        <h2 class="text-2xl font-black text-slate-900 mb-3">Get in Touch with Noam</h2>
        <p class="text-slate-500 leading-relaxed max-w-lg mx-auto mb-6">
          To connect with Noam Korbl, visit his LinkedIn, X, or use our Contact page.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <a href="https://www.linkedin.com/in/noam-korbl-201a3266/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-all">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://x.com/nskorbz87" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:border-slate-400 hover:text-slate-800 transition-all">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href={`${base}/contact`} class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-teal-50 hover:border-teal-300 hover:text-teal-600 transition-all">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            Contact Us
          </a>
        </div>
      </div>
    </section>

    <!-- Meet the Team -->
    <section class="mb-8">
      <div class="text-center">
        <p class="text-sm text-slate-500 leading-relaxed">
          You can also read more about the rest of the team, including <a href={`${base}/about/tegan-miller`} class="font-semibold text-teal-600 hover:text-teal-500 transition-colors">Financial Writer Tegan Miller</a>, or <a href={`${base}/about/justin-grossbard`} class="font-semibold text-teal-600 hover:text-teal-500 transition-colors">Co-Founder Justin Grossbard</a>.
        </p>
      </div>
    </section>
  </div>

  <!-- Meet the Expert Traders Section -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-4xl">
      <div class="bg-gradient-to-br from-slate-900 via-slate-900 to-[#0d1b2a] rounded-2xl p-8 sm:p-10 lg:p-12">
        <div class="text-center mb-10">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Meet the Expert Traders</p>
          <h2 class="text-3xl font-black text-white">The Best Prop Firms Team and Vision</h2>
        </div>
        <p class="text-slate-300 leading-relaxed mb-5">
          Best Prop Firms was created to provide traders with clear, well-researched comparisons of proprietary trading firms. Our team consists of finance analysts, content strategists, and trading professionals who test the prop firms and challenges themselves before rating funding models, trading platforms, and profit-sharing agreements.
        </p>
