---
import Base from "../../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const articles = [
  {
    title: "What are the Best Forex Brokers in the USA?",
    outlet: "CBS News",
    color: "bg-blue-900 text-white",
    url: "https://www.cbsnews.com/news/what-are-the-best-forex-brokers-in-the-usa/",
  },
  {
    title: "Best Forex Trading Platforms in Australia",
    outlet: "Newcastle Herald",
    color: "bg-sky-600 text-white",
    url: "https://www.newcastleherald.com.au/story/8358719/best-forex-trading-platform-australia-guide/",
  },
  {
    title: "How to Trade Forex in NZ: 2024 Guide",
    outlet: "Otago Daily Times",
    color: "bg-emerald-700 text-white",
    url: "https://www.odt.co.nz/features/sponsored-content/how-trade-forex-nz-2024-guide",
  },
];

const mediaLogos = [
  { name: "CBS News", image: "/images/press/cnn-logo.png" },
];
---

<Base
  title="Tegan Miller — Financial Writer & Analyst | BestPropFirms.com"
  description="Learn about Tegan Miller, Financial Writer and Analyst at BestPropFirms.com. With expertise in economics, finance, and technical writing, Tegan creates data-driven content for traders."
>
  <!-- Hero -->
  <section class="relative bg-[#0d1b2a] text-white py-16 sm:py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(20,184,166,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(99,102,241,0.1),transparent_60%)]"></div>
    <div class="relative mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-8">
        <!-- Photo -->
        <div class="flex-shrink-0">
          <div class="w-44 h-44 sm:w-52 sm:h-52 rounded-full p-1 bg-gradient-to-br from-teal-400 via-emerald-400 to-teal-600 shadow-2xl shadow-teal-500/20">
            <div class="w-full h-full rounded-full overflow-hidden bg-white">
              <img
                src={`${base}/images/team/tegan-miller-300x280-1.png`}
                alt="Tegan Miller"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
        <!-- Info -->
        <div class="text-center sm:text-left">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/10 px-4 py-1.5 text-xs font-semibold text-teal-300 mb-4 backdrop-blur-sm">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Financial Writer &middot; BestPropFirms.com
          </div>
          <h1 class="text-4xl sm:text-5xl font-black mb-3 leading-tight">Tegan Miller</h1>
          <p class="text-lg text-teal-400 font-semibold mb-3">Financial Writer and Analyst</p>
          <p class="text-slate-300 leading-relaxed max-w-xl">
            Specialising in the prop trading and forex industries, Tegan creates data-driven, clear, and accessible content that helps traders understand complex trading concepts and make well-informed financial decisions.
          </p>
          <!-- Contact link -->
          <div class="flex items-center gap-3 mt-5 justify-center sm:justify-start">
            <a href={`${base}/contact`} class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-teal-600 hover:border-teal-600 hover:text-white transition-all" aria-label="Contact">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-16 pb-12">

    <!-- About -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">About</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">About<br/>Tegan Miller</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed mb-4">
            Tegan Miller is a seasoned finance writer and analyst, specialising in the prop trading and forex industries. With a background in Economics and Finance, Tegan has a proven track record of creating data-driven, clear, and accessible content for traders, helping audiences understand complex trading concepts and make well-informed financial decisions.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Writing technical content for websites like CompareForexBrokers.com and BestPropFirms.com, with a special interest in financial regulation and ethics, Tegan provides traders with reliable insights, comparisons, and strategies tailored to both beginner and professional traders alike.
          </p>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Education</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Academic<br/>Background</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100 flex items-center justify-center">
                <svg class="h-6 w-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-slate-900 text-lg">RMIT University</p>
                <p class="text-teal-600 font-semibold text-sm mb-2">Bachelor of Economics and Finance</p>
                <p class="text-slate-500 text-sm leading-relaxed">
                  Tegan developed a strong foundation in financial analysis, economic theories, and market dynamics. This academic background has been crucial to her success in producing insightful and practical content for the financial and trading sectors.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications & Media -->
    <section class="mb-16">
      <div class="text-center mb-8">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Media Presence</p>
        <h2 class="text-3xl font-black text-slate-900">Publications & Features</h2>
        <p class="text-slate-500 mt-2 max-w-xl mx-auto">Tegan's work has been featured in various well-regarded publications, providing valuable perspectives on trading platforms and industry trends.</p>
      </div>

      <!-- Article Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {articles.map((article) => (
          <a
            href={article.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-teal-200 transition-all"
          >
            <div class={`px-4 py-2 ${article.color}`}>
              <p class="text-[10px] font-bold uppercase tracking-widest opacity-90">{article.outlet}</p>
            </div>
            <div class="p-4">
              <p class="font-bold text-slate-900 text-sm leading-snug group-hover:text-teal-600 transition-colors mb-2">
                {article.title}
              </p>
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-teal-600">
                Read article
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <p class="text-sm text-slate-500 mt-5 text-center leading-relaxed max-w-2xl mx-auto">
        Through these contributions, Tegan has established herself as a trusted source of information for traders navigating forex and prop trading platforms globally.
      </p>
    </section>

    <!-- Expertise -->
    <section class="mb-16">
      <div class="text-center mb-8">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Skill Set</p>
        <h2 class="text-3xl font-black text-slate-900">Areas of Expertise</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-teal-200 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100 flex items-center justify-center mb-4">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1.5">In-Depth Financial Analysis</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Known for breaking down intricate trading systems and providing real-world context to guide traders.</p>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-teal-200 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100 flex items-center justify-center mb-4">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1.5">Technical Writing</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Skilled at creating engaging, informative content that resonates with a wide range of readers, with a clear, concise, and adaptable writing style.</p>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-teal-200 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100 flex items-center justify-center mb-4">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-slate-900 mb-1.5">Ethics in Financial Content</h3>
          <p class="text-sm text-slate-500 leading-relaxed">With a particular interest in financial regulation and ethical content development, Tegan ensures transparency and integrity are central to her work.</p>
        </div>
      </div>
    </section>

    <!-- Personal Life -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Beyond Work</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Personal<br/>Interests</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed">
            Beyond her professional endeavors, Tegan enjoys exploring the city's art galleries, experimenting with fusion cuisine, and traveling to remote locations to capture landscape photography. With a passion for both the arts and sciences, Tegan combines analytical skills with a creative outlook, bringing fresh perspectives to every project.
          </p>
        </div>
      </div>
    </section>

    <!-- Connect -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-slate-100 to-slate-50 border border-slate-200 rounded-2xl p-7 sm:p-8 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Connect</p>
        <h2 class="text-2xl font-black text-slate-900 mb-3">Get in Touch with Tegan</h2>
        <p class="text-slate-500 leading-relaxed max-w-lg mx-auto mb-6">
          To connect with Tegan Miller, use our Contact page.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <a href={`${base}/contact`} class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-teal-50 hover:border-teal-300 hover:text-teal-600 transition-all">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            Contact Us
          </a>
        </div>
      </div>
    </section>

    <!-- Meet the Team -->
    <section class="mb-8">
      <div class="text-center">
        <p class="text-sm text-slate-500 leading-relaxed">
          You can also read more about the rest of the team, including <a href={`${base}/about/justin-grossbard`} class="font-semibold text-teal-600 hover:text-teal-500 transition-colors">Co-Founder Justin Grossbard</a>, or <a href={`${base}/about/noam-korbl`} class="font-semibold text-teal-600 hover:text-teal-500 transition-colors">Co-Founder Noam Korbl</a>.
        </p>
      </div>
    </section>
  </div>

  <!-- Meet the Expert Traders Section -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-4xl">
      <div class="bg-gradient-to-br from-slate-900 via-slate-900 to-[#0d1b2a] rounded-2xl p-8 sm:p-10 lg:p-12">
        <div class="text-center mb-10">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Meet the Expert Traders</p>
          <h2 class="text-3xl font-black text-white">The Best Prop Firms Team and Vision</h2>
        </div>
        <p class="text-slate-300 leading-relaxed mb-5">
          Best Prop Firms was created to provide traders with clear, well-researched comparisons of proprietary trading firms. Our team consists of finance analysts, content strategists, and trading professionals who test the prop firms and challenges themselves before rating funding models, trading platforms, and profit-sharing agreements.
        </p>
        <div class="space-y-5">
          <div class="bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
              </svg>
              <div>
                <p class="font-bold text-white mb-2">We're Hiring</p>
                <p class="text-slate-400 text-sm leading-relaxed">
                  As we continue to expand, we're hiring a <strong class="text-slate-300">Content Writer</strong> to produce in-depth reviews, a <strong class="text-slate-300">Content Editor</strong> to maintain content accuracy, and a <strong class="text-slate-300">Graphic Designer</strong> to create infographics and comparison tables. If you're interested in being part of our team, check out our Careers page for available roles.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-8 text-center">
          <p class="text-slate-400 text-sm leading-relaxed">
            Want to stay updated on prop trading news and job openings? Follow Best Prop Firms on
            <a href="https://x.com/Prop_Firms" target="_blank" rel="noopener noreferrer" class="text-teal-400 hover:text-teal-300 font-semibold">Twitter</a>,
            <a href="https://www.facebook.com/bestpropfirmscom" target="_blank" rel="noopener noreferrer" class="text-teal-400 hover:text-teal-300 font-semibold">Facebook</a>,
            <a href="https://www.linkedin.com/company/bestpropfirms/" target="_blank" rel="noopener noreferrer" class="text-teal-400 hover:text-teal-300 font-semibold">LinkedIn</a>, and
            <a href="https://www.youtube.com/@propfirms" target="_blank" rel="noopener noreferrer" class="text-teal-400 hover:text-teal-300 font-semibold">YouTube</a>
            to get the latest insights, prop firm comparisons, and career opportunities.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
