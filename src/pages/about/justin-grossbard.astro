---
import Base from "../../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const publications = [
  {
    title: "Brave New World: AI-Generated Content and SEO Marketing",
    outlet: "Forbes",
    color: "bg-slate-900 text-white",
    url: "https://www.forbes.com/councils/forbesbusinesscouncil/2023/03/01/brave-new-world-ai-generated-content-and-seo-marketing/",
  },
  {
    title: "How to Pay Your International Freelancers",
    outlet: "Kiplinger",
    color: "bg-blue-600 text-white",
    url: "https://www.kiplinger.com/business/how-to-pay-your-international-freelancers",
  },
  {
    title: "EUR/USD Pairing: September Could Be Bullish or Bearish",
    outlet: "MoneyShow",
    color: "bg-emerald-600 text-white",
    url: "https://www.moneyshow.com/articles/sart-59442/eur-usd-pairing-september-could-be-bullish-or-bearish/",
  },
  {
    title: "Why Forex Trading is Growing",
    outlet: "7News.com.au",
    color: "bg-red-600 text-white",
    url: "https://7news.com.au/business/finance/why-forex-trading-is-growing-c-209451",
  },
];

const mediaLogos = [
  { name: "Forbes", image: "/images/media-logos/forbes.png" },
  { name: "Finance Magnates", image: "/images/media-logos/finance-magnates.png" },
  { name: "Kiplinger", image: "/images/media-logos/kiplinger.png" },
  { name: "Entrepreneur", image: "/images/media-logos/entrepreneur.png" },
  { name: "MoneyShow", image: "/images/media-logos/moneyshow.png" },
  { name: "Scoop", image: "/images/media-logos/scoop.png" },
];
---

<Base
  title="Justin Grossbard — Co-Founder & Strategic Head of Research | BestPropFirms.com"
  description="Learn about Justin Grossbard, co-founder of BestPropFirms.com. With decades of expertise in digital marketing and online trading, Justin leads strategic research for the platform."
>
  <!-- Hero -->
  <section class="relative bg-[#0d1b2a] text-white py-16 sm:py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(20,184,166,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(99,102,241,0.1),transparent_60%)]"></div>
    <div class="relative mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-8">
        <!-- Photo -->
        <div class="flex-shrink-0">
          <div class="w-44 h-44 sm:w-52 sm:h-52 rounded-full p-1 bg-gradient-to-br from-teal-400 via-emerald-400 to-teal-600 shadow-2xl shadow-teal-500/20">
            <div class="w-full h-full rounded-full overflow-hidden bg-white">
              <img
                src={`${base}/images/team/justin-grossbard.png`}
                alt="Justin Grossbard"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
        <!-- Info -->
        <div class="text-center sm:text-left">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/10 px-4 py-1.5 text-xs font-semibold text-teal-300 mb-4 backdrop-blur-sm">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Co-Founder &middot; BestPropFirms.com
          </div>
          <h1 class="text-4xl sm:text-5xl font-black mb-3 leading-tight">Justin Grossbard</h1>
          <p class="text-lg text-teal-400 font-semibold mb-3">Co-Founder & Strategic Head of Research</p>
          <p class="text-slate-300 leading-relaxed max-w-xl">
            Leveraging decades of expertise in digital marketing and online trading, Justin has helped transform Best Prop Firms into the go-to platform for comparing prop trading firms.
          </p>
          <!-- Social links -->
          <div class="flex items-center gap-3 mt-5 justify-center sm:justify-start">
            <a href="https://www.linkedin.com/in/justingrossbard/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-blue-600 hover:border-blue-600 hover:text-white transition-all" aria-label="LinkedIn">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/JustinGrossbard" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-slate-700 hover:border-slate-600 hover:text-white transition-all" aria-label="X (Twitter)">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href={`${base}/contact`} class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/10 text-slate-300 hover:bg-teal-600 hover:border-teal-600 hover:text-white transition-all" aria-label="Contact">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-16 pb-12">

    <!-- Co-Founder and Role -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Role</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Co-Founder<br/>& Researcher</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed">
            Justin Grossbard co-founded Best Prop Firms in 2014 with Noam Korbl and serves as the Strategic Head of Research. Leveraging his decades of expertise in digital marketing and online trading, Justin has helped transform Best Prop Firms into the go-to platform for comparing prop trading firms. The site offers detailed reviews and info on firms, platforms, fees, profit splits, and other key factors that prop traders consider when choosing a firm.
          </p>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-2xl p-7 sm:p-8">
        <div class="flex items-center gap-3 mb-5">
          <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
          </svg>
          <h2 class="text-xl font-black text-blue-900">Education</h2>
        </div>
        <p class="text-blue-800 leading-relaxed mb-4">
          Justin studied in Melbourne, Australia and holds a <strong>Bachelor of Commerce (Honours)</strong> and a <strong>Master's in Marketing</strong> from Monash University. His tertiary education in finance, economics, and marketing provides the framework for his analytical approach to prop trading and online brokers.
        </p>
        <p class="text-blue-800 leading-relaxed">
          For more info about his academic background, you can read Justin's alumni story with Melbourne's Monash University.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Bachelor of Commerce (Honours)
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Master's in Marketing
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-blue-100 text-blue-700 px-3 py-1.5 rounded-full">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Monash University
          </span>
        </div>
      </div>
    </section>

    <!-- Digital Marketing & Entrepreneurial Ventures -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Ventures</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Digital Marketing<br/>& Business</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed mb-4">
            Justin's entrepreneurial career includes founding <strong class="text-slate-800">Innovate Online</strong>, a digital marketing agency, and under his leadership, the company has helped a range of Australian businesses scale their operations, including ChefGood and The Hamper Emporium. His ability to simplify complex concepts and industries like prop trading makes these sites valuable resources for online traders and consumers alike.
          </p>
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-5 mt-4">
            <div class="flex items-start gap-3">
              <svg class="h-6 w-6 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              <div>
                <p class="font-bold text-amber-900 text-sm mb-1">Published Author</p>
                <p class="text-sm text-amber-800 leading-relaxed">
                  Justin is the author of <em>5 Alternative Investments to Earn a Return Outside of Stocks and Bonds</em>, which gives you insights into diverse investment options beyond traditional financial markets. Available via Amazon or Google Play.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications & Media -->
    <section class="mb-16">
      <div class="text-center mb-8">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Media Presence</p>
        <h2 class="text-3xl font-black text-slate-900">Publications & Features</h2>
        <p class="text-slate-500 mt-2 max-w-xl mx-auto">Justin's expertise has been featured in leading financial and business publications.</p>
      </div>

      <!-- Featured Outlets -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-8">
        {mediaLogos.map((outlet) => (
          <div class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-white border border-slate-200 shadow-sm h-14 min-w-[120px]">
            <img
              src={`${base}${outlet.image}`}
              alt={outlet.name}
              class="h-6 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all"
              loading="lazy"
              onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-sm font-bold text-slate-500">${outlet.name}</span>'`}
            />
          </div>
        ))}
      </div>

      <!-- Article Cards -->
      <div class="grid sm:grid-cols-2 gap-4">
        {publications.map((pub) => (
          <a href={pub.url} target="_blank" rel="noopener noreferrer" class="group bg-white border border-slate-200 rounded-xl p-5 hover:border-teal-300 hover:shadow-md transition-all block">
            <span class={`inline-block text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md mb-3 ${pub.color}`}>
              {pub.outlet}
            </span>
            <p class="font-bold text-slate-900 leading-snug group-hover:text-teal-600 transition-colors">{pub.title}</p>
            <span class="inline-flex items-center gap-1 text-xs text-slate-400 mt-2 group-hover:text-teal-500 transition-colors">
              Read article
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </span>
          </a>
        ))}
      </div>

      <p class="text-center text-sm text-slate-500 mt-5">
        For more of his work, you can also find articles on Medium and Muckrack.
      </p>
    </section>

    <!-- Leadership in the Digital Space -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-200 rounded-2xl p-7 sm:p-8">
        <div class="flex items-center gap-3 mb-5">
          <svg class="h-6 w-6 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
          </svg>
          <h2 class="text-xl font-black text-teal-900">Leadership in the Digital Space</h2>
        </div>
        <p class="text-teal-800 leading-relaxed mb-4">
          As the CEO of Innovate Online, Justin leads a team of <strong>25 professionals</strong>, providing digital marketing solutions for clients across industries. His ability to grow businesses through strategic online visibility efforts is well recognised, with successful partnerships and scaling initiatives for businesses such as Marley Spoon and Maggie Beer Holdings.
        </p>
        <p class="text-teal-800 leading-relaxed">
          In 2019, Best Prop Firms transitioned from a local Australian comparison site to a <strong>global platform</strong>, offering local and relevant information for online traders around the world. This shift ensures you can find the most reputable prop trading firms based on region-specific requirements and trading needs.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <div class="flex items-center gap-2 bg-teal-100 text-teal-700 rounded-lg px-4 py-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
            <span class="text-sm font-bold">25+ Team Members</span>
          </div>
          <div class="flex items-center gap-2 bg-teal-100 text-teal-700 rounded-lg px-4 py-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
            <span class="text-sm font-bold">Global Platform</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Personal Life -->
    <section class="mb-16">
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Beyond Work</p>
          <h2 class="text-3xl font-black text-slate-900 leading-tight">Personal Life<br/>& Interests</h2>
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-teal-400 to-emerald-500 mt-4"></div>
        </div>
        <div class="md:col-span-3">
          <p class="text-slate-600 leading-relaxed mb-5">
            Outside of his professional work, Justin is a passionate fan of AFL football, following his favourite team, the Bombers. He also enjoys military strategy films, whisky tastings, and spending time with his family, including his two cats, Bruno and Chloe.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full">
              <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
              AFL (Bombers)
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full">
