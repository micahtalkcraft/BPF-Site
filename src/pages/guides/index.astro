---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { getBreadcrumbSchema, getFaqSchema, getPublisherSchema, SITE_URL } from "../../helpers/schema";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

/** Prefix local asset paths with the site base URL */
function assetUrl(path: string | undefined): string | undefined {
  if (!path) return undefined;
  if (path.startsWith("http")) return path;
  return `${base}${path}`;
}

const posts = await getCollection("blog");

// Sort by date descending
const sorted = posts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Featured post: first post with featured=true, or latest
const featured = sorted.find((p) => p.data.featured) ?? sorted[0];
const rest = sorted.filter((p) => p.id !== featured.id);

// Unique categories for filter chips
const categories = [...new Set(sorted.map((p) => p.data.category))].sort();

const faqs = [
  { q: "What is prop trading?", a: "Proprietary trading (prop trading) is when a firm provides traders with simulated or funded capital to trade financial markets. Traders keep a share of the profits — typically 70–90% — without risking their own money beyond the initial challenge fee." },
  { q: "How do prop firm challenges work?", a: "Most prop firms require you to pass an evaluation (challenge) before accessing a funded account. You trade a demo account under specific rules — profit targets, drawdown limits, and minimum trading days — and if you pass, you receive a funded account with real profit-sharing." },
  { q: "Which prop firm is best for beginners?", a: "Firms with simple one-step evaluations, low fees, and flexible trading rules tend to be best for beginners. Check our reviews for detailed scoring across challenges, platforms, and payout reliability to find the right fit." },
  { q: "What is the difference between forex and futures prop trading?", a: "Forex prop firms focus on currency pairs and CFDs with platforms like MT4, MT5, or cTrader. Futures prop firms trade regulated exchange contracts (ES, NQ, etc.) on platforms like NinjaTrader or Tradovate, with different fee structures and margin rules." },
  { q: "How much money do you need to start prop trading?", a: "Most prop firms charge a one-time challenge fee ranging from $50 to $500, depending on the account size you choose. You don't need trading capital of your own — the firm provides the funded account once you pass the evaluation. Some firms also offer free retries or refundable fees after your first payout." },
  { q: "Can you make a living from prop trading?", a: "Yes, some traders earn a full-time income through prop trading, but it requires consistent profitability, disciplined risk management, and choosing a firm with reliable payouts. Most successful prop traders build up gradually by passing multiple challenges, scaling their accounts, and diversifying across firms." },
  { q: "What happens if you fail a prop firm challenge?", a: "If you breach a drawdown limit or fail to hit the profit target within the allowed timeframe, you lose access to that challenge account. Most firms let you purchase a new challenge (often at a discounted reset fee), and some offer free retries or extensions depending on your performance." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["WebPage", "CollectionPage"],
    "@id": `${SITE_URL}/guides/#webpage`,
    url: `${SITE_URL}/guides/`,
    name: "Prop Trading Guides & Education (2026) | BestPropFirms.com",
    description: "Expert prop trading guides covering challenges, funded accounts, strategy, and firm comparisons — based on verified firsthand testing.",
    isPartOf: { "@id": `${SITE_URL}/#website` },
    publisher: { "@id": `${SITE_URL}/#organization` },
    datePublished: "2025-01-01",
    dateModified: "2026-03-13",
  },
  getFaqSchema(faqs),
  getBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Prop Trading Guides" },
  ]),
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

<Base
  title="Prop Trading Guides & Education (2026) | BestPropFirms.com"
  description="Expert prop trading guides covering challenges, funded accounts, strategy, and firm comparisons — based on verified firsthand testing."
  jsonLd={jsonLd}
>
  <!-- Page header -->
  <section class="bg-[#0d1b2a] text-white py-14 px-4">
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Guides</p>
      <h1 class="text-4xl font-black mb-3">Prop Trading Guides: Challenges, Funded Accounts & Strategy</h1>
      <p class="text-slate-300 text-sm max-w-2xl leading-relaxed">
        Our prop trading guides cover everything from understanding how prop firm challenges work to comparing the best funded trading accounts in 2026. Whether you're a beginner learning what a prop firm is, or an experienced trader looking for the best futures or forex prop firms, our articles are based on verified, firsthand testing. Use the categories below to find guides relevant to your trading style and goals.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs crumbs={[{ name: "Home", url: "/" }, { name: "Guides" }]} />
  </div>

  <!-- Featured article -->
  {featured && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 mb-12">
      <a
        href={`${base}/guides/${featured.id.replace(/\.md$/, "")}`}
        class="group block bg-white border border-slate-200 rounded-2xl shadow-lg hover:shadow-xl transition-shadow overflow-hidden"
      >
        <div class="flex flex-col md:flex-row">
          {/* Thumbnail */}
          {featured.data.coverImage ? (
            <div class="md:w-1/2 flex-shrink-0">
              <img
                src={assetUrl(featured.data.coverImage)}
                alt={featured.data.title}
                class="w-full h-56 md:h-full object-cover"
              />
            </div>
          ) : (
            <div class="md:w-1/2 flex-shrink-0 bg-gradient-to-br from-teal-500 to-blue-600 flex items-center justify-center min-h-[14rem]">
              <svg class="h-16 w-16 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
          )}
          {/* Content */}
          <div class="flex-1 p-6 md:p-8 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-3">
              <span class="inline-flex items-center rounded-full bg-teal-50 border border-teal-200 px-2.5 py-0.5 text-[10px] font-bold text-teal-700 uppercase tracking-wide">
                Featured
              </span>
              <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-[10px] font-semibold text-slate-600">
                {featured.data.category}
              </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-slate-900 group-hover:text-teal-600 transition-colors mb-3 leading-tight">
              {featured.data.title}
            </h2>
            <p class="text-slate-600 leading-relaxed mb-4 line-clamp-3">
              {featured.data.excerpt}
            </p>
            <div class="flex items-center gap-4 text-xs text-slate-400 mb-5">
              <span>{formatDate(featured.data.publishedAt)}</span>
              {featured.data.readingTimeMinutes && (
                <span class="flex items-center gap-1">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {featured.data.readingTimeMinutes} min read
                </span>
              )}
            </div>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 group-hover:text-teal-700 transition-colors">
              Read article
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- Search & Filter bar -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-8">
    <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
      <div class="relative flex-1 max-w-sm">
        <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
        </svg>
        <input
          id="blog-search"
          type="text"
          placeholder="Search articles…"
          class="w-full rounded-lg border border-slate-200 bg-white pl-9 pr-3 py-2.5 text-sm text-slate-800 placeholder:text-slate-400 focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100 transition"
        />
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide whitespace-nowrap">Category:</span>
        <button data-cat="all" class="cat-chip rounded-full border px-3 py-1 text-xs font-semibold transition-colors bg-teal-500 text-white border-teal-500">All</button>
        {categories.map((cat) => (
          <button data-cat={cat} class="cat-chip rounded-full border px-3 py-1 text-xs font-semibold transition-colors bg-white text-slate-600 border-slate-200 hover:border-teal-300 hover:text-teal-600">
            {cat}
          </button>
        ))}
      </div>
      <p id="blog-count" class="text-xs text-slate-400 whitespace-nowrap sm:ml-auto"></p>
    </div>
  </div>

  <!-- Article grid -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
      {rest.map((post) => (
        <article
          class="group bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col"
          data-blog-card
          data-title={post.data.title.toLowerCase()}
          data-category={post.data.category}
        >
          {/* Thumbnail */}
          <a href={`${base}/guides/${post.id.replace(/\.md$/, "")}`} class="block">
            {post.data.coverImage ? (
              <img
                src={assetUrl(post.data.coverImage)}
                alt={post.data.title}
                class="w-full h-44 object-cover"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-44 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                <svg class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
            )}
          </a>
          {/* Content */}
          <div class="flex-1 flex flex-col p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-[10px] font-semibold text-slate-600">
                {post.data.category}
              </span>
            </div>
            <h3 class="text-base font-extrabold text-slate-900 group-hover:text-teal-600 transition-colors mb-2 leading-snug">
              <a href={`${base}/guides/${post.id.replace(/\.md$/, "")}`}>{post.data.title}</a>
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed line-clamp-2 mb-4 flex-1">
              {post.data.excerpt}
            </p>
            <div class="flex items-center justify-between text-xs text-slate-400 mt-auto pt-3 border-t border-slate-100">
              <span>{formatDate(post.data.publishedAt)}</span>
              {post.data.readingTimeMinutes && (
                <span class="flex items-center gap-1">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {post.data.readingTimeMinutes} min
                </span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    const searchInput = document.getElementById("blog-search") as HTMLInputElement | null;
    const catBtns = document.querySelectorAll<HTMLButtonElement>(".cat-chip");
    const cards = document.querySelectorAll<HTMLElement>("[data-blog-card]");
    const countEl = document.getElementById("blog-count");

    let activeCat = "all";
    let searchQuery = "";

    function applyFilters() {
      let visible = 0;
      cards.forEach((card) => {
        const title = card.dataset.title ?? "";
        const cat = card.dataset.category ?? "";
        const matchesSearch = title.includes(searchQuery);
        const matchesCat = activeCat === "all" || cat === activeCat;
        const show = matchesSearch && matchesCat;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (countEl) {
        countEl.textContent =
          visible === cards.length
            ? `${cards.length} articles`
            : `${visible} of ${cards.length} articles`;
      }
    }

    function updateChipStyles() {
      catBtns.forEach((btn) => {
        const c = btn.dataset.cat ?? "";
        const isActive = c === activeCat || (c === "all" && activeCat === "all");
        btn.classList.toggle("bg-teal-500", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-teal-500", isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-600", !isActive);
        btn.classList.toggle("border-slate-200", !isActive);
      });
    }

    searchInput?.addEventListener("input", () => {
      searchQuery = (searchInput.value ?? "").trim().toLowerCase();
      applyFilters();
    });

    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeCat = btn.dataset.cat ?? "all";
        updateChipStyles();
        applyFilters();
      });
    });

    applyFilters();
  </script>

  <!-- ── Discord Banner ────────────────────────────────────────────────── -->
  <section class="bg-white border-t border-slate-200 py-12 px-4">
    <div class="mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#5865F2] via-[#4752C4] to-[#3B44A8] p-8 md:p-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        <div class="relative flex flex-col md:flex-row items-center gap-6 md:gap-8">
          <div class="flex-1 text-center md:text-left">
            <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-[11px] font-bold text-white/90 uppercase tracking-widest">
              <span class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
              3,800+ Members Online
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-white mb-2">
              Learn With Other Traders
            </h2>
            <p class="text-sm text-white/70 leading-relaxed max-w-lg md:max-w-lg mx-auto md:mx-0">
              Join our Discord to ask questions, share strategies, get payout proof, and discuss the latest prop firm news with thousands of active traders.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a
              href="https://discord.gg/cKDj3pBUjb"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2.5 rounded-xl bg-white px-6 py-3.5 font-bold text-[#5865F2] shadow-lg transition-all duration-200 hover:shadow-xl hover:scale-[1.02] active:scale-[0.98]"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"/>
              </svg>
              Join Our Discord
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Popular Guides ──────────────────────────────────────────────── -->
  <section class="bg-slate-50 border-t border-slate-200 py-16 px-4">
    <div class="mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Most Read</p>
        <h2 class="text-3xl font-black text-slate-900">Popular Prop Trading Guides</h2>
        <p class="text-sm text-slate-500 mt-2">Our most-visited articles, based on reader engagement and search demand.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href={`${base}/guides/what-is-a-prop-firm`} class="group flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-teal-300 hover:shadow-md transition-all">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-teal-50 border border-teal-100 flex items-center justify-center text-teal-600 font-black text-sm">01</div>
          <div>
            <p class="font-bold text-slate-900 group-hover:text-teal-600 transition-colors mb-1">What Is a Prop Trading Firm?</p>
            <p class="text-xs text-slate-500 leading-relaxed">Everything beginners need to know about how prop firms work, from evaluations to payouts.</p>
          </div>
        </a>
        <a href={`${base}/guides/how-prop-trading-challenges-work`} class="group flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-teal-300 hover:shadow-md transition-all">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-teal-50 border border-teal-100 flex items-center justify-center text-teal-600 font-black text-sm">02</div>
          <div>
            <p class="font-bold text-slate-900 group-hover:text-teal-600 transition-colors mb-1">How Prop Trading Challenges Work</p>
            <p class="text-xs text-slate-500 leading-relaxed">Profit targets, drawdown limits, and evaluation rules — a complete breakdown.</p>
          </div>
        </a>
        <a href={`${base}/guides/prop-trading-for-beginners`} class="group flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-teal-300 hover:shadow-md transition-all">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-teal-50 border border-teal-100 flex items-center justify-center text-teal-600 font-black text-sm">03</div>
          <div>
            <p class="font-bold text-slate-900 group-hover:text-teal-600 transition-colors mb-1">Prop Trading for Beginners</p>
            <p class="text-xs text-slate-500 leading-relaxed">Step-by-step guide to getting started, choosing your first firm, and passing a challenge.</p>
          </div>
        </a>
        <a href={`${base}/guides/funded-trading-accounts`} class="group flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-teal-300 hover:shadow-md transition-all">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-teal-50 border border-teal-100 flex items-center justify-center text-teal-600 font-black text-sm">04</div>
          <div>
            <p class="font-bold text-slate-900 group-hover:text-teal-600 transition-colors mb-1">Best Funded Trading Accounts</p>
            <p class="text-xs text-slate-500 leading-relaxed">Verified comparison of funded account options by fees, profit split, and payout speed.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Browse by Topic ───────────────────────────────────────────────── -->
  <section class="bg-slate-50 py-16 px-4">
    <div class="mx-auto max-w-4xl sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Explore</p>
        <h2 class="text-3xl font-black text-slate-900">Browse Guides by Topic</h2>
        <p class="text-sm text-slate-500 mt-2">Find guides grouped by what matters most to your trading journey.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Getting Started -->
        <div class="bg-white rounded-xl border border-slate-200 p-5">
          <div class="flex items-center gap-2 mb-4">
            <svg class="h-5 w-5 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" /></svg>
            <h3 class="font-bold text-slate-900">Getting Started</h3>
          </div>
          <ul class="space-y-2">
