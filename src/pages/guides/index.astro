---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://www.bestpropfirms.com";

function assetUrl(path: string | undefined): string | undefined {
  if (!path) return undefined;
  if (path.startsWith("http")) return path;
  return `${base}${path}`;
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const guideLinks = [
  { label: "What is a Prop Trading Firm?", slug: "what-is-a-prop-firm" },
  { label: "Risk Management in Prop Trading", slug: "risk-management-prop-trading" },
  { label: "Pros and Cons of Prop Trading", slug: "pros-and-cons-of-prop-trading" },
  { label: "Prop Trading Account Types", slug: "prop-trading-account-types" },
  { label: "Prop Trading for Beginners", slug: "prop-trading-for-beginners" },
  { label: "Prop Trading Strategies", slug: "prop-trading-strategies" },
  { label: "How Do Prop Firms Pay You?", slug: "how-do-prop-firms-pay-you" },
];

const tocItems = [
  { slug: "how-does-proprietary-trading-work", text: "How Does Proprietary Trading Work?" },
  { slug: "traditional-vs-online-prop-trading", text: "Traditional vs Online Prop Trading" },
  { slug: "who-is-prop-trading-for", text: "Who Is Prop Trading For?" },
  { slug: "pros-and-cons-of-prop-trading", text: "Pros and Cons of Prop Trading" },
  { slug: "understanding-the-risks", text: "Understanding the Risks" },
  { slug: "common-proprietary-trading-strategies", text: "Common Strategies" },
  { slug: "are-prop-firms-regulated", text: "Are Prop Firms Regulated?" },
  { slug: "quick-history-of-prop-trading", text: "Quick History" },
  { slug: "faqs", text: "FAQs" },
];

// Load all guides for footer section
const allGuides = await getCollection("guides");
const sortedGuides = allGuides
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 6);

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "What Is Prop Trading? A Complete Guide",
  description: "A comprehensive guide to proprietary trading — how it works, who it's for, the pros and cons, strategies, regulation, and history.",
