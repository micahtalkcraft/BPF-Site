  author: {
    "@type": "Person",
    name: "Noam Korbl",
  },
  publisher: {
    "@type": "Organization",
    name: "BestPropFirms.com",
    url: siteUrl,
  },
  mainEntityOfPage: `${siteUrl}/guides`,
};
