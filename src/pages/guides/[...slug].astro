---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { filterFirmsByRegion, currentRegion } from "../../config/currentRegion";
import ScoreBadge from "../../components/shared/ScoreBadge.astro";

export async function getStaticPaths() {
  const posts = await getCollection("guides");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

/** Prefix local asset paths (starting with /) with the site base URL */
function assetUrl(path: string | undefined): string | undefined {
  if (!path) return undefined;
  if (path.startsWith("http")) return path;
  return `${base}${path}`;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Build TOC from h2 headings only (clean, not overwhelming)
const tocItems = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

// Get other guides for "More guides" section
const allPosts = await getCollection("guides");
const morePosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

const siteUrl = `https://${currentRegion.subdomain}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.publishedAt,
  author: post.data.author
    ? { "@type": "Person", name: post.data.author, ...(post.data.authorImage && { image: post.data.authorImage }) }
    : { "@type": "Organization", name: "BestPropFirms.com" },
  publisher: {
    "@type": "Organization",
    name: "BestPropFirms.com",
    url: siteUrl,
  },
  ...(post.data.coverImage && { image: post.data.coverImage }),
  mainEntityOfPage: `${siteUrl}/guides/${post.slug}`,
};

// Load prop firm + review data for featured firms (if any)
const propFirms = filterFirmsByRegion(await getCollection("prop-firms"));
const reviews = await getCollection("reviews");
const reviewMap = Object.fromEntries(reviews.map((r) => [r.data.propFirmId, r.data]));
const firmMap = Object.fromEntries(propFirms.map((f) => [f.data.slug, f.data]));

// Determine region flag from tags
const tags = post.data.tags.map((t: string) => t.toLowerCase());
const regionFlag = tags.includes("canada") ? "ca" : tags.includes("uk") ? "gb" : tags.includes("india") ? "in" : tags.includes("australia") ? "au" : null;

interface FeaturedFirmCard {
  rank: number;
  name: string;
  descriptor: string;
  slug: string;
  logoUrl?: string;
  website?: string;
  overallScore?: number;
  splitMax: number | null;
  maxDrawdown: number | null;
  lowestFee: number | null;
  platforms: string;
  evalLabel: string;
  trustpilotRating: number | null;
  discountCode: string | null;
  discountPercent: number | null;
  tags: string[];
}

const featuredFirmCards: FeaturedFirmCard[] = (post.data.featuredFirms ?? []).map((ff, i) => {
  const firm = firmMap[ff.slug];
  const review = firm ? reviewMap[firm.id] : undefined;
  const fees = firm?.pricing.challengeFees ?? [];
  const lowestFee = fees.length > 0 ? fees.reduce((m, x) => x.fee < m.fee ? x : m).fee : null;
  const custom = firm?.custom as any;
  return {
    rank: i + 1,
    name: firm?.name ?? ff.slug,
    descriptor: ff.descriptor,
    slug: ff.slug,
    logoUrl: firm?.media?.logo ? `${base}${firm.media.logo}` : undefined,
    website: firm?.links?.website,
    overallScore: review?.overallScore,
    splitMax: firm?.payouts.splitMax ?? null,
    maxDrawdown: firm?.evaluation.maxDrawdown ?? null,
    lowestFee,
    platforms: firm?.markets.platforms.slice(0, 2).join(", ") ?? "—",
    evalLabel: firm?.evaluation.types.map((t) => t === "other" ? "Futures" : t.split("-").map(w => w[0].toUpperCase()+w.slice(1)).join("-")).join(", ") ?? "—",
    trustpilotRating: firm?.trust.trustpilotRating ?? null,
    discountCode: custom?.discountCode ?? null,
    discountPercent: custom?.discountPercent ?? null,
    tags: custom?.tags ?? [],
  };
});
---

<Base
  title={`${post.data.title} | BestPropFirms.com`}
  description={post.data.excerpt}
  ogType="article"
  ogImage={post.data.coverImage}
  jsonLd={articleJsonLd}
>
  <!-- Article header -->
  <section class="bg-[#0d1b2a] text-white py-14 px-4">
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <a href={`${base}/guides`} class="text-xs text-slate-400 hover:text-teal-400 transition-colors flex items-center gap-1">
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Guides
        </a>
        <span class="text-slate-600">·</span>
        <span class="rounded-full bg-white/10 px-2.5 py-0.5 text-[10px] font-semibold text-slate-300">
          {post.data.category}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black leading-tight mb-3">
        {post.data.title}
      </h1>
      <p class="text-slate-400 text-base leading-relaxed mb-5 max-w-4xl">
        {post.data.excerpt}
      </p>
      <!-- Author byline -->
      <div class="flex items-center gap-3">
        {post.data.authorImage && (
          <img
            src={assetUrl(post.data.authorImage)}
            alt={post.data.author}
            class="w-9 h-9 rounded-full object-cover border-2 border-white/20"
          />
        )}
        <div class="flex flex-col">
          {post.data.author && (
            <span class="text-sm font-semibold text-white">{post.data.author}</span>
          )}
          <div class="flex items-center gap-3 text-xs text-slate-400">
            <span>{formatDate(post.data.publishedAt)}</span>
            {post.data.readingTimeMinutes && (
              <span class="flex items-center gap-1">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {post.data.readingTimeMinutes} min read
              </span>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cover image (only when no video) -->
  {post.data.coverImage && !post.data.youtubeVideoId && (
    <div class="mx-auto max-w-3xl px-4 -mt-6 mb-8 relative z-10">
      <img
        src={assetUrl(post.data.coverImage)}
        alt={post.data.title}
        class="w-full rounded-xl shadow-lg object-cover max-h-96"
      />
    </div>
  )}

  <!-- Two-column: Quick-reference sidebar + video -->
  {post.data.youtubeVideoId && featuredFirmCards.length > 0 && (
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col lg:flex-row gap-6">

        {/* ── Left: Quick-reference table card ── */}
        <div class="lg:w-[380px] flex-shrink-0">
          <div class="bg-white border border-slate-200 rounded-2xl shadow-lg overflow-hidden h-full flex flex-col">
            {/* Card header */}
            <div class="bg-[#0d1b2a] px-5 py-4">
              <div class="flex items-center gap-2.5 mb-1.5">
                <p class="text-sm font-black text-white uppercase tracking-wide flex-1">Top Picks at a Glance</p>
              </div>
              <p class="text-[11px] text-slate-400">{featuredFirmCards.length} firms ranked for {new Date().getFullYear()}</p>
            </div>

            {/* Table header */}
            <div class="flex items-center px-5 py-2 bg-teal-500 text-[10px] font-bold text-white uppercase tracking-widest">
              <span class="w-6 flex-shrink-0">#</span>
              <span class="flex-1">Firm</span>
              <span class="text-right w-auto">Category</span>
            </div>

            {/* Table rows */}
            <div class="flex-1 divide-y divide-slate-100">
              {featuredFirmCards.map((fc) => (
                <a
                  href={`${base}/reviews/${fc.slug}`}
                  class="flex items-center px-5 py-2.5 hover:bg-teal-50/50 transition-colors group"
                >
                  <span class={`w-6 flex-shrink-0 text-xs font-black ${fc.rank === 1 ? "text-amber-400" : fc.rank === 2 ? "text-slate-400" : fc.rank === 3 ? "text-amber-600" : "text-slate-300"}`}>
                    {fc.rank}.
                  </span>
                  <div class="flex items-center gap-2.5 flex-1 min-w-0">
                    {fc.logoUrl ? (
                      <div class="flex-shrink-0 w-7 h-7 rounded-md bg-white border border-slate-200 flex items-center justify-center overflow-hidden">
                        <img src={fc.logoUrl} alt={fc.name} class="w-full h-full object-contain p-0.5" loading="lazy" />
                      </div>
                    ) : (
                      <div class="flex-shrink-0 w-7 h-7 rounded-md bg-teal-500 flex items-center justify-center">
                        <span class="text-[9px] font-black text-white">{fc.name.split(" ").map((w) => w[0]).slice(0, 2).join("").toUpperCase()}</span>
                      </div>
                    )}
                    <span class="text-sm font-bold text-slate-900 group-hover:text-teal-600 transition-colors truncate">
                      {fc.name}
                    </span>
                  </div>
                  <span class="text-[11px] text-slate-500 text-right flex-shrink-0 max-w-[140px] leading-tight hidden sm:block lg:block">
                    {fc.descriptor}
                  </span>
                </a>
              ))}
            </div>

            {/* Card footer */}
            <div class="px-5 py-3 border-t border-slate-100 bg-slate-50/50">
              <p class="text-[10px] text-slate-400 leading-relaxed">
                Rankings based on spreads, fees, platforms, trust, and payout reliability for traders in this region.
              </p>
            </div>
          </div>
        </div>

        {/* ── Right: Video + blurb ── */}
        <div class="flex-1 min-w-0 flex flex-col gap-6">
          {/* Video embed */}
          <div class="rounded-2xl overflow-hidden shadow-lg border border-slate-200 bg-black">
            <div class="relative w-full" style="padding-bottom:56.25%">
              <iframe
                src={`https://www.youtube.com/embed/${post.data.youtubeVideoId}`}
                title={post.data.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="absolute inset-0 w-full h-full"
                loading="lazy"
              ></iframe>
            </div>
          </div>
        </div>

      </div>
    </div>
  )}

  <!-- Video only (no featured firms) -->
  {post.data.youtubeVideoId && featuredFirmCards.length === 0 && (
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 mt-8 mb-10">
      <div class="rounded-2xl overflow-hidden shadow-lg border border-slate-200 bg-black">
        <div class="relative w-full" style="padding-bottom:56.25%">
          <iframe
            src={`https://www.youtube.com/embed/${post.data.youtubeVideoId}`}
            title={post.data.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  )}

  <!-- Article body with TOC sidebar -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-10">

    <!-- Featured firms list (enhanced cards — top 5 only) -->
    {featuredFirmCards.length > 0 && (
      <div class="mb-10">
        <h2 class="text-xl font-black text-slate-900 mb-5">Our Top Picks</h2>
        <div class="space-y-4">
          {featuredFirmCards.slice(0, 5).map((fc) => (
            <div class="relative group bg-white border border-slate-200 rounded-2xl shadow-sm hover:shadow-md hover:border-teal-200 transition-all duration-200 overflow-hidden">
              {/* Left accent bar */}
              <span class="absolute left-0 top-4 bottom-4 w-1 rounded-r-full bg-gradient-to-b from-teal-400 to-teal-600 opacity-0 group-hover:opacity-100 transition-opacity duration-200" />

              <div class="p-5 sm:p-6">
                {/* Top row: rank, logo, name, descriptor, score, CTA */}
                <div class="flex items-center gap-4 mb-4">
                  {/* Rank */}
                  <span class="hidden sm:block flex-shrink-0 text-2xl font-black text-slate-200 w-8 text-center select-none">
                    {String(fc.rank).padStart(2, "0")}
                  </span>

                  {/* Logo */}
                  {fc.logoUrl ? (
                    <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center overflow-hidden shadow-sm">
                      <img src={fc.logoUrl} alt={`${fc.name} logo`} class="w-full h-full object-contain p-1.5" loading="lazy" />
                    </div>
                  ) : (
                    <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-teal-500 flex items-center justify-center border border-slate-200">
                      <span class="text-sm font-black text-white">{fc.name.split(" ").map((w) => w[0]).slice(0, 2).join("").toUpperCase()}</span>
                    </div>
                  )}

                  {/* Name + descriptor */}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <a
                        href={`${base}/reviews/${fc.slug}`}
                        class="text-lg font-extrabold text-slate-900 hover:text-teal-600 transition-colors"
                      >
                        {fc.name}
                      </a>
                    </div>
                    <p class="text-xs text-slate-500 mt-0.5">{fc.descriptor}</p>
                  </div>

                  {/* Score */}
                  <div class="flex-shrink-0">
                    {fc.overallScore !== undefined ? (
                      <ScoreBadge score={fc.overallScore} size="lg" />
                    ) : (
                      <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
                        <span class="text-[10px] text-slate-400 font-medium text-center leading-tight">N/A</span>
                      </div>
                    )}
                  </div>
                </div>

                {/* Stats grid + CTA row */}
                <div class="flex flex-col sm:flex-row sm:items-end gap-4">
                  {/* Stats */}
                  <div class="flex items-center gap-3 sm:gap-5 flex-wrap flex-1">
                    <div class="rounded-lg bg-slate-50 px-3 py-2 text-center min-w-[70px]">
                      <p class="text-[9px] text-slate-400 uppercase tracking-wide font-medium mb-0.5">Payout</p>
                      <p class={`font-bold text-sm ${fc.splitMax ? "text-teal-600" : "text-slate-300"}`}>
                        {fc.splitMax ? `${fc.splitMax}%` : "—"}
                      </p>
                    </div>
                    <div class="rounded-lg bg-slate-50 px-3 py-2 text-center min-w-[70px]">
                      <p class="text-[9px] text-slate-400 uppercase tracking-wide font-medium mb-0.5">Max DD</p>
                      <p class="font-bold text-sm text-slate-700">
                        {fc.maxDrawdown ? `${fc.maxDrawdown}%` : "—"}
                      </p>
                    </div>
                    {fc.lowestFee !== null && (
                      <div class="rounded-lg bg-slate-50 px-3 py-2 text-center min-w-[70px]">
                        <p class="text-[9px] text-slate-400 uppercase tracking-wide font-medium mb-0.5">From</p>
                        <p class="font-bold text-sm text-slate-700">${fc.lowestFee}</p>
                      </div>
                    )}
                    {fc.trustpilotRating && (
                      <div class="rounded-lg bg-slate-50 px-3 py-2 text-center min-w-[70px]">
                        <p class="text-[9px] text-slate-400 uppercase tracking-wide font-medium mb-0.5">Trustpilot</p>
                        <p class="font-bold text-sm text-slate-700">{fc.trustpilotRating} <span class="text-amber-400">★</span></p>
                      </div>
                    )}
                    <div class="rounded-lg bg-slate-50 px-3 py-2 text-center min-w-[70px]">
                      <p class="text-[9px] text-slate-400 uppercase tracking-wide font-medium mb-0.5">Platforms</p>
                      <p class="font-bold text-xs text-slate-700">{fc.platforms}</p>
                    </div>
                  </div>

                  {/* CTAs */}
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <a
                      href={`${base}/reviews/${fc.slug}`}
                      class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-teal-500 px-5 py-2.5 text-xs font-semibold text-white hover:bg-teal-600 transition-colors whitespace-nowrap"
                    >
                      Read Review
                      <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    {fc.website && (
                      <a
                        href={fc.website}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center gap-1 rounded-lg border border-slate-200 px-4 py-2.5 text-xs font-semibold text-slate-600 hover:border-teal-300 hover:text-teal-600 transition-colors whitespace-nowrap"
                      >
                        Visit Site
                        <svg class="h-3 w-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>

                {/* Discount code strip */}
                {fc.discountCode && (
                  <div class="mt-4 pt-3 border-t border-dashed border-slate-200 flex items-center gap-3 flex-wrap">
                    <svg class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                    <span class="text-xs font-semibold text-emerald-700">
                      {fc.discountPercent ? `${fc.discountPercent}% Off` : "Discount"} — Code:
                    </span>
                    <div class="inline-flex items-center rounded overflow-hidden border border-dashed border-emerald-300">
                      <span class="font-mono font-bold text-xs bg-emerald-50 px-3 py-1 text-emerald-700 tracking-wide select-all">
                        {fc.discountCode}
                      </span>
                      <button
                        type="button"
                        data-copy-code={fc.discountCode}
                        class="copy-code-btn flex items-center gap-1 bg-emerald-500 hover:bg-emerald-600 text-white px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide transition-colors cursor-pointer"
                      >
                        <svg class="h-3 w-3 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                        <svg class="h-3 w-3 check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="copy-label">Copy</span>
                      </button>
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="flex gap-10">

      <!-- TOC sidebar (desktop only) -->
      {tocItems.length > 1 && (
        <aside class="hidden xl:block w-56 flex-shrink-0">
          <nav id="toc-nav" class="sticky top-24">
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-3">On this page</p>
            <ul class="space-y-0.5 border-l-2 border-slate-100">
              {tocItems.map((item) => (
                <li>
                  <a
                    href={`#${item.slug}`}
                    data-toc-link={item.slug}
                    class="toc-link block pl-3.5 py-1.5 text-[13px] leading-snug text-slate-400 hover:text-teal-600 transition-colors border-l-2 -ml-[2px] border-transparent hover:border-teal-400"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Main article content -->
      <article class="min-w-0 max-w-3xl flex-1">
        <div class="prose prose-slate prose-lg max-w-none
          prose-headings:font-extrabold prose-headings:text-slate-900
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-3
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:leading-relaxed prose-p:text-slate-700
          prose-a:text-teal-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:text-teal-700 hover:prose-a:underline
          prose-strong:text-slate-900
          prose-li:text-slate-700
          prose-table:text-sm
          prose-th:bg-slate-50 prose-th:text-slate-700 prose-th:font-bold
          prose-td:text-slate-600
          prose-h2:scroll-mt-24
          prose-h3:scroll-mt-24
        ">
          <Content />
        </div>

        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-slate-200">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Tags:</span>
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Back to guides -->
        <div class="mt-8">
          <a href={`${base}/guides`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to all guides
          </a>
        </div>
      </article>
    </div>
  </div>

  <!-- TOC scroll-spy script -->
  <script>
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (tocLinks.length > 0) {
      const slugs = Array.from(tocLinks).map((a) => a.dataset.tocLink!);
      const headingEls = slugs
        .map((s) => document.getElementById(s))
        .filter(Boolean) as HTMLElement[];

      function setActive(slug: string) {
        tocLinks.forEach((a) => {
          const isActive = a.dataset.tocLink === slug;
          a.classList.toggle("text-teal-600", isActive);
          a.classList.toggle("font-semibold", isActive);
          a.classList.toggle("border-teal-500", isActive);
          a.classList.toggle("text-slate-400", !isActive);
          a.classList.toggle("border-transparent", !isActive);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
              break;
            }
          }
        },
        { rootMargin: "-80px 0px -75% 0px", threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));

      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY + 120;
            let current = slugs[0];
            for (let i = 0; i < headingEls.length; i++) {
              if (headingEls[i].offsetTop <= scrollY) {
                current = slugs[i];
              }
            }
            setActive(current);
            ticking = false;
          });
          ticking = true;
        }
      });

      tocLinks.forEach((a) => {
        a.addEventListener("click", (e) => {
          e.preventDefault();
          const target = document.getElementById(a.dataset.tocLink!);
          if (target) {
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            history.replaceState(null, "", `#${a.dataset.tocLink}`);
          }
        });
      });
    }
  </script>

  <!-- Copy discount code script -->
  <script>
    document.querySelectorAll<HTMLButtonElement>(".copy-code-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const code = btn.dataset.copyCode;
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code);
          const copyIcon = btn.querySelector(".copy-icon") as HTMLElement;
          const checkIcon = btn.querySelector(".check-icon") as HTMLElement;
          const label = btn.querySelector(".copy-label") as HTMLElement;
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");
          if (label) label.textContent = "Copied!";
          setTimeout(() => {
            copyIcon?.classList.remove("hidden");
            checkIcon?.classList.add("hidden");
            if (label) label.textContent = "Copy";
          }, 2000);
        } catch {
          const codeSpan = btn.previousElementSibling as HTMLElement;
          if (codeSpan) {
            const range = document.createRange();
            range.selectNodeContents(codeSpan);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            sel?.addRange(range);
          }
        }
      });
    });
  </script>

  <!-- More guides -->
  {morePosts.length > 0 && (
    <section class="bg-slate-100 border-t border-slate-200 py-12 px-4">
      <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
        <h2 class="text-2xl font-black text-slate-900 mb-6">More Guides</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {morePosts.map((p) => (
            <a
              href={`${base}/guides/${p.slug}`}
              class="group bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col"
            >
              {p.data.coverImage ? (
                <img src={assetUrl(p.data.coverImage)} alt={p.data.title} class="w-full h-40 object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-40 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                  <svg class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              )}
              <div class="p-4 flex-1 flex flex-col">
                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-500 w-fit mb-2">
                  {p.data.category}
                </span>
                <h3 class="text-sm font-bold text-slate-900 group-hover:text-teal-600 transition-colors leading-snug mb-2">
                  {p.data.title}
                </h3>
                <div class="flex items-center gap-3 text-[11px] text-slate-400 mt-auto">
                  <span>{formatDate(p.data.publishedAt)}</span>
                  {p.data.readingTimeMinutes && <span>{p.data.readingTimeMinutes} min read</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
