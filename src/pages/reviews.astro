  <script>
    const ITEMS_PER_PAGE = 10;
    const searchInput = document.getElementById("firm-search") as HTMLInputElement | null;
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-firm-card]"));
    const countEl = document.getElementById("results-count");
    const paginationEl = document.getElementById("pagination");

    let activeFilters = new Set<string>();
    let searchQuery = "";
    let currentPage = 1;

    function getMatchingCards(): HTMLElement[] {
      return cards.filter((card) => {
        const name = card.dataset.name ?? "";
        const types = (card.dataset.types ?? "").split(" ").filter(Boolean);
        const tags = (card.dataset.tags ?? "").split(",").filter(Boolean);
        const matchesSearch = name.includes(searchQuery);
        const isBrokerBacked = card.dataset.brokerBacked === "true";
        const hasOffer = card.dataset.hasOffer === "true";
        const hasBrokerFilter = activeFilters.has("broker-backed");
        const hasFuturesFilter = activeFilters.has("futures");
        const hasOffersFilter = activeFilters.has("offers");
        const typeFilters = [...activeFilters].filter((f) => f !== "broker-backed" && f !== "futures" && f !== "offers");
        const matchesFilter =
          activeFilters.size === 0 ||
          ((typeFilters.length === 0 || typeFilters.some((f) => types.includes(f))) &&
           (!hasBrokerFilter || isBrokerBacked) &&
           (!hasFuturesFilter || tags.some((t) => t.includes("Futures"))) &&
           (!hasOffersFilter || hasOffer));
        return matchesSearch && matchesFilter;
      });
    }

    function applyFilters() {
      const matching = getMatchingCards();
      const totalPages = Math.max(1, Math.ceil(matching.length / ITEMS_PER_PAGE));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      const matchingSet = new Set(matching);

      cards.forEach((card) => {
        if (!matchingSet.has(card)) {
          card.style.display = "none";
        } else {
          const idx = matching.indexOf(card);
          card.style.display = idx >= start && idx < end ? "" : "none";
        }
      });

      if (countEl) {
        if (matching.length === 0) {
          countEl.textContent = "0 firms";
        } else {
          countEl.textContent = `${start + 1}–${Math.min(end, matching.length)} of ${matching.length} firms`;
        }
      }

      renderPagination(totalPages);
    }

    function renderPagination(totalPages: number) {
      if (!paginationEl) return;
      if (totalPages <= 1) { paginationEl.innerHTML = ""; return; }

      let html = "";
      // Prev arrow
      html += `<button data-page="${currentPage - 1}" ${currentPage <= 1 ? "disabled" : ""} class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 bg-white text-slate-500 hover:border-teal-300 hover:text-teal-600 transition-colors disabled:opacity-30 disabled:pointer-events-none" aria-label="Previous page"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></button>`;
      // Page numbers
      for (let p = 1; p <= totalPages; p++) {
        const active = p === currentPage;
        html += `<button data-page="${p}" class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-sm font-semibold border transition-colors ${active ? "bg-teal-500 border-teal-500 text-white shadow-sm" : "bg-white border-slate-200 text-slate-600 hover:border-teal-300 hover:text-teal-600"}">${p}</button>`;
      }
      // Next arrow
      html += `<button data-page="${currentPage + 1}" ${currentPage >= totalPages ? "disabled" : ""} class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 bg-white text-slate-500 hover:border-teal-300 hover:text-teal-600 transition-colors disabled:opacity-30 disabled:pointer-events-none" aria-label="Next page"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>`;

      paginationEl.innerHTML = html;

      paginationEl.querySelectorAll<HTMLButtonElement>("button[data-page]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const p = parseInt(btn.dataset.page ?? "1", 10);
          if (p >= 1 && p <= totalPages) {
            currentPage = p;
            applyFilters();
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        });
      });
    }

    function updateChipStyles() {
      filterBtns.forEach((btn) => {
        const f = btn.dataset.filter ?? "";
        const isActive =
          f === "all" ? activeFilters.size === 0 : activeFilters.has(f);
        btn.classList.toggle("bg-teal-500", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-teal-500", isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-600", !isActive);
        btn.classList.toggle("border-slate-200", !isActive);
      });
    }

    searchInput?.addEventListener("input", () => {
      searchQuery = (searchInput.value ?? "").trim().toLowerCase();
      currentPage = 1;
      applyFilters();
    });

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter ?? "";
        if (f === "all") {
          activeFilters.clear();
        } else {
          if (activeFilters.has(f)) {
            activeFilters.delete(f);
          } else {
            activeFilters.add(f);
          }
        }
        currentPage = 1;
        updateChipStyles();
        applyFilters();
      });
    });

    applyFilters();
  </script>
