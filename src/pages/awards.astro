  <!-- ══════════════════════════════════════════════════════════════════════════
       SCROLL ANIMATIONS
       ══════════════════════════════════════════════════════════════════════════ -->
  <style>
    /* Hero trophy entrance */
    @keyframes hero-bounce {
      0% { opacity: 0; transform: scale(0.6) rotate(-10deg); }
      50% { transform: scale(1.05) rotate(2deg); }
      100% { opacity: 1; transform: scale(1) rotate(0deg); }
    }
    .animate-hero-bounce {
      animation: hero-bounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    /* Fade-up for scroll-triggered elements */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Stagger-in for child cards */
    @keyframes stagger-in {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Gold shimmer for section headings */
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }

    /* Remove footer margin gap on awards page (dark bg all the way down) */
    :global(footer) { margin-top: 0 !important; }

    [data-animate] {
      opacity: 0;
      transform: translateY(30px);
      transition: none;
    }
    [data-animate].is-visible {
      animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: var(--delay, 0s);
    }

    /* Shimmer effect on visible gold text */
    .is-visible .shimmer-gold {
      background: linear-gradient(90deg, #d4af37 0%, #f5d060 40%, #d4af37 60%, #f5d060 100%);
      background-size: 200% auto;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmer 3s linear infinite;
    }
  </style>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
  </script>

