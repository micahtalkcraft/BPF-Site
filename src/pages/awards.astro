---
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Award winners data
const awards = [
  {
    category: "Smoothest Onboarding & Account Access",
    winner: "DNA Funded",
    slug: "dna-funded",
    logo: "/images/logos/dna-funded-logo.png",
    observation: "Single-flow setup; trade immediately after signup",
    methodology: "At DNA Funded, challenge purchase, credential delivery, and platform access all occurred in a single uninterrupted flow, allowing us to place trades immediately after signup. There were no additional verification steps once access was granted, and the transition from purchase to first trade happened within the same session.",
    tradeoff: "The trade-off observed was a narrower choice of trading platforms compared to firms offering multiple environments.",
    icon: "rocket",
  },
  {
    category: "Most Stable Trading Platform Performance",
    winner: "Blueberry Funded",
    slug: "blueberry-funded",
    logo: "/images/logos/blueberry_funded_logo_dark.jpg",
    observation: "No observable lag during tested sessions; real-time metric updates",
    methodology: "At Blueberry Funded, trading and dashboard systems remained responsive during live trading sessions, with orders placed and managed without platform lag and account metrics updating in real time. Across repeated sessions, platform behaviour stayed consistent and predictable under normal trading conditions.",
    tradeoff: "Platform availability was still subject to scheduled maintenance windows, which temporarily restricted access outside active trading hours.",
    icon: "chart",
  },
  {
    category: "Most Consistent Rule Enforcement",
    winner: "FundedNext",
    slug: "fundednext",
    logo: "/images/logos/funded_next_dark.svg",
    observation: "Threshold-based enforcement; predictable progression",
    methodology: "At FundedNext, rule enforcement during testing was triggered automatically when predefined limits were approached or crossed, rather than through discretionary review. Phase progression and restriction logic followed the same pattern each time, making enforcement behaviour predictable during active trading.",
    tradeoff: "Some performance metrics required checking both the trading platform and the dashboard to view the full account picture.",
    icon: "shield",
  },
  {
    category: "Funded Account Scaling & Rewards",
    winner: "BrightFunded",
    slug: "brightfunded",
    logo: "/images/logos/brightfunded_dark.png",
    observation: "Scaling and account benefits unlocked through continued trading and completed payouts",
    methodology: "At BrightFunded, funded accounts were not treated as a static end state. After completing the evaluation, we verified that core risk limits, drawdown parameters, and position sizing rules carried over directly into the funded account without requiring strategy changes. Through the scaling plan and Trade2Earn rewards system, continued trading and completed payouts resulted in incremental account size increases.",
    tradeoff: "Account expansion and benefit access followed predefined milestones, so flexibility increased progressively rather than being available immediately at the funded stage.",
    icon: "trending",
  },
  {
    category: "Most Reliable Payout Behaviour",
    winner: "FundedNext",
    slug: "fundednext",
    logo: "/images/logos/funded_next_dark.svg",
    observation: "Automated status updates; no manual follow-up needed",
    methodology: "At FundedNext, when we submitted payout requests during testing, the process progressed through clearly defined stages without the need for manual follow-up. Status updates were reflected directly in the dashboard as each step completed, and access to subsequent account stages followed automatically once conditions were met. FundedNext also guarantees 24 hour payout processing.",
    tradeoff: null,
    icon: "payout",
  },
];

// Key findings
const keyFindings = [
  {
    area: "Reliability & Payouts",
    winners: "FundedNext and Blueberry Funded",
    detail: "Demonstrated the highest consistency in payout speeds and automated rule enforcement.",
  },
  {
    area: "Funded Account Progression",
    winners: "FundedNext and BrightFunded",
    detail: "Showed the strongest stability in funded account stage rule continuity and scaling access.",
  },
  {
    area: "Financial Market Access",
    winners: "FXIFY",
    detail: "Performed most consistently across futures execution and structured evaluation formats.",
  },
];

// Core performance table
const corePerformance = [
  { category: "Smoothest Onboarding and Account Access", winner: "DNA Funded", observation: "Single-flow setup; trade immediately after signup" },
  { category: "Most Stable Trading Platform Performance", winner: "Blueberry Funded", observation: "No observable lag during tested sessions; real-time metric updates" },
  { category: "Most Consistent Rule Enforcement Observed", winner: "FundedNext", observation: "Threshold-based enforcement; predictable progression" },
  { category: "Funded Account Scaling and Rewards", winner: "FundedNext & BrightFunded", observation: "Scaling and account benefits unlocked through continued trading and completed payouts" },
  { category: "Most Reliable Payout Behaviour", winner: "FundedNext", observation: "Automated status updates; no manual follow-up needed" },
];

// 2. Challenge Structure Outcomes
const challengeStructure = [
  { category: "Instant Funding Outcomes", winner: "Blueberry Funded", slug: "blueberry-funded", logo: "/images/logos/blueberry_funded_logo_dark.jpg", observation: "Immediate trading access; no evaluation phase required" },
  { category: "One Step Challenge Outcomes", winner: "FXIFY", slug: "fxify", logo: "/images/logos/fxify_logo_dark.jpeg", observation: "Straightforward single-phase path; easy-to-track progress" },
  { category: "Two Step Challenge Outcomes", winner: "BrightFunded", slug: "brightfunded", logo: "/images/logos/brightfunded_dark.png", observation: "Clear progression between phases; dashboard reflects status" },
  { category: "Three Step Challenge Outcomes", winner: "FXIFY", slug: "fxify", logo: "/images/logos/fxify_logo_dark.jpeg", observation: "Staged requirements clearly tracked via phase markers" },
];

// 3. Market Access Outcomes
const marketAccess = [
  { category: "Futures Market Access", winner: "FXIFY Futures", slug: "fxify-futures", logo: "/images/logos/fxify-futures.png", observation: "Dedicated futures setup; session-based trading availability" },
  { category: "Crypto Market Access", winner: "BrightFunded", slug: "brightfunded", logo: "/images/logos/brightfunded_dark.png", observation: "Crypto available alongside traditional markets; managed in one account" },
  { category: "Forex Market Access", winner: "FundedNext", slug: "fundednext", logo: "/images/logos/funded_next_dark.svg", observation: "Consistent order handling; stable pricing during overlap" },
];

// 4. Trading Feature Outcomes
const tradingFeatures = [
  { category: "News Trading Compatibility", winner: "FundedNext", slug: "fundednext", logo: "/images/logos/funded_next_dark.svg", observation: "No discretionary breaches triggered by news volatility" },
  { category: "EA (Automated Trading) Compatibility", winner: "Blueberry Funded", slug: "blueberry-funded", logo: "/images/logos/blueberry_funded_logo_dark.jpg", observation: "EAs ran without interference; repeated entries handled correctly" },
  { category: "Support and Issue Resolution", winner: "Blueberry Funded", slug: "blueberry-funded", logo: "/images/logos/blueberry_funded_logo_dark.jpg", observation: "Replies aligned with dashboard status; resolved access issues fast" },
];

// 5. Operational Friction & Failure Analysis
const failureAnalysis = [
  { category: "Manual Rule Enforcement", impact: "High risk. Breaches relied on human review rather than code, leading to disputed failure notifications 24+ hours after the trade", frequency: "Medium" },
  { category: "Structural Instability", impact: "Execution risk. Material changes to rules or payout policies occurred retroactively after traders were funded", frequency: "Low" },
  { category: "Friction-Heavy Payouts", impact: "Cash flow delay. \u201CCompliance checks\u201D delayed payouts by 5\u20137 days beyond the advertised timeframe", frequency: "High" },
  { category: "Hidden Consistency Rules", impact: "Payout denial. \u201CSoft\u201D rules around lot size consistency were applied to deny payouts despite a profit", frequency: "Medium" },
];

// Failure deep-dives
const failureDeepDives = [
  {
    title: "Impact of Manual Rule Enforcement",
    icon: "shield",
    issue: "At prop trading firms like Apex Trader Funding and Elite Trader Funding, we observed that daily drawdown limits were often calculated at End of Day (EOD) or via periodic server checks rather than tick-by-tick.",
    consequence: "This creates a \u201CSilent Breach\u201D risk. A trader can unknowingly violate a drawdown limit mid-session, continue trading for hours, and only receive a failure notification the next day, wasting time and effort on a dead account.",
  },
  {
    title: "Payout Friction & Delays",
    icon: "clock",
    issue: "During testing on Blue Guardian and The Funded Trader, we recorded payout delays attributed to manual \u201Ccompliance reviews.\u201D While eventually paid, the funds arrived 5\u20137 days later than the policy stated.",
    consequence: "For experienced traders relying on cash flow, these unpredictable delays make it impossible to treat prop trading as a reliable income stream compared to automated firms like FundedNext.",
  },
  {
    title: "Hidden Trading Rules Trap",
    icon: "eye",
    issue: "In tests of Alpha Capital and Goat Funded Trader, we noted complex \u201CConsistency Rules\u201D that were not enforced by the platform code.",
    consequence: "Traders often pass the profit target but fail the manual review phase because one trade size deviated slightly from their average. Unlike our winners (which hard-code these limits), these manual firms often flag this only after the challenge is complete, leading to denied funding.",
  },
];
---

<Base
  title="Prop Firm Awards 2026 — Testing Results | BestPropFirms.com"
  description="2026 Prop Firm Testing Results: operational performance awards based on live challenge purchases and first-hand testing of 39 proprietary trading firms."
>

  <!-- ══════════════════════════════════════════════════════════════════════════
       HERO — Prestigious gold design
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0a0a0a]">
    <!-- Gold radial glow -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/4 h-[600px] w-[800px] rounded-full bg-[radial-gradient(ellipse,rgba(212,175,55,0.15),transparent_70%)]"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 h-[400px] w-[600px] rounded-full bg-[radial-gradient(ellipse,rgba(212,175,55,0.08),transparent_70%)]"></div>
    </div>
    <!-- Subtle grid pattern -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0h60v60H0z' fill='none' stroke='%23d4af37' stroke-width='0.5'/%3E%3C/svg%3E&quot;);"></div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">
      <!-- Trophy icon -->
      <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br from-[#d4af37] via-[#f5d060] to-[#d4af37] shadow-lg shadow-[#d4af37]/20 animate-hero-bounce">
        <svg class="h-11 w-11 text-[#0a0a0a]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
        </svg>
      </div>

      <!-- Badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#d4af37]/30 bg-[#d4af37]/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-[#d4af37]">
        <span class="h-1.5 w-1.5 rounded-full bg-[#d4af37]"></span>
        2026 Testing Cycle
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-4">
        <span class="bg-gradient-to-r from-[#d4af37] via-[#f5d060] to-[#d4af37] bg-clip-text text-transparent">Prop Firm Testing Results</span>
        <br />
        <span class="text-white">2026</span>
      </h1>

      <p class="text-base sm:text-lg text-slate-400 mb-8 max-w-2xl mx-auto leading-relaxed">
        This report documents the operational performance of <span class="font-bold text-white">39 proprietary trading firms</span> tested during the 2026 cycle.
      </p>

      <!-- Meta badges -->
      <div class="flex flex-wrap items-center justify-center gap-3 text-xs">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-400">
          <svg class="h-3 w-3 text-[#d4af37]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          Updated: 15/01/2026
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-slate-400">
          <svg class="h-3 w-3 text-[#d4af37]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Fact Checked
        </span>
      </div>
    </div>

    <!-- Bottom gold divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-[#d4af37]/40 to-transparent"></div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       METHODOLOGY INTRO
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#0d1117] py-12 px-4">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <p class="text-sm text-slate-400 leading-relaxed">
        Unlike comparisons based on advertised features, the results are derived from <span class="font-semibold text-white">challenge account purchases and first-hand testing</span>. We evaluate prop firms using a standardized Retail Trader Path audit, including working through the evaluation process, funded account access, rule-boundary interaction, and withdrawal processing, to validate observed operational behaviour under real prop trading conditions.
      </p>
    </div>

    <!-- Category tabs visual -->
    <div class="mx-auto max-w-3xl mt-8 flex flex-wrap items-center justify-center gap-2">
      {["Challenge Structures", "Market Access", "Trading Features", "Failure Analysis"].map((tab) => (
        <span class="rounded-full border border-[#d4af37]/20 bg-[#d4af37]/5 px-4 py-1.5 text-xs font-semibold text-[#d4af37]">
          {tab}
        </span>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       KEY FINDINGS SUMMARY
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#0a0a0a] py-16 px-4">
    <div class="mx-auto max-w-5xl" data-animate>
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-[#d4af37] mb-2">Aggregated Results</p>
        <h2 class="text-3xl font-black text-white">2026 Key Findings Summary</h2>
        <p class="text-sm text-slate-500 mt-2">Aggregated performance results from our live testing database</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {keyFindings.map((finding) => (
          <div class="relative overflow-hidden rounded-xl border border-[#d4af37]/20 bg-gradient-to-b from-[#d4af37]/5 to-transparent p-6">
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#d4af37]/60 to-transparent"></div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#d4af37]/70 mb-2">{finding.area}</p>
            <p class="text-lg font-black text-white mb-2">{finding.winners}</p>
            <p class="text-xs text-slate-400 leading-relaxed">{finding.detail}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-slate-500 mt-6 text-center italic">
        The outcomes below reflect repeatable operational behaviour recorded during live testing, rather than marketing claims.
      </p>
    </div>
  </section>

  <!-- Gold separator -->
  <div class="h-px bg-gradient-to-r from-transparent via-[#d4af37]/30 to-transparent"></div>

  <!-- ══════════════════════════════════════════════════════════════════════════
       CORE PERFORMANCE TABLE
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#0d1117] py-16 px-4">
    <div class="mx-auto max-w-5xl" data-animate>
      <div class="text-center mb-10">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#d4af37]/10">
          <svg class="h-6 w-6 text-[#d4af37]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-2xl font-black text-white mb-1">1. Core Performance Outcomes</h2>
        <p class="text-sm text-slate-500">Which prop firms demonstrated the most repeatable operational performance during live testing</p>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto rounded-xl border border-white/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#d4af37]/10 border-b border-[#d4af37]/20">
              <th class="px-5 py-3 text-left text-[10px] font-bold uppercase tracking-widest text-[#d4af37]">Category</th>
              <th class="px-5 py-3 text-left text-[10px] font-bold uppercase tracking-widest text-[#d4af37]">Winner (2026)</th>
              <th class="px-5 py-3 text-left text-[10px] font-bold uppercase tracking-widest text-[#d4af37]">Key Observation</th>
            </tr>
          </thead>
          <tbody>
            {corePerformance.map((row, i) => (
              <tr class={`border-b border-white/5 ${i % 2 === 0 ? 'bg-white/[0.02]' : ''}`}>
                <td class="px-5 py-3.5 text-slate-300 font-medium">{row.category}</td>
                <td class="px-5 py-3.5 text-white font-bold">{row.winner}</td>
                <td class="px-5 py-3.5 text-slate-400">{row.observation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Gold separator -->
  <div class="h-px bg-gradient-to-r from-transparent via-[#d4af37]/30 to-transparent"></div>

  <!-- ══════════════════════════════════════════════════════════════════════════
       OVERALL WINNERS SHOWCASE (moved here — right after core performance)
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="relative bg-[#0a0a0a] py-20 px-4 overflow-hidden">
    <!-- Background gold glows -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 h-[400px] w-[400px] rounded-full bg-[radial-gradient(ellipse,rgba(212,175,55,0.06),transparent_70%)]"></div>
      <div class="absolute top-1/2 right-1/4 translate-x-1/2 -translate-y-1/2 h-[400px] w-[400px] rounded-full bg-[radial-gradient(ellipse,rgba(212,175,55,0.06),transparent_70%)]"></div>
    </div>

    <div class="relative mx-auto max-w-5xl" data-animate>
      <div class="text-center mb-14">
        <!-- Trophy row -->
        <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-[#d4af37] via-[#f5d060] to-[#b8960c] shadow-xl shadow-[#d4af37]/20">
          <svg class="h-8 w-8 text-[#0a0a0a]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
          </svg>
        </div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37] mb-3">Prop Firm Overall Winners</p>
        <h2 class="text-3xl sm:text-4xl font-black text-white">Award Winners 2026</h2>
      </div>

      <!-- Award cards -->
      <div class="space-y-8">
        {awards.map((award, i) => (
          <div class="group relative overflow-hidden rounded-2xl border border-[#d4af37]/20 bg-gradient-to-br from-[#141414] to-[#0d0d0d] hover:border-[#d4af37]/40 transition-all duration-300" data-animate style={`--delay: ${i * 0.1}s`}>
            <!-- Top gold accent -->
            <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-[#d4af37] to-transparent opacity-60 group-hover:opacity-100 transition-opacity"></div>

            <div class="p-6 sm:p-8">
              <!-- Award header -->
              <div class="flex flex-col sm:flex-row items-start gap-5">
                <!-- Logo + trophy badge -->
                <div class="relative flex-shrink-0">
                  <div class="h-20 w-20 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden p-2">
                    <img
                      src={`${base}${award.logo}`}
                      alt={award.winner}
                      class="h-full w-full object-contain rounded-lg"
                      loading="lazy"
                    />
                  </div>
                  <!-- Trophy badge -->
                  <div class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-br from-[#d4af37] via-[#f5d060] to-[#d4af37] shadow-lg shadow-[#d4af37]/30">
                    <svg class="h-3.5 w-3.5 text-[#0a0a0a]" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                    </svg>
                  </div>
                </div>

                <!-- Text content -->
                <div class="flex-1 min-w-0">
                  <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#d4af37] mb-1">{award.category}</p>
                  <div class="flex items-center gap-3 flex-wrap mb-2">
                    <h3 class="text-2xl font-black text-white">
                      <a href={`${base}/reviews/${award.slug}`} class="hover:text-[#d4af37] transition-colors">
                        {award.winner}
                      </a>
                    </h3>
                    <span class="inline-flex items-center gap-1 rounded-full bg-[#d4af37]/10 border border-[#d4af37]/20 px-2.5 py-0.5 text-[10px] font-bold text-[#d4af37] uppercase tracking-wider">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      Winner
                    </span>
                  </div>
                  <p class="text-sm text-slate-400 mb-4 leading-relaxed italic">"{award.observation}"</p>
                </div>
              </div>

              <!-- Methodology detail -->
              <div class="mt-4 rounded-xl bg-white/[0.03] border border-white/5 p-5">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">Methodology</p>
                <p class="text-sm text-slate-400 leading-relaxed">{award.methodology}</p>
                {award.tradeoff && (
                  <p class="text-sm text-slate-500 leading-relaxed mt-3 italic">{award.tradeoff}</p>
                )}
              </div>

              <!-- CTA -->
              <div class="mt-5 flex items-center gap-3">
                <a
                  href={`${base}/reviews/${award.slug}`}
                  class="inline-flex items-center gap-1.5 rounded-lg bg-gradient-to-r from-[#d4af37] to-[#b8960c] px-4 py-2 text-sm font-bold text-[#0a0a0a] hover:from-[#f5d060] hover:to-[#d4af37] transition-all shadow-sm shadow-[#d4af37]/20"
                >
                  Read Full Review
