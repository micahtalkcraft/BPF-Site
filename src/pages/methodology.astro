---
import Base from "../layouts/Base.astro";

const categories = [
  {
    num: "01",
    title: "Challenge Accounts",
    slug: "challenge-accounts",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/challenge-accounts-scoring.png",
    description:
      "We evaluate the transparency and accessibility of each firm's challenge structure. A fair challenge should give traders a genuine opportunity to prove their skills without unreasonable barriers.",
    factors: [
      "Challenge Levels — variety of funding tiers from $5K to $500K+",
      "Profit Targets — Phase 1 and Phase 2 targets assessed for achievability (ideally under 10% and 5%)",
      "Drawdown Limits — flexible daily/overall limits (e.g. 5% daily, 10% overall)",
      "Challenge Flexibility — one-step, two-step, and custom formats plus fee accessibility",
      "Additional Policies — inactivity rules, consistency requirements, and refund policies",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Low fees, flexible drawdown, achievable targets, varied challenge formats" },
      { range: "6–8 / 10", label: "Good", desc: "Moderate fees, standard conditions, limited flexibility" },
      { range: "0–5 / 10", label: "Poor", desc: "High fees, restrictive drawdowns, targets above 12%" },
    ],
  },
  {
    num: "02",
    title: "Spreads & Commission Fees",
    slug: "spreads-commissions",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/spreads-and-commission-fees-scoring.png",
    description:
      "Trading costs directly impact a trader's ability to profit. We focus on transparency and competitiveness of spreads and commissions, since inflated costs can erode returns even with a strong win rate.",
    factors: [
      "Forex Spreads — tighter spreads (below 0.5 pips for EUR/USD) receive top marks",
      "Commission Fees — low, consistent rates prioritised over variable or hidden charges",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Sub-0.5 pip spreads, low commission up to $3.50 per lot" },
      { range: "6–8 / 10", label: "Good", desc: "Around 1 pip spread, fair commission (~$4.50 per lot)" },
      { range: "0–5 / 10", label: "Poor", desc: "Above 1.5 pip spreads, high or unclear fees" },
    ],
  },
  {
    num: "03",
    title: "Financial Markets & Leverage",
    slug: "markets-leverage",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/financial-markets-and-leverage-scoring.png",
    description:
      "Access to diverse markets and sensible leverage allows traders to employ a wider range of strategies. We assess both breadth and balance — leverage that is too restrictive limits strategies; leverage that is too high increases risk.",
    factors: [
      "Market Range — wide access including forex, indices, commodities, and crypto",
      "Leverage Levels — typically up to 50:1 for forex, balanced against risk management policies",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Forex, indices, commodities, and crypto; 50:1 leverage" },
      { range: "6–8 / 10", label: "Good", desc: "Basic forex and indices; standard leverage" },
      { range: "0–5 / 10", label: "Poor", desc: "Limited markets, overly restricted or excessively high leverage" },
    ],
  },
  {
    num: "04",
    title: "Trading Platforms",
    slug: "trading-platforms",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/trading-platforms-scoring.png",
    description:
      "The quality and reliability of the trading platform affects execution, analysis, and overall trading experience. We assess platform choice, stability, and the depth of available tools.",
    factors: [
      "Platform Options — MT4, MT5, cTrader, and proprietary platforms rated on availability",
      "Advanced Tools — risk management, charting capabilities, and order type breadth",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Full platform range, advanced charting, robust order types" },
      { range: "6–8 / 10", label: "Good", desc: "Limited platform selection, basic tools" },
      { range: "0–5 / 10", label: "Poor", desc: "Performance issues, minimal features, poor execution" },
    ],
  },
  {
    num: "05",
    title: "Payments & Profit Payouts",
    slug: "payouts",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/payments-and-profit-payouts-scoring.png",
    description:
      "Reliable and frequent payouts are critical for traders who depend on their funded accounts. This category carries significant weight because a firm's payout record directly reflects trustworthiness.",
    factors: [
      "Profit Split — higher percentages (above 80%) scored better",
      "Payout Frequency — weekly or bi-weekly payouts with low minimums preferred",
      "Withdrawal Methods — breadth of options including crypto, bank transfer, and payment processors",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "80%+ split, weekly payouts, low withdrawal minimums" },
      { range: "6–8 / 10", label: "Good", desc: "Standard splits (75–80%), bi-weekly payouts" },
      { range: "0–5 / 10", label: "Poor", desc: "Low split, high minimums, infrequent or delayed payouts" },
    ],
  },
  {
    num: "06",
    title: "Customer Service & Education",
    slug: "support-education",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/customer-service-and-education-scoring.png",
    description:
      "Responsive support and quality educational resources help traders succeed, especially newer traders entering prop trading for the first time. We evaluate both availability and quality.",
    factors: [
      "Support Availability — 24/7 support with live chat, email, or phone access rated highly",
      "Educational Resources — tutorials, webinars, and relevant training content enhance scores",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "24/7 support, live chat, extensive educational content" },
      { range: "6–8 / 10", label: "Good", desc: "Limited support hours, basic tutorials" },
      { range: "0–5 / 10", label: "Poor", desc: "Delayed responses, minimal educational content" },
    ],
  },
  {
    num: "07",
    title: "Trust & Community",
    slug: "trust-community",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/trust-and-community-scoring.png",
    description:
      "We assess the reputation, transparency, and community presence of each firm. Trust is non-negotiable — firms with poor track records, unclear fee structures, or suspicious reviews are scored accordingly.",
    factors: [
      "Reputation — high Trustpilot scores and independent review platform ratings",
      "Broker Partnerships — connections to regulated brokers and clear company ownership",
      "Trading Community — active social media, Discord, and forum presence",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Positive reviews, active community, fully transparent fees and ownership" },
      { range: "6–8 / 10", label: "Good", desc: "Mixed reviews, moderate community presence" },
      { range: "0–5 / 10", label: "Poor", desc: "Poor reviews, limited transparency, unclear ownership" },
    ],
  },
  {
    num: "08",
    title: "Sign-Up Process",
    slug: "sign-up",
    image: "https://www.bestpropfirms.com/wp-content/uploads/2025/05/sign-up-process-scoring.png",
    description:
      "A streamlined onboarding experience signals that a firm respects traders' time. We assess clarity, speed, and the KYC verification process to ensure traders can get started without unnecessary friction.",
    factors: [
      "Simplicity and Speed — streamlined forms and immediate challenge access prioritised",
      "KYC Requirements — clear, transparent verification processes that protect both parties",
    ],
    scale: [
      { range: "9–10 / 10", label: "Excellent", desc: "Simple sign-up, clear KYC, immediate challenge access" },
      { range: "6–8 / 10", label: "Good", desc: "Moderate steps, standard KYC process" },
      { range: "0–5 / 10", label: "Poor", desc: "Complicated or unclear process, lengthy or opaque KYC" },
    ],
  },
];
---

<Base
  title="Our Methodology — How We Score & Rank Prop Firms | BestPropFirms.com"
  description="Our independent scoring methodology covers 8 categories: challenge accounts, spreads, markets, platforms, payouts, support, trust, and sign-up. No paid placements, ever."
>
  <!-- Hero -->
  <section class="bg-[#0d1b2a] text-white py-16 px-4">
    <div class="mx-auto max-w-4xl sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Transparency First</p>
      <h1 class="text-4xl font-black mb-4">Our Methodology</h1>
      <p class="text-slate-300 text-lg max-w-2xl leading-relaxed">
        Every firm on BestPropFirms.com is independently reviewed and scored across 8 categories.
        No firm can pay for a better ranking. Here is exactly how we do it.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">

    <!-- Overview card -->
    <div class="bg-white border border-slate-200 rounded-2xl p-8 mb-12 shadow-sm">
      <h2 class="text-2xl font-black text-slate-900 mb-3">How We Grade Prop Firms in 2026</h2>
      <p class="text-slate-600 leading-relaxed mb-4">
        Our goal is to help traders identify the best prop firm for their strategy by comparing features,
        trading costs, and execution quality. Rankings are centred on the factors that matter most to funded
        traders: profit payouts, account costs, leverage availability, and funding steps.
      </p>
      <p class="text-slate-600 leading-relaxed mb-6">
        Each firm receives a score out of 100, calculated as a weighted average across 8 independently assessed
        categories. Challenge accounts and profit payouts carry the highest weighting due to their direct
        financial impact on traders. Support and community contributions enhance overall accessibility ratings.
      </p>

      <!-- Category quick-list -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {categories.map((cat) => (
          <a
            href={`#${cat.slug}`}
            class="group flex flex-col items-center gap-1.5 rounded-xl border border-slate-200 bg-slate-50 hover:border-teal-300 hover:bg-teal-50 p-3 text-center transition-colors"
          >
            <span class="text-[11px] font-black text-teal-500 uppercase tracking-wider">{cat.num}</span>
            <span class="text-xs font-semibold text-slate-700 group-hover:text-teal-700 leading-tight">{cat.title}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Overall scoring table -->
    <div class="mb-12 rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
      <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
        <h2 class="text-lg font-black text-slate-900">Overall Score Classifications</h2>
        <p class="text-sm text-slate-500 mt-0.5">How individual category scores combine into a final rating</p>
      </div>
      <div class="divide-y divide-slate-100">
        <div class="flex items-center gap-4 px-6 py-4">
          <div class="flex-shrink-0 w-28">
            <span class="inline-flex items-center rounded-full bg-green-500 px-3 py-1 text-sm font-black text-white">80–100</span>
          </div>
          <div>
            <p class="font-bold text-slate-900">Outstanding</p>
            <p class="text-sm text-slate-500">Excellent performance across all 8 categories with no significant weaknesses</p>
          </div>
        </div>
        <div class="flex items-center gap-4 px-6 py-4">
          <div class="flex-shrink-0 w-28">
            <span class="inline-flex items-center rounded-full bg-yellow-400 px-3 py-1 text-sm font-black text-white">60–79</span>
          </div>
          <div>
            <p class="font-bold text-slate-900">Good</p>
            <p class="text-sm text-slate-500">Strong overall balance with minor limitations in one or two categories</p>
          </div>
        </div>
        <div class="flex items-center gap-4 px-6 py-4">
          <div class="flex-shrink-0 w-28">
            <span class="inline-flex items-center rounded-full bg-red-500 px-3 py-1 text-sm font-black text-white">0–59</span>
          </div>
          <div>
            <p class="font-bold text-slate-900">Below Average</p>
            <p class="text-sm text-slate-500">Significant limitations across multiple categories that may disadvantage traders</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Category sections -->
    <div class="space-y-0">
      {categories.map((cat, catIdx) => (
        <section id={cat.slug} class={`scroll-mt-20 ${catIdx > 0 ? "mt-20 pt-20 border-t border-slate-200" : "mt-12"}`}>
          <!-- Section header -->
          <div class="flex items-center gap-3 mb-6">
            <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-teal-500 flex items-center justify-center text-xs font-black text-white">{cat.num}</span>
            <h2 class="text-2xl font-black text-slate-900">{cat.title}</h2>
          </div>

          <!-- Description -->
          <p class="text-slate-600 leading-relaxed mb-6">{cat.description}</p>

          <!-- Scoring image -->
          <div class="mb-6 rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
            <img
              src={cat.image}
              alt={`${cat.title} scoring breakdown`}
              class="w-full h-auto"
              loading="lazy"
            />
          </div>

          <!-- Two-column: factors + scale -->
          <div class="grid sm:grid-cols-2 gap-6">
            <!-- What we assess -->
            <div class="bg-slate-50 rounded-xl border border-slate-200 p-5">
              <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-3">What We Assess</p>
              <ul class="space-y-2">
                {cat.factors.map((f) => (
                  <li class="flex items-start gap-2 text-sm text-slate-700">
                    <svg class="mt-0.5 h-3.5 w-3.5 flex-shrink-0 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Scoring scale -->
            <div class="bg-white rounded-xl border border-slate-200 p-5">
              <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-3">Scoring Scale</p>
              <div class="space-y-3">
                {cat.scale.map((s, idx) => (
                  <div class="flex items-start gap-3">
                    <span class={`flex-shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-black text-white whitespace-nowrap ${idx === 0 ? "bg-green-500" : idx === 1 ? "bg-yellow-400" : "bg-red-500"}`}>
                      {s.range}
                    </span>
                    <div>
                      <p class="text-xs font-bold text-slate-800">{s.label}</p>
                      <p class="text-xs text-slate-500 leading-snug">{s.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Editorial independence note -->
    <div class="mt-16 rounded-2xl border border-teal-200 bg-teal-50 p-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-teal-500 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="white" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="text-lg font-black text-teal-900">Editorial Independence</h3>
      </div>
      <p class="text-sm text-teal-800 leading-relaxed mb-3">
        No prop firm can pay for a better score or ranking on BestPropFirms.com. Our methodology is applied
        consistently to every firm we review, regardless of any affiliate relationship.
      </p>
      <p class="text-sm text-teal-800 leading-relaxed">
        We keep our reviews current — firms that cease operations or fundamentally change their conditions
        are updated or removed from rankings accordingly. If you spot data that needs updating, contact us.
      </p>
    </div>

    <!-- Methodology version -->
    <p class="mt-8 text-center text-xs text-slate-400">
      Methodology version 1.0 · Last updated February 2026
    </p>

  </div>
</Base>
