---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import FirmListIsland from "../components/prop-firms/FirmListIsland";
import type { FirmItem } from "../components/prop-firms/FirmListIsland";
import * as flags from "country-flag-icons/string/3x2";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const propFirms = await getCollection("prop-firms");
const reviews = await getCollection("reviews");

const reviewMap = Object.fromEntries(reviews.map((r) => [r.data.propFirmId, r.data]));

const totalFirms = propFirms.length;

// Build serialisable data for the React island — sort first to assign stable ranks
const sortedFirms = [...propFirms].sort((a, b) => {
  if (a.data.status !== b.data.status) return a.data.status === "active" ? -1 : 1;
  const as = reviewMap[a.data.id]?.overallScore ?? 0;
  const bs = reviewMap[b.data.id]?.overallScore ?? 0;
  return bs - as;
});

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "BestPropFirms.com",
    url: "https://www.bestpropfirms.com",
    description: "Independent, data-driven rankings and reviews of proprietary trading firms.",
    potentialAction: {
      "@type": "SearchAction",
      target: "https://www.bestpropfirms.com/reviews?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "BestPropFirms.com",
    url: "https://www.bestpropfirms.com",
    logo: "https://www.bestpropfirms.com/favicon.svg",
    sameAs: [],
  },
];

// Slugs of firms that won 2026 awards
const awardWinnerSlugs = new Set(["dna-funded", "blueberry-funded", "fundednext", "brightfunded", "fxify", "fxify-futures"]);

// Broker-backed firms
const brokerBackedSlugs = new Set(["dna-funded", "blueberry-funded", "fundednext", "ic-funded", "fxify-futures", "fxify", "oanda", "fundednext-futures", "hantec-trader", "alpha-capital"]);

const videos = [
  { id: "1otayPx_z1s", title: "The5ers Prop Firm Review | We Tested the Challenge", views: "2.5K", timeAgo: "3 weeks ago" },
  { id: "oIPQPwGXGac", title: "BEST Futures Prop Firms in 2025", views: "5.1K", timeAgo: "1 month ago" },
  { id: "dZ7gorgnMvU", title: "The BEST Prop Firms in 2025", views: "12K", timeAgo: "2 months ago" },
  { id: "QHPnbIvv2qA", title: "The BEST 3 Prop Firms for CANADIAN Traders", views: "3.8K", timeAgo: "6 weeks ago" },
];

const firmItems: FirmItem[] = sortedFirms.map((f, idx) => {
  const review = reviewMap[f.data.id];
  const fees = f.data.pricing.challengeFees;
  const lowestFee = fees.length > 0 ? fees.reduce((m, x) => x.fee < m.fee ? x : m).fee : null;
  return {
    id: f.data.id,
    slug: f.data.slug,
    name: f.data.name,
    status: f.data.status,
    rank: idx + 1,
    evaluationTypes: f.data.evaluation.types,
    maxDrawdown: f.data.evaluation.maxDrawdown,
    dailyDrawdown: f.data.evaluation.dailyDrawdown,
    splitMax: f.data.payouts.splitMax,
    platforms: f.data.markets.platforms,
    lowestFee,
    overallScore: review?.overallScore,
    trustpilotRating: f.data.trust.trustpilotRating,
    tags: (f.data.custom as any)?.tags ?? [],
    discountCode: (f.data.custom as any)?.discountCode,
    discountPercent: (f.data.custom as any)?.discountPercent,
    logoUrl: f.data.media?.logo,
    website: f.data.links?.website,
    hasReview: !!review,
    flagged: review?.flagged === true,
    isAwardWinner: awardWinnerSlugs.has(f.data.slug),
    isBrokerBacked: brokerBackedSlugs.has(f.data.slug),
    foundedYear: f.data.foundedYear,
    hqCountry: f.data.hqCountry,
    flagDataUri: f.data.hqCountry
      ? `data:image/svg+xml,${encodeURIComponent((flags as Record<string, string>)[f.data.hqCountry.toUpperCase()] ?? '')}`
      : undefined,
  };
});
---

<Base
  title="Best Prop Trading Firms 2026 — Ranked & Reviewed | BestPropFirms.com"
  description="Independent, data-driven rankings of the best proprietary trading firms. Compare challenge fees, drawdown rules, payout splits, and trust scores. Zero paid placements."
  jsonLd={jsonLd}
>
  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative bg-[#0d1b2a] text-white overflow-hidden">
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
      <div class="h-[500px] w-[700px] rounded-full bg-teal-500/10 blur-3xl"></div>
    </div>
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='80' height='80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0h80v80H0z' fill='none' stroke='white' stroke-width='0.5'/%3E%3C/svg%3E&quot;);"></div>
    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-24 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-slate-300">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400"></span>
        Independent · Unsponsored · Data-Verified
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6">
        Find a Prop Firm<br />
        <span class="text-teal-400">You Can Actually Trust</span>
      </h1>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto leading-relaxed">
        Every ranking is built from a single verified data record. Transparent scores across <span class="font-bold text-white">{totalFirms} evaluated firms</span> — no guesswork, no paid placements.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={`${base}/reviews`} class="w-full sm:w-auto rounded-lg bg-teal-500 px-6 py-3 font-semibold text-white hover:bg-teal-400 transition-colors shadow-lg shadow-teal-500/20">
          See All Rankings
        </a>
        <a href={`${base}/offers`} class="w-full sm:w-auto rounded-lg border border-white/20 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
          View Exclusive Offers →
        </a>
      </div>
    </div>
  </section>

  <!-- ── As Seen On ─────────────────────────────────────────────────────────── -->
  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-400 text-center mb-5">As Seen On</p>
      <div class="flex items-center justify-center gap-6 sm:gap-14 lg:gap-20 opacity-60 grayscale overflow-hidden">
        <img src={`${base}/images/press/cnn-logo.png`} alt="CNN" class="h-6 sm:h-9 w-auto object-contain flex-shrink-0 max-w-[20%] sm:max-w-none" loading="lazy" />
        <img src={`${base}/images/press/client-logo1.png`} alt="CBS News" class="h-6 sm:h-9 w-auto object-contain flex-shrink-0 max-w-[20%] sm:max-w-none" loading="lazy" />
        <img src={`${base}/images/press/client-logo6.png`} alt="Yahoo" class="h-6 sm:h-9 w-auto object-contain flex-shrink-0 max-w-[20%] sm:max-w-none" loading="lazy" />
        <img src={`${base}/images/press/afr-logo.png`} alt="Financial Review" class="h-5 sm:h-8 w-auto object-contain flex-shrink-0 max-w-[20%] sm:max-w-none" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ── All Firms (searchable) ────────────────────────────────────────────── -->
  <section id="firms" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">Complete Rankings</p>
        <h2 class="text-3xl font-black text-slate-900">All Prop Firms Ranked</h2>
        <p class="text-sm text-slate-500 mt-1">Sorted by our score — filter and search below</p>
      </div>
      <a href={`${base}/reviews`} class="text-sm font-semibold text-teal-600 hover:text-teal-500 transition-colors whitespace-nowrap hidden sm:block">
        Detailed reviews →
      </a>
    </div>

    <FirmListIsland firms={firmItems} basePath={import.meta.env.BASE_URL.replace(/\/$/, '')} client:load />
  </section>

  <!-- ── Latest Videos ──────────────────────────────────────────────────── -->
  <section class="bg-white border-t border-slate-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">Latest Videos</p>
          <h2 class="text-3xl font-black text-slate-900">Watch Our Latest Content</h2>
        </div>
        <a href="https://www.youtube.com/@propfirms/videos" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-teal-600 hover:text-teal-500 transition-colors whitespace-nowrap hidden sm:block">
          View all videos →
        </a>
      </div>

      <!-- Video cards — horizontal scroll on mobile, grid on sm+ -->
      <div class="relative">
        <div id="video-scroll" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 lg:grid-cols-4 sm:overflow-visible scrollbar-hide" style="-ms-overflow-style:none;scrollbar-width:none;">
          {videos.map((video) => (
            <a
              href={`https://www.youtube.com/watch?v=${video.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex-shrink-0 w-[75vw] sm:w-auto snap-start"
            >
              <!-- Thumbnail -->
              <div class="relative aspect-video rounded-xl overflow-hidden bg-slate-100 mb-3 shadow-sm">
                <img
                  src={`https://i.ytimg.com/vi/${video.id}/mqdefault.jpg`}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <!-- Dark overlay on hover -->
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-200" />
                <!-- Play button -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="h-11 w-11 rounded-full bg-red-600 flex items-center justify-center shadow-lg opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all duration-200">
                    <svg class="h-5 w-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <!-- Info -->
              <h3 class="font-bold text-slate-900 text-sm leading-snug line-clamp-2 group-hover:text-teal-600 transition-colors mb-1">{video.title}</h3>
              <p class="text-xs text-slate-400">{video.views} views · {video.timeAgo}</p>
            </a>
          ))}
        </div>

        <!-- Mobile scroll arrows -->
        <button
          id="vid-prev"
          class="sm:hidden absolute -left-1 top-[25%] -translate-y-1/2 z-10 h-9 w-9 rounded-full bg-white border border-slate-200 shadow-md flex items-center justify-center text-slate-500 hover:text-teal-600 hover:border-teal-300 transition-colors"
          aria-label="Previous video"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button
          id="vid-next"
          class="sm:hidden absolute -right-1 top-[25%] -translate-y-1/2 z-10 h-9 w-9 rounded-full bg-white border border-slate-200 shadow-md flex items-center justify-center text-slate-500 hover:text-teal-600 hover:border-teal-300 transition-colors"
          aria-label="Next video"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <!-- Mobile "View all" link -->
      <div class="mt-4 text-center sm:hidden">
        <a href="https://www.youtube.com/@propfirms/videos" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-teal-600 hover:text-teal-500 transition-colors">
          View all videos →
        </a>
      </div>

      <!-- YouTube channel bar -->
      <div class="mt-8 flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50 px-5 py-3.5">
        <div class="flex items-center gap-3">
          <!-- YouTube icon -->
          <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-red-600 flex items-center justify-center">
            <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-slate-900 text-sm">Best PropFirms</p>
            <p class="text-xs text-slate-400">1.3K subscribers · 44 videos</p>
          </div>
        </div>
        <a
          href="https://www.youtube.com/@propfirms?sub_confirmation=1"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full bg-red-600 hover:bg-red-700 px-4 py-2 text-xs font-bold text-white transition-colors shadow-sm"
        >
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Subscribe
        </a>
      </div>
    </div>
  </section>

  <script>
    // Video carousel scroll arrows (mobile only)
    const scrollEl = document.getElementById("video-scroll");
    const prevBtn = document.getElementById("vid-prev");
    const nextBtn = document.getElementById("vid-next");
    if (scrollEl && prevBtn && nextBtn) {
      const getCardWidth = () => {
        const card = scrollEl.querySelector("a");
        if (!card) return 300;
        return card.getBoundingClientRect().width + 16; // card width + gap
      };
      prevBtn.addEventListener("click", () => {
        scrollEl.scrollBy({ left: -getCardWidth(), behavior: "smooth" });
      });
      nextBtn.addEventListener("click", () => {
        scrollEl.scrollBy({ left: getCardWidth(), behavior: "smooth" });
      });
    }
  </script>

  <!-- ── How We Review ─────────────────────────────────────────────────────── -->
  <section class="bg-slate-50 border-t border-slate-200 py-16 px-4">
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Our Process</p>
        <h2 class="text-3xl font-black text-slate-900">How We Review Prop Firms</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-50 border border-teal-200 text-teal-600 text-lg font-black">1</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Research</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We read the firm's official terms, challenge rules, payout policies, and T&Cs. All data sourced directly — no third-party aggregators.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-50 border border-teal-200 text-teal-600 text-lg font-black">2</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Score</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Each firm is scored across 7 categories: Trust, Conditions, Pricing, Platforms, Payouts, Support, and UX — using our published methodology.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal-50 border border-teal-200 text-teal-600 text-lg font-black">3</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Publish</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Data stored in one canonical record. Every metric on every page flows from that source — no duplicated values, no stale data.</p>
        </div>
      </div>
      <div class="mt-10 text-center">
        <a href={`${base}/methodology`} class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 transition-colors">
          Read the full methodology →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Discord Banner ────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="relative overflow-hidden rounded-2xl border border-[#5865F2]/20 shadow-xl">
      <!-- Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#5865F2] via-[#4752C4] to-[#3C45A5]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_80%_-10%,rgba(255,255,255,0.12),transparent)]"></div>
      <div class="pointer-events-none absolute -right-12 -bottom-12 h-56 w-56 rounded-full bg-white/5 blur-3xl"></div>

      <div class="relative px-6 py-8 sm:px-10 sm:py-10 flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-6 md:gap-10">
        <!-- Discord logo -->
        <div class="flex-shrink-0">
          <div class="flex h-16 w-16 sm:h-20 sm:w-20 items-center justify-center rounded-2xl bg-white/15 backdrop-blur-sm shadow-lg">
            <svg class="h-10 w-10 sm:h-12 sm:w-12 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z" />
            </svg>
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-[11px] font-bold text-white/90 uppercase tracking-widest">
            <span class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
            3,800+ Members Online
          </div>
          <h2 class="text-2xl sm:text-3xl font-black text-white mb-2">
            Join The Trading Desk
          </h2>
          <p class="text-sm text-white/70 leading-relaxed max-w-lg md:max-w-lg mx-auto md:mx-0">
            Connect with thousands of prop firm traders. Get real-time deal alerts, payout proof, firm updates, and trading discussion — all in one place.
          </p>
        </div>

        <!-- CTA -->
        <div class="flex-shrink-0">
          <a
            href="#"
            class="group inline-flex items-center gap-2.5 rounded-xl bg-white px-6 py-3.5 font-bold text-[#5865F2] shadow-lg transition-all duration-200 hover:shadow-xl hover:scale-[1.02] active:scale-[0.98]"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z" />
            </svg>
            Join Discord Server
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────────────── -->
  <section class="bg-slate-50 py-16 px-4">
    <div class="mx-auto max-w-3xl sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Got Questions?</p>
        <h2 class="text-3xl font-black text-slate-900">Frequently Asked Questions</h2>
        <p class="text-sm text-slate-500 mt-2">Everything you need to know about prop trading firms and how we rank them.</p>
      </div>

      <div class="space-y-3">
        <!-- FAQ 1 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            What is a prop trading firm?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            A proprietary trading firm (prop firm) provides traders with capital to trade financial markets. Instead of risking your own money, you trade the firm's capital and share a percentage of the profits. Most firms require you to pass an evaluation or challenge before receiving a funded account.
          </div>
        </details>

        <!-- FAQ 2 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            How does the Broker Score work?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            Our Broker Score is a proprietary rating from 0-100 based on our hands-on testing. We purchase challenges with our own money and evaluate: platform stability, execution speed, spread consistency, payout reliability, customer support quality, and rule transparency. We do not use user reviews or affiliate incentives in our scoring.
          </div>
        </details>

        <!-- FAQ 3 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            What's the difference between instant funding and evaluation programs?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            Instant funding gives you immediate access to a funded account without passing a challenge, typically with lower profit splits or higher fees. Evaluation programs require you to hit profit targets while following trading rules, usually offering better profit splits once you pass.
          </div>
        </details>

        <!-- FAQ 4 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            How do payouts work at prop firms?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            After generating profits on your funded account, you can request a payout according to the firm's schedule (daily, weekly, bi-weekly, or monthly). Payouts are typically processed via bank transfer, cryptocurrency, or payment processors like PayPal. The firm keeps their percentage, and you receive your share.
          </div>
        </details>

        <!-- FAQ 5 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            Are prop firms legitimate or scams?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            The prop trading industry includes both legitimate firms and questionable operators. We only feature firms we've personally tested and received payouts from. Look for firms with transparent rules, verified payout history, responsive support, and realistic trading conditions.
          </div>
        </details>

        <!-- FAQ 6 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            Can US traders use prop firms?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            Yes, but options are more limited due to regulatory restrictions. Many international prop firms don't accept US clients, while others have specific programs for US traders. We clearly mark which firms accept US traders in our reviews and filters.
          </div>
        </details>

        <!-- FAQ 7 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            What platforms do prop firms offer?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            Most prop firms offer MetaTrader 4 (MT4), MetaTrader 5 (MT5), or cTrader. Some newer firms also support TradingView for charting with proprietary execution. The platform availability often depends on the broker the prop firm uses for execution.
          </div>
        </details>

        <!-- FAQ 8 -->
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-slate-300">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-sm font-bold text-slate-900 select-none [&::-webkit-details-marker]:hidden">
            How much capital can I get from a prop firm?
            <svg class="h-4 w-4 flex-shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
            Initial funded account sizes typically range from $10,000 to $200,000. Many firms offer scaling programs where you can increase your account size by demonstrating consistent profitability, with some programs reaching up to $2 million or more.
          </div>
        </details>
      </div>
    </div>
