  <script>
    const searchInput = document.getElementById("offer-search") as HTMLInputElement | null;
    const sortBtns = document.querySelectorAll<HTMLButtonElement>(".offer-sort-chip");
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-offer-card]"));
    const countEl = document.getElementById("offer-results-count");
    const listEl = document.getElementById("offers-list");

    let searchQuery = "";
    let activeSort = "percent";

    function getVisible(): HTMLElement[] {
      return cards.filter((c) => c.dataset.name?.includes(searchQuery));
    }

    function sortCards(visible: HTMLElement[]) {
      if (activeSort === "name") {
        visible.sort((a, b) => (a.dataset.name ?? "").localeCompare(b.dataset.name ?? ""));
      } else if (activeSort === "rating") {
        visible.sort((a, b) => parseFloat(b.dataset.rating ?? "0") - parseFloat(a.dataset.rating ?? "0"));
      } else {
        visible.sort((a, b) => parseFloat(b.dataset.percent ?? "0") - parseFloat(a.dataset.percent ?? "0"));
      }
      return visible;
    }

    function applyFilters() {
      const visible = getVisible();
      const sorted = sortCards(visible);
      const hiddenSet = new Set(cards.filter((c) => !visible.includes(c)));

      cards.forEach((c) => (c.style.display = hiddenSet.has(c) ? "none" : ""));

      // Re-order in DOM
      if (listEl) {
        sorted.forEach((c) => listEl.appendChild(c));
      }

      if (countEl) {
        countEl.textContent = visible.length === cards.length ? "" : `${visible.length} of ${cards.length} offers`;
      }
    }

    function updateSortStyles() {
      sortBtns.forEach((btn) => {
        const s = btn.dataset.sort ?? "";
        const isActive = s === activeSort;
        btn.classList.toggle("bg-teal-500", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-teal-500", isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-600", !isActive);
        btn.classList.toggle("border-slate-200", !isActive);
      });
    }

    searchInput?.addEventListener("input", () => {
      searchQuery = (searchInput.value ?? "").trim().toLowerCase();
      applyFilters();
    });

    sortBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeSort = btn.dataset.sort ?? "percent";
        updateSortStyles();
        applyFilters();
      });
    });
  </script>

