---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import FirmAvatar from "../components/shared/FirmAvatar.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const propFirms = await getCollection("prop-firms");
const reviews = await getCollection("reviews");

const reviewMap = Object.fromEntries(reviews.map((r) => [r.data.propFirmId, r.data]));

const awardWinnerSlugs = new Set(["dna-funded", "blueberry-funded", "fundednext", "brightfunded", "fxify", "fxify-futures"]);

// Featured offers = ones with a discountCode on the firm, sorted by % desc, capped at 4
const allOffers = propFirms
  .map((f) => {
    const code = (f.data.custom as any)?.discountCode as string | undefined;
    const percent = (f.data.custom as any)?.discountPercent as number | undefined;
    const desc = ((f.data.custom as any)?.discountDesc as string | undefined) ??
      (percent ? `${percent}% off on all challenge fees` : undefined);
    const review = reviewMap[f.data.id];
    const hasReview = !!review;
    const verified = review?.verified !== false;
    const flagged = review?.flagged === true;
    const isAwardWinner = awardWinnerSlugs.has(f.data.slug);
    return { firm: f.data, code, percent, desc, hasReview, verified, flagged, isAwardWinner };
  })
  .filter((x) => x.code && (x.percent || x.desc))
  .sort((a, b) => (b.percent ?? 0) - (a.percent ?? 0));

const featuredOffers = allOffers.filter((x) => x.percent);
const featuredGrid = featuredOffers.slice(0, 4);
---

<Base
  title="Best Prop Firm Discount Codes & Offers 2026 | BestPropFirms.com"
  description="Exclusive discount codes and limited-time offers on prop firm challenge fees. Save up to 90% with verified coupon codes."
>
  <!-- Page header -->
  <section class="bg-[#0d1b2a] text-white py-14 px-4">
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Exclusive Deals</p>
      <h1 class="text-4xl font-black mb-3">Prop Firm Offers & Discounts</h1>
      <p class="text-slate-300 text-lg max-w-2xl">
        Verified discount codes and exclusive offers — updated monthly. Never pay full price on a challenge.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-12">

    <!-- ── Featured offers grid (max 4) ──────────────────────────────────── -->
    {featuredGrid.length > 0 && (
      <section>
        <div class="mb-6">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">February 2026</p>
          <h2 class="text-2xl font-black text-slate-900">Featured Offers This Month</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {featuredGrid.map(({ firm, code, percent, hasReview, verified, flagged, isAwardWinner }) => (
            <div class="group bg-white border border-slate-200 rounded-xl overflow-hidden hover:border-orange-300 hover:shadow-md transition-all duration-200">
              <!-- Top accent -->
              <div class="h-1 bg-gradient-to-r from-orange-500 to-orange-300"></div>
              <div class="p-4">
                <!-- Firm info -->
                <div class="flex items-center gap-2.5 mb-3">
                  <FirmAvatar name={firm.name} logoUrl={firm.media?.logo ? `${base}${firm.media.logo}` : undefined} size="sm" />
                  <div class="min-w-0">
                    <div class="flex items-center gap-1.5">
                      <p class="text-sm font-bold text-slate-900 leading-tight truncate">{firm.name}</p>
                      {hasReview && !flagged && verified && (
                        <svg class="h-[16px] w-[16px] text-[#1d9bf0] flex-shrink-0" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                          <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
                        </svg>
                      )}
                      {isAwardWinner && (
                        <span class="inline-flex items-center justify-center h-[16px] w-[16px] rounded-full bg-gradient-to-br from-amber-400 via-yellow-300 to-amber-500 shadow-sm shadow-amber-400/40 flex-shrink-0">
                          <svg class="h-2 w-2 text-amber-900" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                          </svg>
                        </span>
                      )}
                    </div>
                    {firm.trust.trustpilotRating && (
                      <p class="text-[10px] text-slate-400">{firm.trust.trustpilotRating} ★ Trustpilot</p>
                    )}
                  </div>
                </div>
                <!-- Discount badge -->
                <div class="rounded-xl border-2 border-orange-200 bg-orange-50 p-3 text-center mb-3">
                  <p class="text-2xl font-black text-orange-600 leading-none">{percent}% OFF</p>
                </div>
                <!-- Code -->
                <button
                  class="w-full flex items-center justify-between rounded-lg border border-dashed border-slate-200 hover:border-orange-400 bg-slate-50 hover:bg-orange-50 px-3 py-2 transition-all cursor-pointer group/btn"
                  onclick={`navigator.clipboard.writeText('${code}').then(()=>{const el=this.querySelector('.copy-label');el.textContent='Copied!';setTimeout(()=>{el.textContent='${code}'},1500)})`}
                >
                  <span class="copy-label text-xs font-black text-slate-800 tracking-wider">{code}</span>
                  <svg class="h-3.5 w-3.5 text-slate-400 group-hover/btn:text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── All offers list ──────────────────────────────────────────────── -->
    <section>
      <div class="mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">All Discounts</p>
        <h2 class="text-2xl font-black text-slate-900">Current Prop Firm Offers</h2>
        <p class="text-sm text-slate-500 mt-1">Click any code to copy it instantly</p>
      </div>

      <div class="space-y-4">
        {allOffers.map(({ firm, code, percent, desc, hasReview, verified, flagged, isAwardWinner }) => (
          <div class="group relative bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-teal-300 hover:shadow-lg hover:shadow-teal-500/10 transition-all duration-200">
            <!-- Left accent bar -->
            <span class="absolute left-0 top-6 bottom-6 w-1 rounded-r-full bg-gradient-to-b from-teal-400 to-teal-600 opacity-0 group-hover:opacity-100 transition-opacity duration-200" />

            {/* ── DESKTOP layout (sm+) ── */}
            <div class="hidden sm:flex items-stretch">

              <!-- Left: % OFF panel -->
              <div class="flex-shrink-0 w-28 bg-gradient-to-br from-slate-50 to-white border-r border-slate-100 flex flex-col items-center justify-center p-3">
                <div class="w-full rounded-2xl border-2 border-teal-200 bg-teal-50 flex flex-col items-center justify-center py-3 px-1">
                  {percent ? (
                    <Fragment>
                      <span class="text-2xl font-black text-teal-600 leading-none">{percent}%</span>
                      <span class="text-[9px] font-bold uppercase tracking-widest text-teal-400 mt-0.5">OFF</span>
                    </Fragment>
                  ) : (
                    <Fragment>
                      <svg class="h-6 w-6 text-teal-500 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-[9px] font-bold uppercase tracking-widest text-teal-500">DEAL</span>
                    </Fragment>
                  )}
                </div>
              </div>

              <!-- Middle: firm info -->
              <div class="flex-1 min-w-0 px-6 py-5 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-2">
                  <FirmAvatar name={firm.name} logoUrl={firm.media?.logo ? `${base}${firm.media.logo}` : undefined} />
                  <div class="min-w-0">
                    <div class="flex items-center gap-1.5">
                      <p class="font-extrabold text-slate-900 text-lg leading-tight truncate">{firm.name}</p>
                      {hasReview && !flagged && verified && (
                        <svg class="h-[18px] w-[18px] text-[#1d9bf0] flex-shrink-0" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                          <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
                        </svg>
                      )}
                      {isAwardWinner && (
                        <span class="inline-flex items-center justify-center h-[18px] w-[18px] rounded-full bg-gradient-to-br from-amber-400 via-yellow-300 to-amber-500 shadow-sm shadow-amber-400/40 flex-shrink-0">
                          <svg class="h-2.5 w-2.5 text-amber-900" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                          </svg>
                        </span>
                      )}
                    </div>
                    {firm.trust.trustpilotRating && (
                      <div class="flex items-center gap-1 mt-0.5">
                        <span class="text-amber-400 text-xs">{'★'.repeat(Math.round(firm.trust.trustpilotRating))}</span>
                        <span class="text-[11px] text-slate-400">{firm.trust.trustpilotRating} · {firm.trust.trustpilotCount?.toLocaleString()} reviews</span>
                      </div>
                    )}
                  </div>
                </div>
                {desc && (
                  <div class="mt-2 pt-2 border-t border-slate-100">
                    <p class="text-sm text-slate-500">{desc}</p>
                  </div>
                )}
              </div>

              <!-- Code button (desktop) -->
              <div class="flex-shrink-0 flex items-center px-6 border-l border-slate-100">
                <div>
                  <p class="text-[10px] text-slate-400 uppercase tracking-wide font-semibold mb-2 text-center">Coupon Code</p>
                  <button
                    class="group/btn flex items-center gap-2 rounded-xl border-2 border-dashed border-amber-300 bg-amber-50 hover:bg-amber-100 hover:border-amber-400 px-5 py-2.5 transition-all cursor-pointer shadow-sm hover:shadow-md"
                    onclick={`navigator.clipboard.writeText('${code}').then(()=>{const el=this.querySelector('.copy-label');el.textContent='Copied!';setTimeout(()=>{el.textContent='${code}'},1500)})`}
                  >
                    <span class="copy-label font-black text-amber-700 tracking-widest text-base">{code}</span>
                    <svg class="h-4 w-4 text-amber-500 group-hover/btn:text-amber-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                </div>
              </div>

              <!-- CTA column -->
              <div class="flex-shrink-0 flex flex-col items-center justify-center gap-2.5 px-6 border-l border-slate-100">
                <a
                  href={firm.links?.website ?? '#'}
                  target="_blank"
                  rel="noopener noreferrer nofollow sponsored"
                  class="inline-flex items-center justify-center gap-1.5 rounded-xl bg-teal-500 hover:bg-teal-600 px-5 py-3 text-sm font-bold text-white transition-colors whitespace-nowrap shadow-md shadow-teal-500/20 hover:shadow-lg hover:shadow-teal-500/30 w-full"
                >
                  Claim Offer
                  <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
                <a
                  href={`${base}/reviews/${firm.slug}`}
                  class="text-[11px] font-medium text-slate-400 hover:text-teal-600 transition-colors whitespace-nowrap"
                >
                  Read Review →
                </a>
              </div>

            </div>

            {/* ── MOBILE layout (below sm) ── */}
            <div class="sm:hidden p-4">
              <!-- Top row: discount + firm name -->
              <div class="flex items-center gap-3 mb-3">
                <div class="flex-shrink-0 rounded-xl border-2 border-teal-200 bg-teal-50 flex flex-col items-center justify-center w-16 h-16">
                  {percent ? (
                    <Fragment>
                      <span class="text-xl font-black text-teal-600 leading-none">{percent}%</span>
                      <span class="text-[7px] font-bold uppercase tracking-widest text-teal-400 mt-0.5">OFF</span>
                    </Fragment>
                  ) : (
                    <Fragment>
                      <svg class="h-5 w-5 text-teal-500 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-[7px] font-bold uppercase tracking-widest text-teal-500">DEAL</span>
                    </Fragment>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2.5">
                    <FirmAvatar name={firm.name} logoUrl={firm.media?.logo ? `${base}${firm.media.logo}` : undefined} />
                    <div class="min-w-0">
                      <div class="flex items-center gap-1.5">
                        <p class="font-extrabold text-slate-900 text-lg leading-tight truncate">{firm.name}</p>
                        {hasReview && !flagged && verified && (
                          <svg class="h-[16px] w-[16px] text-[#1d9bf0] flex-shrink-0" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                            <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
                          </svg>
                        )}
                        {isAwardWinner && (
                          <span class="inline-flex items-center justify-center h-[16px] w-[16px] rounded-full bg-gradient-to-br from-amber-400 via-yellow-300 to-amber-500 shadow-sm shadow-amber-400/40 flex-shrink-0">
                            <svg class="h-2 w-2 text-amber-900" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                            </svg>
                          </span>
                        )}
                      </div>
                      {firm.trust.trustpilotRating && (
                        <div class="flex items-center gap-1 mt-0.5">
                          <span class="text-amber-400 text-xs">{'★'.repeat(Math.round(firm.trust.trustpilotRating))}</span>
                          <span class="text-[11px] text-slate-400">{firm.trust.trustpilotRating}</span>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>

              {desc && (
                <div class="border-t border-slate-100 pt-2 mb-3">
                  <p class="text-xs text-slate-500">{desc}</p>
                </div>
              )}

              <!-- Code + CTA row -->
              <div class="flex gap-2">
                <button
                  class="group/btn flex-1 flex items-center justify-center gap-2 rounded-xl border-2 border-dashed border-amber-300 bg-amber-50 hover:bg-amber-100 px-3 py-3 cursor-pointer transition-all"
                  onclick={`navigator.clipboard.writeText('${code}').then(()=>{const el=this.querySelector('.copy-label-m');el.textContent='Copied!';setTimeout(()=>{el.textContent='${code}'},1500)})`}
                >
                  <svg class="h-4 w-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                  <span class="copy-label-m font-black text-amber-700 tracking-widest text-sm">{code}</span>
                </button>
                <a
                  href={firm.links?.website ?? '#'}
                  target="_blank"
                  rel="noopener noreferrer nofollow sponsored"
                  class="flex-shrink-0 inline-flex items-center justify-center gap-1.5 rounded-xl bg-teal-500 hover:bg-teal-600 px-5 py-3 text-sm font-bold text-white transition-colors shadow-md shadow-teal-500/20"
                >
                  Claim
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>

              <a
                href={`${base}/reviews/${firm.slug}`}
                class="block text-center text-[11px] font-medium text-slate-400 hover:text-teal-600 transition-colors mt-2.5"
              >
                Read Full Review →
              </a>
            </div>

          </div>
        ))}
      </div>
    </section>
  </div>
</Base>
