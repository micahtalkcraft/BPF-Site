---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import FirmAvatar from "../components/shared/FirmAvatar.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import { getPublisherSchema, getBreadcrumbSchema, SITE_URL } from "../helpers/schema";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const propFirms = await getCollection("prop-firms");
const reviews = await getCollection("reviews");

const reviewMap = Object.fromEntries(reviews.map((r) => [r.data.propFirmId, r.data]));

const awardWinnerSlugs = new Set(["dna-funded", "blueberry-funded", "fundednext", "brightfunded", "fxify", "fxify-futures"]);

// Featured offers = ones with a discountCode on the firm, sorted by % desc, capped at 4
const allOffers = propFirms
  .map((f) => {
    const code = (f.data.custom as any)?.discountCode as string | undefined;
    const percent = (f.data.custom as any)?.discountPercent as number | undefined;
    const desc = ((f.data.custom as any)?.discountDesc as string | undefined) ??
      (percent ? `${percent}% off on all challenge fees` : undefined);
    const savingNote = (f.data.custom as any)?.discountSavingNote as string | undefined;
    const review = reviewMap[f.data.id];
    const hasReview = !!review;
    const verified = review?.verified !== false;
    const flagged = review?.flagged === true;
    const isAwardWinner = awardWinnerSlugs.has(f.data.slug);
    return { firm: f.data, code, percent, desc, savingNote, hasReview, verified, flagged, isAwardWinner };
  })
  .filter((x) => x.code && (x.percent || x.desc))
  .sort((a, b) => (b.percent ?? 0) - (a.percent ?? 0));

// Hand-picked featured offers with descriptions
const featuredSlugs = ["dna-funded", "ic-funded", "blueberry-funded", "brightfunded"];
const featuredDescriptions: Record<string, string> = {
  "dna-funded": "25% off all challenge fees. Broker-backed with tight spreads, flexible evaluation models, and fast payouts.",
  "ic-funded": "25% off every challenge. Backed by IC Markets with raw spreads and up to 90% profit split.",
  "blueberry-funded": "20% off all challenges. ASIC-backed broker with 1,100+ instruments and scaling to $2M.",
  "brightfunded": "20% off challenge fees. Industry-leading loyalty program with profit splits scaling to 100%.",
};
const offerMap = Object.fromEntries(allOffers.map((x) => [x.firm.slug, x]));
const featuredGrid = featuredSlugs.map((s) => offerMap[s]).filter(Boolean);

// Challenge fee data for the "Challenges" tab — $100K fees with discount applied
const challengeRows = allOffers
  .map(({ firm, code, percent, savingNote, hasReview, verified, flagged, isAwardWinner }) => {
    const fees = (firm.pricing?.challengeFees ?? []) as Array<{ accountSize: number; fee: number; model?: string; label?: string }>;
    const oneStep100K = fees.find((f) => f.accountSize === 100000 && (f.model === "1-step" || f.model === "one-step"));
    const any100K = fees.find((f) => f.accountSize === 100000);
    const fee100K = oneStep100K ?? any100K;
    if (!fee100K) return null;
    const normalPrice = fee100K.fee;
    const pct = percent ?? 0;
    const discountedPrice = pct ? Math.round(normalPrice * (1 - pct / 100)) : normalPrice;
    const saving = normalPrice - discountedPrice;
    return {
      firm,
      code,
      percent: pct,
      normalPrice,
      discountedPrice,
      saving,
      model: (fee100K.model === "one-step" ? "1-step" : fee100K.model) ?? "challenge",
      label: fee100K.label,
      savingNote,
      hasReview,
      verified,
      flagged,
      isAwardWinner,
    };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .sort((a, b) => a.discountedPrice - b.discountedPrice);

const faqs = [
  { q: "What is a prop trading code?", a: "A prop trading code is a discount code that reduces the cost of your prop firm challenge, helping you save money upfront. At Best Prop Firms, we offer exclusive codes that you won't find elsewhere, giving you access to the best deals in the industry. Our codes cover trusted firms like FundedNext Futures, FXIFY, and DNA Funded, with savings of up to 26%. Check this page often for the latest working promo codes." },
  { q: "How to get a free prop firm account?", a: "To get a free prop firm account, follow Best Prop Firms on social media for a chance to enter exclusive giveaways and draws. We regularly host promotions where traders can win funded accounts from firms like BrightFunded and FXIFY. By staying connected on platforms like X and Facebook, you'll never miss an opportunity to save on challenge fees or even secure a fully funded trading account for free." },
  { q: "Is prop trading worth it?", a: "Prop trading is worth it if you want to trade large capital without risking your own funds, and at Best Prop Firms, we help you find the best opportunities. With access to scaling programs, payout guarantees, and refund offers from leading prop firms, traders can build sustainable income streams. However, success in prop trading depends on sticking to the firm's rules, managing risk carefully, and choosing the right firm that matches your trading style." },
  { q: "Which prop firm actually pays?", a: "Best Prop Firms only lists prop firms that we assess thoroughly for real payouts, reliable support, and trust factors. Firms like FundedNext Futures offer payout guarantees within 24 hours, while others like DNA Funded and IC Funded have verified payout histories. Our methodology for ranking prop firms looks at factors like trust scores, user reviews, payment speed, and transparency, before we make recommendations." },
  { q: "Do prop firm discount codes expire?", a: "Most prop firm discount codes listed on Best Prop Firms do not have a set expiration date and remain active for extended periods. However, promotional codes tied to seasonal events like Black Friday, Cyber Monday, or Valentine's Day are typically time-limited and will expire once the promotion ends. To make sure a code is still valid before you use it, check the \"Last verified\" date displayed next to each coupon on this page. We regularly verify every code so you can shop with confidence knowing the discount will apply at checkout." },
  { q: "Can you stack multiple prop firm discount codes?", a: "Whether you can combine multiple discount codes on a single purchase depends entirely on the prop firm. Some firms allow you to apply a promo code on top of an existing sale or bundle offer, while others restrict usage to one code per transaction. The best way to find out is to check the terms and conditions on the prop firm's website or try applying both codes at checkout. If stacking is not permitted, we recommend using whichever single code gives you the largest overall saving on your challenge fee." },
  { q: "Which prop firm has the biggest discount right now?", a: "The best way to find the biggest prop firm discount is to browse the full list of verified coupon codes above. You can compare percentage savings across every firm at a glance, and our Savings tab lets you see exactly how much you will pay for a $100K challenge after each discount is applied. Best Prop Firms negotiates industry-exclusive codes that are not available anywhere else, so the deals you see on this page often beat what you will find on the prop firm's own website. We update and verify codes regularly to make sure you always have access to the best possible price." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE_URL}/offers/#webpage`,
    url: `${SITE_URL}/offers/`,
    name: "Prop Firm Promo Codes & Discount Codes 2026 | BestPropFirms.com",
    description: "Find verified prop firm discount codes for 2026. Save up to 25% on DNA Funded, FXIFY, BrightFunded & more — updated monthly.",
    isPartOf: { "@id": `${SITE_URL}/#website` },
    publisher: { "@id": `${SITE_URL}/#organization` },
    datePublished: "2025-01-01",
    dateModified: "2026-03-12",
  },
  ...allOffers.map((offer) => ({
    "@context": "https://schema.org" as const,
    "@type": "Offer" as const,
    name: `${offer.firm.name} Discount Code${offer.percent ? ` — ${offer.percent}% Off` : ""}`,
    description: offer.desc ?? `Discount code for ${offer.firm.name} prop trading challenges`,
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: offer.firm.links?.website ?? `${SITE_URL}/offers/`,
    offeredBy: {
      "@type": "Organization" as const,
      name: offer.firm.name,
    },
    ...(offer.percent && { discount: `${offer.percent}%` }),
  })),
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question" as const,
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer" as const,
        text: faq.a,
      },
    })),
  },
  getBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Prop Firm Promo Codes & Discounts" },
  ]),
];
---

<Base
  title="Prop Firm Promo Codes & Discount Codes 2026 | BestPropFirms.com"
  description="Find verified prop firm discount codes for 2026. Save up to 25% on DNA Funded, FXIFY, BrightFunded & more — updated monthly."
  jsonLd={jsonLd}
>
  <!-- Page header -->
  <section class="bg-[#0d1b2a] text-white py-14 px-4">
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-400 mb-2">Exclusive Deals</p>
      <h1 class="text-4xl font-black mb-3">Prop Firm Promo Codes & Discount Codes 2026</h1>
      <p class="text-slate-300 text-sm max-w-2xl leading-relaxed">
        Find the best prop firm promo codes and discount codes for 2026, verified and updated monthly. We've negotiated exclusive codes across the top-rated prop firms, including DNA Funded, FXIFY, BrightFunded, and FundedNext, so you never pay full price on a challenge. Each code is manually tested before listing.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumbs crumbs={[{ name: "Home", url: "/" }, { name: "Offers" }]} />
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-12">

    <!-- ── Featured offers grid (max 4) ──────────────────────────────────── -->
    {featuredGrid.length > 0 && (
      <section>
        <div class="mb-6">
          <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">February 2026</p>
          <h2 class="text-2xl font-black text-slate-900">Featured Offers This Month</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {featuredGrid.map(({ firm, code, percent, hasReview, verified, flagged, isAwardWinner }) => (
            <div class="group bg-white border border-slate-200 rounded-xl overflow-hidden hover:border-orange-300 hover:shadow-md transition-all duration-200">
              <!-- Top accent -->
              <div class="h-1 bg-gradient-to-r from-orange-500 to-orange-300"></div>
              <div class="p-4 flex flex-col h-full">
                <!-- Firm info -->
                <div class="flex items-center gap-2.5 mb-3">
                  <FirmAvatar name={firm.name} logoUrl={firm.media?.logo ? `${base}${firm.media.logo}` : undefined} size="sm" />
                  <div class="min-w-0">
                    <div class="flex items-center gap-1.5">
                      <p class="text-sm font-bold text-slate-900 leading-tight truncate">{firm.name}</p>
                      {hasReview && !flagged && verified && (
                        <svg class="h-[16px] w-[16px] text-[#1d9bf0] flex-shrink-0" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                          <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
                        </svg>
                      )}
                      {isAwardWinner && (
                        <span class="inline-flex items-center justify-center h-[16px] w-[16px] rounded-full bg-gradient-to-br from-amber-400 via-yellow-300 to-amber-500 shadow-sm shadow-amber-400/40 flex-shrink-0">
                          <svg class="h-2 w-2 text-amber-900" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                          </svg>
                        </span>
                      )}
                    </div>
                    {firm.trust.trustpilotRating && (
                      <div class="flex items-center gap-1 mt-0.5 flex-wrap">
                        <span class="text-[10px] text-slate-400">{firm.trust.trustpilotRating} ★ Trustpilot</span>
                        <span class="text-[10px] text-slate-300">·</span>
                        <span class="text-[10px] text-slate-400 inline-flex items-center gap-0.5"><svg class="h-2.5 w-2.5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>Verified Mar 12, 2026</span>
                      </div>
                    )}
                  </div>
                </div>
                <!-- Discount badge -->
                <div class="rounded-xl border-2 border-orange-200 bg-orange-50 p-3 text-center mb-3">
                  <p class="text-2xl font-black text-orange-600 leading-none">{percent}% OFF</p>
                </div>
                <!-- Description -->
                {featuredDescriptions[firm.slug] && (
                  <p class="text-xs text-slate-500 leading-relaxed mb-3 flex-1">{featuredDescriptions[firm.slug]}</p>
                )}
                <!-- Code -->
                <button
                  class="w-full flex items-center justify-between rounded-lg border border-dashed border-slate-200 hover:border-orange-400 bg-slate-50 hover:bg-orange-50 px-3 py-2 transition-all cursor-pointer group/btn mt-auto"
                  onclick={`navigator.clipboard.writeText('${code}').then(()=>{const el=this.querySelector('.copy-label');el.textContent='Copied!';setTimeout(()=>{el.textContent='${code}'},1500)})`}
                >
                  <span class="copy-label text-xs font-black text-slate-800 tracking-wider">{code}</span>
                  <svg class="h-3.5 w-3.5 text-slate-400 group-hover/btn:text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── All offers list ──────────────────────────────────────────────── -->
    <section>
      <div class="mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-1">All Discounts</p>
        <h2 class="text-2xl font-black text-slate-900">Current Prop Firm Offers</h2>
        <p class="text-sm text-slate-500 mt-1">Click any code to copy it instantly</p>
      </div>

      <!-- Tab switcher -->
      <div class="flex gap-1 mb-6 rounded-xl p-1 w-fit border border-slate-200 bg-white shadow-sm">
        <button id="tab-savings" class="offer-tab px-6 py-2.5 rounded-lg text-sm font-bold transition-all bg-teal-500 text-white shadow-md shadow-teal-500/20 cursor-pointer">
          Coupons
        </button>
        <button id="tab-challenges" class="offer-tab px-6 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 cursor-pointer">
          Savings
        </button>
      </div>

      <!-- ── Panel container with slide animation ── -->
      <div class="relative overflow-hidden">
      <!-- ── SAVINGS PANEL ── -->
      <div id="panel-savings" class="transition-[transform,opacity] duration-300 ease-in-out">

      <!-- Filter bar -->
      <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center mb-6">
        <div class="relative flex-1 max-w-sm">
          <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
          </svg>
          <input
            id="offer-search"
            type="text"
            placeholder="Search offers…"
            class="w-full rounded-lg border border-slate-200 bg-white pl-9 pr-3 py-2 text-sm text-slate-800 placeholder:text-slate-400 focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100 transition"
          />
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide whitespace-nowrap">Sort:</span>
          <button data-sort="percent" class="offer-sort-chip rounded-full border px-3 py-1 text-xs font-semibold transition-colors bg-teal-500 text-white border-teal-500">Highest %</button>
          <button data-sort="name" class="offer-sort-chip rounded-full border px-3 py-1 text-xs font-semibold transition-colors bg-white text-slate-600 border-slate-200 hover:border-teal-300 hover:text-teal-600">A–Z</button>
          <button data-sort="rating" class="offer-sort-chip rounded-full border px-3 py-1 text-xs font-semibold transition-colors bg-white text-slate-600 border-slate-200 hover:border-teal-300 hover:text-teal-600">Trustpilot</button>
        </div>
        <p id="offer-results-count" class="text-xs text-slate-400 whitespace-nowrap sm:ml-auto"></p>
      </div>

      <div id="offers-list" class="space-y-4">
        {allOffers.map(({ firm, code, percent, desc, hasReview, verified, flagged, isAwardWinner }) => (
          <div
            class="group relative bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-teal-300 hover:shadow-lg hover:shadow-teal-500/10 transition-all duration-200"
            data-offer-card
            data-name={firm.name.toLowerCase()}
            data-percent={percent ?? 0}
            data-rating={firm.trust.trustpilotRating ?? 0}
          >
            <!-- Left accent bar -->
            <span class="absolute left-0 top-6 bottom-6 w-1 rounded-r-full bg-gradient-to-b from-teal-400 to-teal-600 opacity-0 group-hover:opacity-100 transition-opacity duration-200" />

            {/* ── DESKTOP layout (sm+) ── */}
            <div class="hidden sm:flex items-stretch">

              <!-- Left: % OFF panel -->
              <div class="flex-shrink-0 w-28 bg-gradient-to-br from-slate-50 to-white border-r border-slate-100 flex flex-col items-center justify-center p-3">
                <div class="w-full rounded-2xl border-2 border-teal-200 bg-teal-50 flex flex-col items-center justify-center py-3 px-1">
                  {percent ? (
                    <Fragment>
                      <span class="text-2xl font-black text-teal-600 leading-none">{percent}%</span>
                      <span class="text-[9px] font-bold uppercase tracking-widest text-teal-400 mt-0.5">OFF</span>
                    </Fragment>
                  ) : (
                    <Fragment>
                      <svg class="h-6 w-6 text-teal-500 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-[9px] font-bold uppercase tracking-widest text-teal-500">DEAL</span>
                    </Fragment>
                  )}
                </div>
              </div>

              <!-- Middle: firm info -->
              <div class="flex-1 min-w-0 px-6 py-5 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-2">
                  <FirmAvatar name={firm.name} logoUrl={firm.media?.logo ? `${base}${firm.media.logo}` : undefined} />
                  <div class="min-w-0">
                    <div class="flex items-center gap-1.5">
                      <p class="font-extrabold text-slate-900 text-lg leading-tight truncate">{firm.name}</p>
                      {hasReview && !flagged && verified && (
                        <svg class="h-[18px] w-[18px] text-[#1d9bf0] flex-shrink-0" viewBox="0 0 22 22" fill="currentColor" aria-label="Verified">
                          <path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.607-.274 1.264-.144 1.897.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681.132-.637.075-1.299-.165-1.903.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
                        </svg>
                      )}
                      {isAwardWinner && (
                        <span class="inline-flex items-center justify-center h-[18px] w-[18px] rounded-full bg-gradient-to-br from-amber-400 via-yellow-300 to-amber-500 shadow-sm shadow-amber-400/40 flex-shrink-0">
                          <svg class="h-2.5 w-2.5 text-amber-900" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                          </svg>
                        </span>
                      )}
                    </div>
                    {firm.trust.trustpilotRating && (
                      <div class="flex items-center gap-1 mt-0.5 flex-wrap">
                        <span class="text-amber-400 text-xs">{'★'.repeat(Math.round(firm.trust.trustpilotRating))}</span>
                        <span class="text-[11px] text-slate-400">{firm.trust.trustpilotRating}</span>
                        <span class="text-[11px] text-slate-300">·</span>
