  <script>
    // ── Savings tab: search + sort ──
    const searchInput = document.getElementById("offer-search") as HTMLInputElement | null;
    const sortBtns = document.querySelectorAll<HTMLButtonElement>(".offer-sort-chip");
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-offer-card]"));
    const countEl = document.getElementById("offer-results-count");
    const listEl = document.getElementById("offers-list");

    let searchQuery = "";
    let activeSort = "percent";

    function getVisible(): HTMLElement[] {
      return cards.filter((c) => c.dataset.name?.includes(searchQuery));
    }

    function sortCards(visible: HTMLElement[]) {
      if (activeSort === "name") {
        visible.sort((a, b) => (a.dataset.name ?? "").localeCompare(b.dataset.name ?? ""));
      } else if (activeSort === "rating") {
        visible.sort((a, b) => parseFloat(b.dataset.rating ?? "0") - parseFloat(a.dataset.rating ?? "0"));
      } else {
        visible.sort((a, b) => parseFloat(b.dataset.percent ?? "0") - parseFloat(a.dataset.percent ?? "0"));
      }
      return visible;
    }

    function applyFilters() {
      const visible = getVisible();
      const sorted = sortCards(visible);
      const hiddenSet = new Set(cards.filter((c) => !visible.includes(c)));

      cards.forEach((c) => (c.style.display = hiddenSet.has(c) ? "none" : ""));

      if (listEl) {
        sorted.forEach((c) => listEl.appendChild(c));
      }

      if (countEl) {
        countEl.textContent = visible.length === cards.length ? "" : `${visible.length} of ${cards.length} offers`;
      }
    }

    function updateSortStyles() {
      sortBtns.forEach((btn) => {
        const s = btn.dataset.sort ?? "";
        const isActive = s === activeSort;
        btn.classList.toggle("bg-teal-500", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-teal-500", isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-600", !isActive);
        btn.classList.toggle("border-slate-200", !isActive);
      });
    }

    searchInput?.addEventListener("input", () => {
      searchQuery = (searchInput.value ?? "").trim().toLowerCase();
      applyFilters();
    });

    sortBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeSort = btn.dataset.sort ?? "percent";
        updateSortStyles();
        applyFilters();
      });
    });

    // ── Tab switching ──
    const tabSavings = document.getElementById("tab-savings");
    const tabChallenges = document.getElementById("tab-challenges");
    const panelSavings = document.getElementById("panel-savings");
    const panelChallenges = document.getElementById("panel-challenges");

    let currentTab: "savings" | "challenges" = "savings";

    function setActiveTab(tab: "savings" | "challenges") {
      if (tab === currentTab) return;
      const isSavings = tab === "savings";
      const outgoing = isSavings ? panelChallenges : panelSavings;
      const incoming = isSavings ? panelSavings : panelChallenges;
      const slideOut = isSavings ? "translate-x-full" : "-translate-x-full";
      const slideIn = isSavings ? "-translate-x-full" : "translate-x-full";

      // Slide out current panel
      outgoing?.classList.add(slideOut, "opacity-0");
      setTimeout(() => {
        outgoing?.classList.add("hidden");
        outgoing?.classList.remove(slideOut, "opacity-0");

        // Prepare incoming off-screen, then slide in
        incoming?.classList.add(slideIn, "opacity-0");
        incoming?.classList.remove("hidden");
        // Force reflow so the browser registers the start position
        incoming?.offsetHeight;
        incoming?.classList.remove(slideIn, "opacity-0");
      }, 200);

      [tabSavings, tabChallenges].forEach((btn, i) => {
        const isActive = (i === 0 && isSavings) || (i === 1 && !isSavings);
        btn?.classList.toggle("bg-teal-500", isActive);
        btn?.classList.toggle("text-white", isActive);
        btn?.classList.toggle("shadow-md", isActive);
        btn?.classList.toggle("shadow-teal-500/20", isActive);
        btn?.classList.toggle("text-slate-500", !isActive);
      });
      currentTab = tab;
    }

    tabSavings?.addEventListener("click", () => setActiveTab("savings"));
    tabChallenges?.addEventListener("click", () => setActiveTab("challenges"));

    // ── Discount toggle ──
    const toggle = document.getElementById("discount-toggle");
    const toggleDot = document.getElementById("toggle-dot");
    const toggleLabel = document.getElementById("toggle-label");
    let discountsOn = true;

    function applyDiscountToggle() {
      document.querySelectorAll<HTMLElement>("[data-challenge-card]").forEach((card) => {
        card.querySelectorAll<HTMLElement>(".challenge-price-normal").forEach((el) => el.classList.toggle("hidden", discountsOn));
        card.querySelectorAll<HTMLElement>(".challenge-price-discounted").forEach((el) => el.classList.toggle("hidden", !discountsOn));
        card.querySelectorAll<HTMLElement>(".challenge-saving").forEach((el) => el.style.visibility = discountsOn ? "visible" : "hidden");
      });
      // Toggle button appearance
      if (toggle) {
        toggle.classList.toggle("bg-teal-500", discountsOn);
        toggle.classList.toggle("bg-slate-200", !discountsOn);
        toggle.setAttribute("aria-checked", String(discountsOn));
      }
      if (toggleDot) {
        toggleDot.classList.toggle("translate-x-5", discountsOn);
        toggleDot.classList.toggle("translate-x-0", !discountsOn);
      }
      if (toggleLabel) {
        toggleLabel.classList.toggle("text-teal-700", discountsOn);
        toggleLabel.classList.toggle("text-slate-500", !discountsOn);
      }
    }

    toggle?.addEventListener("click", () => {
      discountsOn = !discountsOn;
      applyDiscountToggle();
    });

    // ── Challenge tab: search + sort ──
    const cSearchInput = document.getElementById("challenge-search") as HTMLInputElement | null;
    const cSortBtns = document.querySelectorAll<HTMLButtonElement>(".challenge-sort-chip");
    const cCards = Array.from(document.querySelectorAll<HTMLElement>("[data-challenge-card]"));
    const cCountEl = document.getElementById("challenge-results-count");
    const cListEl = cCards[0]?.parentElement;

    let cSearchQuery = "";
    let cActiveSort = "price";

    function getCVisible(): HTMLElement[] {
      return cCards.filter((c) => (c.dataset.challengeName ?? "").includes(cSearchQuery));
    }

    function sortCCards(visible: HTMLElement[]) {
      if (cActiveSort === "name") {
        visible.sort((a, b) => (a.dataset.challengeName ?? "").localeCompare(b.dataset.challengeName ?? ""));
      } else if (cActiveSort === "percent") {
        visible.sort((a, b) => parseFloat(b.dataset.percent ?? "0") - parseFloat(a.dataset.percent ?? "0"));
      } else {
        // price — sort by discounted price if discounts on, normal otherwise
        visible.sort((a, b) => {
          const aPrice = discountsOn ? parseFloat(a.dataset.discounted ?? "0") : parseFloat(a.dataset.normal ?? "0");
          const bPrice = discountsOn ? parseFloat(b.dataset.discounted ?? "0") : parseFloat(b.dataset.normal ?? "0");
          return aPrice - bPrice;
        });
      }
      return visible;
    }

    function applyCFilters() {
      const visible = getCVisible();
      const sorted = sortCCards(visible);
      const hiddenSet = new Set(cCards.filter((c) => !visible.includes(c)));

      cCards.forEach((c) => (c.style.display = hiddenSet.has(c) ? "none" : ""));

      if (cListEl) {
        sorted.forEach((c) => cListEl.appendChild(c));
      }

      if (cCountEl) {
        cCountEl.textContent = visible.length === cCards.length ? "" : `${visible.length} of ${cCards.length} firms`;
      }
    }

    function updateCSortStyles() {
      cSortBtns.forEach((btn) => {
        const s = btn.dataset.csort ?? "";
        const isActive = s === cActiveSort;
        btn.classList.toggle("bg-teal-500", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-teal-500", isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-600", !isActive);
        btn.classList.toggle("border-slate-200", !isActive);
      });
    }

    cSearchInput?.addEventListener("input", () => {
      cSearchQuery = (cSearchInput.value ?? "").trim().toLowerCase();
      applyCFilters();
    });

    cSortBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        cActiveSort = btn.dataset.csort ?? "price";
        updateCSortStyles();
        applyCFilters();
      });
    });
  </script>

