---
import { getCollection } from "astro:content";
import { filterFirmsByRegion } from "../../config/currentRegion";

export async function getStaticPaths() {
  const propFirms = filterFirmsByRegion(await getCollection("prop-firms"));
  return propFirms.map((f) => ({
    params: { slug: f.data.slug },
    props: { slug: f.data.slug },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const { slug } = Astro.props;
return Astro.redirect(`${base}/reviews/${slug}`, 301);
---
